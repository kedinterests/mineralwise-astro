---
import "@/styles/starwind.css";
import BaseHead from '../components/BaseHead.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BelowContentAd from '../components/BelowContentAd.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

type AdConfig = 'none' | 'bc-only' | 'home';

interface Props {
	title?: string;
	description?: string;
	/** Max width of content area in px. Default 1000. Override for pages that need wider/narrower. */
	maxWidth?: number | string;
	/** Ad placement: none, bc-only (bc above footer), home (ac after hero in content + bc before footer). Default bc-only. */
	adConfig?: AdConfig;
}

const { 
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	maxWidth = 1000,
	adConfig = 'bc-only'
} = Astro.props;

const maxWidthValue = typeof maxWidth === 'number' ? `${maxWidth}px` : maxWidth;
const showBcAd = adConfig === 'bc-only' || adConfig === 'home';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<TopBar />
		<Header />
		<main style={`--container-max-width: ${maxWidthValue}`}>
			<slot />
		</main>
		{showBcAd && (
			<div class="ad-slot ad-bc">
				<BelowContentAd />
			</div>
		)}
		<Footer />
		<script is:inline>
			(function() {
				function isOnsite(href) {
					if (!href || href === '#' || href.startsWith('#')) return true;
					if (href.startsWith('/')) return true;
					try {
						const a = document.createElement('a');
						a.href = href;
						return a.hostname === window.location.hostname;
					} catch { return false; }
				}
				function processLinks() {
					document.querySelectorAll('a[href]').forEach(function(a) {
						const href = a.getAttribute('href');
						if (isOnsite(href)) {
							a.removeAttribute('target');
						} else {
							a.setAttribute('target', '_blank');
							var rel = (a.getAttribute('rel') || '').trim();
							if (!rel.includes('noopener')) rel += (rel ? ' ' : '') + 'noopener';
							if (!rel.includes('noreferrer')) rel += (rel ? ' ' : '') + 'noreferrer';
							a.setAttribute('rel', rel);
						}
					});
				}
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', processLinks);
				} else {
					processLinks();
				}
				document.addEventListener('astro:page-load', processLinks);
			})();
		</script>
	</body>
</html>

<style>
	main {
		min-height: calc(100vh - 200px);
	}
	.ad-slot {
		display: flex;
		justify-content: center;
		margin: 1rem 0;
		min-height: 50px;
	}
</style>
