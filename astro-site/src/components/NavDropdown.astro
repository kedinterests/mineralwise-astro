---
interface Props {
	item: {
		title: string;
		href: string;
		children?: Array<{
			title: string;
			href: string;
			external?: boolean;
		}>;
	};
	currentPath: string;
}

const { item, currentPath } = Astro.props;
const isActive = item.children?.some(child => currentPath === child.href) || false;
---

<div class="relative group flex items-center">
	<button
		class:list={{
			'text-1rem font-medium transition-colors flex items-center gap-1 leading-none': true,
			'text-gray-900 dark:text-white': !isActive,
			'text-blue-600 dark:text-blue-400': isActive,
			'hover:text-blue-600 dark:hover:text-blue-400': true,
		}}
		aria-expanded="false"
		aria-haspopup="true"
	>
		<span class="flex items-center">{item.title}</span>
		<svg
			class="h-4 w-4 transition-transform group-hover:rotate-180 flex-shrink-0"
			fill="none"
			viewBox="0 0 24 24"
			stroke="currentColor"
		>
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
		</svg>
	</button>
	<div class="absolute top-full left-0 mt-2 w-56 bg-white dark:bg-gray-900 rounded-lg shadow-lg border border-gray-200 dark:border-gray-800 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
		<div class="py-2">
			{item.children?.map((child) => (
				<a
					href={child.href}
					class:list={{
						'block px-4 py-2 text-.9rem transition-colors': true,
						'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800': currentPath !== child.href,
						'text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20': currentPath === child.href,
					}}
					target={child.external ? '_blank' : undefined}
					rel={child.external ? 'noopener noreferrer' : undefined}
				>
					{child.title}
				</a>
			))}
		</div>
	</div>
</div>
