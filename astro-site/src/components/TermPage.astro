---
import PageShell from './PageShell.astro';
import ArticleContent from './ArticleContent.astro';
import { getBreadcrumbs } from '../data/hierarchy';

interface Props {
	term: string;
	definition: string;
	path: string;
	prevTerm?: {
		href: string;
		label: string;
	};
	nextTerm?: {
		href: string;
		label: string;
	};
}

const { term, definition, path, prevTerm, nextTerm } = Astro.props;
const breadcrumbs = getBreadcrumbs(path);
---

<PageShell breadcrumbs={breadcrumbs}>
	<ArticleContent>
		<div class="term-card">
			<h1>{term}</h1>
			
			<p>{definition}</p>
			
			<hr />
			
			<div class="term-navigation">
				<div class="nav-item nav-item-left">
					<p class="nav-label">Previous Term</p>
					<p class="nav-link">
						{prevTerm ? (
							<a href={prevTerm.href}>{prevTerm.label}</a>
						) : (
							<span class="empty">—</span>
						)}
					</p>
				</div>
				<div class="nav-item nav-item-right">
					<p class="nav-label">Next Term</p>
					<p class="nav-link">
						{nextTerm ? (
							<a href={nextTerm.href}>{nextTerm.label}</a>
						) : (
							<span class="empty">—</span>
						)}
					</p>
				</div>
			</div>
			
			<div class="view-all">
				<a href="/oil-and-gas-terms" class="view-all-button">View all Oil &amp; Gas Terms</a>
			</div>
		</div>
	</ArticleContent>
</PageShell>

<style>
	.term-card {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}
	
	.term-card h1 {
		margin-top: 0;
		margin-bottom: 1rem;
	}
	
	.term-card > p {
		margin-bottom: 1.5rem;
		font-size: 1.125rem;
		line-height: 1.75rem;
	}
	
	.term-card hr {
		margin: 2rem 0;
		border: none;
		border-top: 1px solid #e5e7eb;
	}
	
	.term-navigation {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}
	
	.nav-item {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	
	.nav-item-left {
		align-items: flex-start;
		text-align: left;
	}
	
	.nav-item-right {
		align-items: flex-end;
		text-align: right;
	}
	
	.nav-label {
		font-weight: 600;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #6b7280;
		margin: 0;
	}
	
	.nav-link {
		margin: 0;
		font-size: 0.9375rem;
	}
	
	.nav-link a {
		color: #0ea5e9; /* sky-500 */
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}
	
	.nav-link a:hover {
		color: #0284c7; /* sky-600 */
		text-decoration: underline;
	}
	
	.nav-link .empty {
		color: #9ca3af;
		font-style: italic;
	}
	
	.view-all {
		text-align: center;
		padding-top: 1rem;
		border-top: 1px solid #e5e7eb;
	}
	
	.view-all-button {
		display: inline-block;
		padding: 0.625rem 1.5rem;
		background-color: #0ea5e9; /* sky-500 */
		color: white;
		text-decoration: none;
		font-weight: 500;
		border-radius: 0.5rem;
		transition: background-color 0.2s;
	}
	
	.view-all-button:hover {
		background-color: #0284c7; /* sky-600 */
		text-decoration: none;
	}
	
	@media (max-width: 640px) {
		.term-card {
			padding: 1.5rem;
		}
		
		.term-navigation {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		
		.nav-item {
			width: 100%;
		}
		
		.nav-item-left,
		.nav-item-right {
			align-items: center;
			text-align: center;
		}
		
		.nav-link {
			width: 100%;
		}
		
		.nav-link a {
			display: block;
			padding: 0.75rem 1rem;
			border-radius: 0.5rem;
			background-color: #f8fafc;
			border: 1px solid #e2e8f0;
			transition: all 0.2s;
		}
		
		.nav-link a:hover {
			background-color: #f1f5f9;
			border-color: #0ea5e9;
			text-decoration: none;
		}
		
		.nav-link .empty {
			display: block;
			padding: 0.75rem 1rem;
			text-align: center;
		}
	}
</style>
