---
interface Stat {
	label: string;
	value: string;
}

interface Link {
	text: string;
	href: string;
	external?: boolean;
}

interface Props {
	stateName: string;
	stateAbbr: string;
	description: string;
	history?: string;
	stats?: Stat[];
	majorFields?: string[];
	companies?: string[];
	regulatoryLink?: Link;
	additionalReading?: Link[];
}

const { 
	stateName, 
	stateAbbr, 
	description, 
	history,
	stats = [],
	majorFields = [],
	companies = [],
	regulatoryLink,
	additionalReading = []
} = Astro.props;
---

<div class="state-page">
	<!-- Hero Section -->
	<div class="state-hero">
		<div class="state-hero-content">
			<h1 class="state-title">{stateName} Mineral Rights</h1>
			<p class="state-description">{description}</p>
		</div>
	</div>

	<!-- History Section -->
	{history && (
		<section class="state-section">
			<h2 class="section-title">History & Overview</h2>
			<div class="section-content">
				<p>{history}</p>
			</div>
		</section>
	)}

	<!-- Stats Grid -->
	{stats.length > 0 && (
		<section class="state-section">
			<h2 class="section-title">Key Statistics</h2>
			<div class="stats-grid">
				{stats.map((stat) => (
					<div class="stat-card">
						<div class="stat-value">{stat.value}</div>
						<div class="stat-label">{stat.label}</div>
					</div>
				))}
			</div>
		</section>
	)}

	<!-- Two Column Layout for Fields and Companies -->
	{(majorFields.length > 0 || companies.length > 0) && (
		<section class="state-section">
			<div class="two-column-grid">
				{majorFields.length > 0 && (
					<div class="info-column">
						<h2 class="section-title">Major Oil and Gas Fields</h2>
						<ul class="info-list">
							{majorFields.map((field) => (
								<li>{field}</li>
							))}
						</ul>
					</div>
				)}
				{companies.length > 0 && (
					<div class="info-column">
						<h2 class="section-title">Oil and Gas Companies Active in {stateName}</h2>
						<ul class="info-list">
							{companies.map((company) => (
								<li>{company}</li>
							))}
						</ul>
					</div>
				)}
			</div>
		</section>
	)}

	<!-- Regulatory Link -->
	{regulatoryLink && (
		<section class="state-section">
			<h2 class="section-title">{stateName} Mineral Rights Links</h2>
			<div class="section-content">
				<p>
					{stateName} Oil and Gas Board: 
					<a 
						href={regulatoryLink.href} 
						target={regulatoryLink.external ? "_blank" : undefined}
						rel={regulatoryLink.external ? "noopener noreferrer" : undefined}
						class="external-link"
					>
						{regulatoryLink.text}
					</a>
				</p>
			</div>
		</section>
	)}

	<!-- Additional Reading -->
	{additionalReading.length > 0 && (
		<section class="state-section">
			<h2 class="section-title">Additional Reading</h2>
			<ul class="reading-list">
				{additionalReading.map((link) => (
					<li>
						<a 
							href={link.href}
							target={link.external ? "_blank" : undefined}
							rel={link.external ? "noopener noreferrer" : undefined}
							class="reading-link"
						>
							{link.text}
						</a>
					</li>
				))}
			</ul>
		</section>
	)}

	<!-- Return Link -->
	<div class="return-link-container">
		<a href="/mineral-rights-by-state" class="return-link">
			← Return to All States
		</a>
	</div>
</div>

<style>
	.state-page {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}

	.state-hero {
		margin-bottom: 3rem;
		padding-bottom: 2.5rem;
		border-bottom: 2px solid #e2e8f0;
	}

	.state-hero-content {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.state-title {
		margin: 0;
		font-size: 2.5rem;
		font-weight: 700;
		line-height: 1.2;
		color: rgb(var(--gray-dark));
	}

	.state-description {
		margin: 0;
		font-size: 1.125rem;
		line-height: 1.75rem;
		color: rgb(var(--gray-dark));
	}

	.state-section {
		margin-bottom: 2.5rem;
	}

	.state-section:last-of-type {
		margin-bottom: 0;
	}

	.section-title {
		margin-top: 0;
		margin-bottom: 1.5rem;
		font-size: 1.75rem;
		font-weight: 600;
		color: rgb(var(--gray-dark));
		border-bottom: 2px solid #0ea5e9;
		padding-bottom: 0.5rem;
	}

	.section-content {
		font-size: 1rem;
		line-height: 1.75rem;
		color: rgb(var(--gray-dark));
	}

	.section-content p {
		margin-bottom: 1.25rem;
	}

	.section-content p:last-child {
		margin-bottom: 0;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5rem;
		margin-top: 1.5rem;
	}

	.stat-card {
		background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
		border-radius: 0.75rem;
		padding: 1.5rem;
		text-align: center;
		border: 1px solid #bae6fd;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.stat-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
	}

	.stat-value {
		font-size: 2rem;
		font-weight: 700;
		color: #0ea5e9;
		margin-bottom: 0.5rem;
	}

	.stat-label {
		font-size: 0.9375rem;
		color: rgb(var(--gray-dark));
		font-weight: 500;
	}

	.two-column-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2.5rem;
		margin-top: 1.5rem;
	}

	.info-column {
		background: #f8fafc;
		border-radius: 0.75rem;
		padding: 1.5rem;
		border: 1px solid #e2e8f0;
	}

	.info-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.info-list li {
		padding: 0.75rem 0;
		border-bottom: 1px solid #e2e8f0;
		color: rgb(var(--gray-dark));
		font-size: 0.9375rem;
	}

	.info-list li:last-child {
		border-bottom: none;
	}

	.external-link {
		color: #0ea5e9;
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.external-link:hover {
		color: #0284c7;
		text-decoration: underline;
	}

	.reading-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.reading-list li {
		padding: 0.75rem 0;
		border-bottom: 1px solid #e2e8f0;
	}

	.reading-list li:last-child {
		border-bottom: none;
	}

	.reading-link {
		color: #0ea5e9;
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.reading-link:hover {
		color: #0284c7;
		text-decoration: underline;
	}

	.return-link-container {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 2px solid #e2e8f0;
		text-align: center;
	}

	.return-link {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background-color: #0ea5e9;
		color: white;
		text-decoration: none;
		font-weight: 500;
		border-radius: 0.5rem;
		transition: background-color 0.2s;
	}

	.return-link:hover {
		background-color: #0284c7;
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.state-page {
			padding: 1.5rem;
		}

		.state-title {
			font-size: 2rem;
		}

		.two-column-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.stats-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
