---
interface Article {
	title: string;
	href: string;
	description: string;
}

interface Tab {
	label: string;
	id: string;
	articles: Article[];
}

interface Props {
	heading: string;
	intro: string;
	tabs: Tab[];
}

const { heading, intro, tabs } = Astro.props;
---

<div class="owner-guide-card">
	<h1 class="owner-guide-heading">{heading}</h1>
	<p class="owner-guide-intro">{intro}</p>
	
	<div class="tabs-container">
		<div class="tabs-header" role="tablist">
			{tabs.map((tab, index) => (
				<button
					class:list={['tab-button', { 'tab-button-active': index === 0 }]}
					data-tab={tab.id}
					role="tab"
					aria-selected={index === 0 ? 'true' : 'false'}
					aria-controls={`panel-${tab.id}`}
					id={`tab-${tab.id}`}
				>
					{tab.label}
				</button>
			))}
		</div>
		
		<div class="tabs-content">
			{tabs.map((tab, index) => (
				<div
					class:list={['tab-panel', { 'tab-panel-active': index === 0 }]}
					id={`panel-${tab.id}`}
					role="tabpanel"
					aria-labelledby={`tab-${tab.id}`}
					hidden={index !== 0}
				>
					<div class="articles-list">
						{tab.articles.map((article) => (
							<article class="article-item">
								<h3 class="article-title">
									<a href={article.href} class="article-link">{article.title}</a>
								</h3>
								<p class="article-description">{article.description}</p>
							</article>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</div>

<script is:inline>
	// Tab switching functionality
	(function() {
		function initTabs() {
			const tabButtons = document.querySelectorAll('.tab-button');
			const tabPanels = document.querySelectorAll('.tab-panel');
			
			if (tabButtons.length === 0) return;
			
			tabButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const targetTab = button.getAttribute('data-tab');
					
					// Remove active state from all buttons and panels
					tabButtons.forEach((btn) => {
						btn.classList.remove('tab-button-active');
						btn.setAttribute('aria-selected', 'false');
					});
					tabPanels.forEach((panel) => {
						panel.classList.remove('tab-panel-active');
						panel.setAttribute('hidden', 'true');
					});
					
					// Add active state to clicked button and corresponding panel
					button.classList.add('tab-button-active');
					button.setAttribute('aria-selected', 'true');
					const targetPanel = document.getElementById('panel-' + targetTab);
					if (targetPanel) {
						targetPanel.classList.add('tab-panel-active');
						targetPanel.removeAttribute('hidden');
					}
				});
			});
		}
		
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initTabs);
		} else {
			initTabs();
		}
	})();
</script>

<style>
	.owner-guide-card {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}

	.owner-guide-heading {
		margin-top: 0;
		margin-bottom: 1.5rem;
		font-size: 2rem;
		font-weight: 700;
		line-height: 1.2;
		color: rgb(var(--gray-dark));
	}

	.owner-guide-intro {
		margin-bottom: 2.5rem;
		font-size: 1.125rem;
		line-height: 1.75rem;
		color: rgb(var(--gray-dark));
	}

	.tabs-container {
		border: 1px solid #e2e8f0;
		border-radius: 0.75rem;
		overflow: hidden;
		background: white;
	}

	.tabs-header {
		display: flex;
		background: #f8fafc;
		border-bottom: 2px solid #e2e8f0;
		overflow-x: auto;
		scrollbar-width: none;
		-ms-overflow-style: none;
	}

	.tabs-header::-webkit-scrollbar {
		display: none;
	}

	.tab-button {
		flex: 1;
		min-width: 150px;
		padding: 1rem 1.5rem;
		background: transparent;
		border: none;
		border-bottom: 3px solid transparent;
		font-size: 1rem;
		font-weight: 600;
		color: #64748b;
		cursor: pointer;
		transition: all 0.2s;
		white-space: nowrap;
		position: relative;
	}

	.tab-button:hover {
		background: #f1f5f9;
		color: #0ea5e9;
	}

	.tab-button-active {
		color: #0ea5e9;
		background: white;
		border-bottom-color: #0ea5e9;
	}

	.tab-button-active:hover {
		background: white;
	}

	.tabs-content {
		background: white;
	}

	.tab-panel {
		display: none;
		padding: 2rem;
		animation: fadeIn 0.3s ease-in;
	}

	.tab-panel-active {
		display: block;
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.articles-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.article-item {
		padding: 1.25rem;
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 0.5rem;
		transition: all 0.2s;
	}

	.article-item:hover {
		border-color: #0ea5e9;
		box-shadow: 0 2px 4px rgba(14, 165, 233, 0.1);
		transform: translateX(4px);
	}

	.article-title {
		margin-top: 0;
		margin-bottom: 0.5rem;
		font-size: 1.125rem;
		font-weight: 600;
		line-height: 1.3;
	}

	.article-link {
		color: #0ea5e9; /* sky-500 */
		text-decoration: none;
		transition: color 0.2s;
	}

	.article-link:hover {
		color: #0284c7; /* sky-600 */
		text-decoration: underline;
	}

	.article-description {
		margin-bottom: 0;
		font-size: 0.9375rem;
		line-height: 1.6;
		color: rgb(var(--gray-dark));
	}

	@media (max-width: 768px) {
		.owner-guide-card {
			padding: 1.5rem;
		}

		.owner-guide-heading {
			font-size: 1.75rem;
		}

		.tabs-header {
			flex-wrap: nowrap;
		}

		.tab-button {
			min-width: 120px;
			padding: 0.875rem 1rem;
			font-size: 0.9375rem;
		}

		.tab-panel {
			padding: 1.5rem;
		}

		.article-item {
			padding: 1rem;
		}
	}

	@media (max-width: 640px) {
		.tab-button {
			min-width: 100px;
			padding: 0.75rem 0.875rem;
			font-size: 0.875rem;
		}

		.tab-panel {
			padding: 1.25rem;
		}
	}
</style>
