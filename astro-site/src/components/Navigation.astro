---
import { navigation } from '../data/navigation';
import NavDropdown from './NavDropdown.astro';

const currentPath = Astro.url.pathname;
---

<nav class="hidden md:flex items-center space-x-8">
	{navigation.map((item) => (
		<div class="relative flex items-center">
			{item.children ? (
				<NavDropdown item={item} currentPath={currentPath} />
			) : (
				<a
					href={item.href}
					class:list={{
						'text-1.2rem font-semibold transition-colors flex items-center': true,
						'text-gray-900 dark:text-white': true,
						'hover:text-[#0284c7] dark:hover:text-sky-400': true,
					}}
					target={item.external ? '_blank' : undefined}
					rel={item.external ? 'noopener noreferrer' : undefined}
				>
					{item.title}
				</a>
			)}
		</div>
	))}
	<!-- SearchIQ search icon -->
	<div class="siq-icon-item-siq-selectbox moveToExtremeRight">
		<div class="siq-icon-searchbox-wrap">
			<div class="siq-expsearch-cont">
				<form class="siq-expsearch" action="/search" method="get">
					<input type="search" placeholder="Search" name="s" class="siq-expsearch-input" aria-label="Search" autocomplete="off" />
					<span class="siq-expsearch-icon" aria-label="Open search">
						<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
						</svg>
					</span>
				</form>
			</div>
		</div>
	</div>
</nav>

<!-- Mobile Menu Button -->
<button 
	type="button" 
	class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-500"
	aria-label="Toggle menu"
	id="mobile-menu-button"
>
	<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
	</svg>
</button>

<!-- Mobile Menu -->
<div id="mobile-menu" class="hidden md:hidden absolute top-16 left-0 right-0 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 shadow-lg">
	<div class="px-4 py-4 space-y-4">
		{navigation.map((item) => (
			<div>
				{item.children ? (
					<div>
						<button 
							class="w-full text-left text-sm font-semibold text-gray-900 dark:text-white hover:text-[#0284c7] dark:hover:text-sky-400 flex items-center justify-between"
							data-mobile-dropdown={item.title}
						>
							{item.title}
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
							</svg>
						</button>
						<div class="hidden mt-2 pl-4 space-y-2" data-mobile-dropdown-menu={item.title}>
							{item.href && item.href !== '#' && (
								<a
									href={item.href}
									class="block text-sm font-semibold text-gray-900 dark:text-white hover:text-[#0284c7] dark:hover:text-sky-400 mb-1"
								>
									{item.title}
								</a>
							)}
							{item.children.map((child) => (
								<a
									href={child.href}
									class="block text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-[#0284c7] dark:hover:text-sky-400"
									target={child.external ? '_blank' : undefined}
									rel={child.external ? 'noopener noreferrer' : undefined}
								>
									{child.title}
								</a>
							))}
						</div>
					</div>
				) : (
					<a
						href={item.href}
						class:list={{
							'block text-sm font-semibold transition-colors': true,
							'text-gray-900 dark:text-white': true,
							'hover:text-[#0284c7] dark:hover:text-sky-400': true,
						}}
						target={item.external ? '_blank' : undefined}
						rel={item.external ? 'noopener noreferrer' : undefined}
					>
						{item.title}
					</a>
				)}
			</div>
		))}
		<!-- SearchIQ search icon (mobile) -->
		<div class="siq-icon-item-siq-selectbox mt-4">
			<div class="siq-icon-searchbox-wrap openFromLeft">
				<div class="siq-expsearch-cont">
					<form class="siq-expsearch" action="/search" method="get">
						<input type="search" placeholder="Search" name="s" class="siq-expsearch-input" aria-label="Search" autocomplete="off" />
						<span class="siq-expsearch-icon" aria-label="Open search">
							<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
							</svg>
						</span>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

<script is:inline>
	document.addEventListener('DOMContentLoaded', function() {
		var menuButton = document.getElementById('mobile-menu-button');
		var mobileMenu = document.getElementById('mobile-menu');
		
		if (menuButton && mobileMenu) {
			menuButton.addEventListener('click', function() {
				mobileMenu.classList.toggle('hidden');
			});
		}
		
		// Mobile dropdowns
		document.querySelectorAll('[data-mobile-dropdown]').forEach(function(button) {
			button.addEventListener('click', function() {
				var menuId = button.getAttribute('data-mobile-dropdown');
				var menu = document.querySelector('[data-mobile-dropdown-menu="' + menuId + '"]');
				if (menu) {
					menu.classList.toggle('hidden');
				}
			});
		});

		// SearchIQ icon-only: expand/collapse on icon click, close on outside click
		// Use event delegation so it works even if SearchIQ or other scripts modify the DOM
		document.addEventListener('click', function(evt) {
			var target = evt.target;
			var icon = target && typeof target.closest === 'function' && target.closest('.siq-expsearch-icon');
			if (icon) {
				evt.preventDefault();
				evt.stopPropagation();
				var searchBox = icon.closest('.siq-icon-searchbox-wrap');
				var inputBox = searchBox && searchBox.querySelector('.siq-expsearch-input');
				if (searchBox && inputBox) {
					if (!searchBox.classList.contains('siq-search-open')) {
						searchBox.classList.add('siq-search-open');
						inputBox.focus();
					} else {
						searchBox.classList.remove('siq-search-open');
						inputBox.blur();
					}
				}
				return;
			}
			// Close when clicking outside
			if (target && typeof target.closest === 'function' && !target.closest('.siq-icon-searchbox-wrap')) {
				document.querySelectorAll('.siq-icon-searchbox-wrap.siq-search-open').forEach(function(box) {
					box.classList.remove('siq-search-open');
				});
			}
		});
	});
</script>
