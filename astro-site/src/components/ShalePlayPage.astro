---
interface Props {
	shaleName: string;
	state?: string;
	description: string;
	companies: string[];
	geology: string;
	counties: string[];
	stats?: Array<{
		label: string;
		value: string;
	}>;
	additionalReading?: Array<{
		text: string;
		href: string;
		external?: boolean;
	}>;
}

const {
	shaleName,
	state,
	description,
	companies,
	geology,
	counties,
	stats = [],
	additionalReading = []
} = Astro.props;

const fullTitle = shaleName;
---

<div class="shale-play-page">
	<!-- Hero Section -->
	<div class="shale-hero">
		<h1 class="shale-title">{fullTitle}</h1>
		{description && (
			<p class="shale-intro">{description}</p>
		)}
	</div>

	<!-- Companies Section -->
	{companies.length > 0 && (
		<div class="shale-section">
			<h2 class="section-title">
				{shaleName} Companies
			</h2>
			<p class="section-intro">Significant producers within the {shaleName} are:</p>
			<ul class="companies-list">
				{companies.map((company) => (
					<li>{company}</li>
				))}
			</ul>
		</div>
	)}

	<!-- Geology Section -->
	{geology && (
		<div class="shale-section">
			<h2 class="section-title">
				{shaleName} Geology
			</h2>
			<div class="geology-content">
				{geology.split('\n\n').filter(p => p.trim()).map((paragraph) => (
					<p>{paragraph.trim()}</p>
				))}
			</div>
		</div>
	)}

	<!-- Location Section -->
	{counties.length > 0 && (
		<div class="shale-section">
			<h2 class="section-title">
				{shaleName} Location
			</h2>
			<p class="section-intro">The {shaleName} is located in the following {state ? `${state} ` : ''}counties:</p>
			<ul class="counties-list">
				{counties.map((county) => (
					<li>{county}</li>
				))}
			</ul>
		</div>
	)}

	<!-- Additional Reading -->
	{additionalReading.length > 0 && (
		<div class="shale-section">
			<h2 class="section-title">
				Additional Reading
			</h2>
			<ul class="reading-list">
				{additionalReading.map((item) => (
					<li>
						<a 
							href={item.href} 
							target={item.external ? "_blank" : undefined}
							rel={item.external ? "noopener noreferrer" : undefined}
							class="reading-link"
						>
							{item.text}
						</a>
					</li>
				))}
			</ul>
		</div>
	)}
</div>

<style>
	.shale-play-page {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}

	.shale-hero {
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 2px solid #e5e7eb;
	}

	.shale-title {
		font-size: 2.75rem;
		font-weight: 800;
		margin-bottom: 1rem;
		color: #1a1a1a;
		line-height: 1.2;
	}

	.shale-intro {
		font-size: 1.25rem;
		color: #4b5563;
		line-height: 1.7;
		margin: 0;
	}

	.shale-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5rem;
		margin-bottom: 3rem;
	}

	.stat-card {
		background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
		border-radius: 12px;
		padding: 1.5rem;
		text-align: center;
		color: white;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.stat-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
	}

	.stat-value {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.stat-label {
		font-size: 0.875rem;
		opacity: 0.9;
		line-height: 1.4;
	}

	.shale-section {
		margin-bottom: 3rem;
	}

	.shale-section:last-child {
		margin-bottom: 0;
	}

	.section-title {
		font-size: 1.75rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}

	.section-intro {
		font-size: 1.125rem;
		color: #6b7280;
		margin-bottom: 1.5rem;
		line-height: 1.6;
	}

	.companies-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 0.125rem 1.5rem;
	}

	.companies-list li {
		font-size: 1rem;
		color: #374151;
		padding: 0.25rem 0;
	}

	.geology-content {
		font-size: 1.0625rem;
		line-height: 1.8;
		color: #374151;
	}

	.geology-content p {
		margin-bottom: 1.25rem;
	}

	.geology-content p:last-child {
		margin-bottom: 0;
	}

	.counties-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 0.125rem 1.5rem;
	}

	.counties-list li {
		font-size: 0.9375rem;
		color: #4b5563;
		padding: 0.25rem 0;
	}

	.reading-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.reading-list li {
		padding-left: 1.5rem;
		position: relative;
	}

	.reading-list li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: #3b82f6;
		font-weight: bold;
	}

	.reading-link {
		font-size: 1.0625rem;
		color: #2563eb;
		text-decoration: none;
		transition: color 0.2s ease;
		font-weight: 500;
	}

	.reading-link:hover {
		color: #1d4ed8;
		text-decoration: underline;
	}

	@media (max-width: 768px) {
		.shale-play-page {
			padding: 1.5rem;
		}

		.shale-title {
			font-size: 2.25rem;
		}

		.shale-intro {
			font-size: 1.125rem;
		}

		.shale-stats {
			grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
			gap: 1rem;
		}

		.stat-value {
			font-size: 1.5rem;
		}

		.section-title {
			font-size: 1.5rem;
		}

		.companies-list {
			grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
		}

		.counties-list {
			grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
		}
	}

	@media (max-width: 640px) {
		.shale-title {
			font-size: 2rem;
		}

		.shale-stats {
			grid-template-columns: 1fr;
		}
	}
</style>
