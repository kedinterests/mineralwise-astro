---
const today = new Date();

const ownerGuideLinks = [
	{ title: 'Oil & Gas 101', href: '/owners-guide/oil-and-gas-basics-for-mineral-owners' },
	{ title: 'Leased & Producing', href: '/owners-guide/leased-and-producing' },
	{ title: 'Unleased Mineral Owner', href: '/owners-guide/unleased-mineral-owner' },
	{ title: 'Leased But Not Producing', href: '/owners-guide/leased-but-not-producing' },
	{ title: 'Lease Proposals', href: '/owners-guide/lease-proposals' },
	{ title: 'Opportunities', href: '/owners-guide/opportunities-for-all' },
	{ title: 'Prefer Cash Payment', href: '/owners-guide/cash-payment-for-oil-and-gas-royalty' },
];

const resourcesLinks = [
	{ title: 'Mineral Rights by State', href: '/resources/mineral-rights-by-state' },
	{ title: 'Shale Plays', href: '/resources/shale-plays' },
	{ title: 'Oil & Gas Operators', href: '/resources/oil-and-gas-operators' },
	{ title: 'Oil & Gas Terms', href: '/resources/oil-and-gas-terms' },
	{ title: 'Oil & Gas Abbreviations', href: '/resources/oil-and-gas-abbreviations' },
];

const companyLinks = [
	{ title: 'About', href: '/about' },
	{ title: 'Contact', href: '/contact-us' },
	{ title: 'Advertising', href: '/advertising' },
	{ title: 'Privacy Policy', href: '/privacy-policy' },
	{ title: 'Terms & Conditions', href: '/terms-and-conditions' },
];

const socialLinks = [
	{ name: 'Facebook', href: 'https://www.facebook.com/100065558110317', icon: 'facebook' },
	{ name: 'X', href: 'https://x.com/mineralwise', icon: 'x' },
	{ name: 'LinkedIn', href: 'https://linkedin.com/company/mineralwise', icon: 'linkedin' },
];
---

<footer class="footer">
	<div class="footer-inner">
		<!-- Logo + Social + Newsletter row -->
		<div class="footer-top">
			<div class="footer-top-left">
				<a href="/" aria-label="MineralWise Home" class="footer-logo">
					<img
						src="/images/mineralWise-logo.webp"
						alt="MineralWise"
						class="footer-logo-img"
					/>
				</a>
			</div>
			<div class="footer-newsletter">
				<p class="footer-newsletter-label">Subscribe to our newsletter</p>
				<form class="footer-newsletter-form" action="#" method="post" aria-label="Newsletter signup">
					<input
						type="email"
						name="email"
						placeholder="Enter your email"
						class="footer-newsletter-input"
						required
					/>
					<button type="submit" class="footer-newsletter-btn">Subscribe</button>
				</form>
			</div>
		</div>

		<!-- Menu columns -->
		<div class="footer-nav">
			<div class="footer-col">
				<h3 class="footer-col-title">Owner's Guide</h3>
				<ul>
					{ownerGuideLinks.map((link) => (
						<li>
							<a href={link.href}>{link.title}</a>
						</li>
					))}
				</ul>
			</div>
			<div class="footer-col">
				<h3 class="footer-col-title">Resources</h3>
				<ul>
					{resourcesLinks.map((link) => (
						<li>
							<a href={link.href}>{link.title}</a>
						</li>
					))}
				</ul>
			</div>
			<div class="footer-col footer-col-social">
				<h3 class="footer-col-title">Company</h3>
				<ul>
					{companyLinks.map((link) => (
						<li>
							<a href={link.href}>{link.title}</a>
						</li>
					))}
				</ul>
				<nav class="footer-social" aria-label="Social media">
					{socialLinks.map((social) => (
						<a
							href={social.href}
							target="_blank"
							rel="noopener noreferrer"
							aria-label={social.name}
							class="footer-social-link"
						>
							{social.icon === 'facebook' && (
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
								</svg>
							)}
							{social.icon === 'x' && (
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
								</svg>
							)}
							{social.icon === 'linkedin' && (
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
								</svg>
							)}
						</a>
					))}
				</nav>
			</div>
		</div>

		<!-- Forum CTA -->
		<div class="footer-forum">
			<p>
				Discuss oil & gas mineral issues with other landowners at the{' '}
				<a href="https://mineralrightsforum.com" target="_blank" rel="noopener noreferrer">Mineral Rights Forum</a>.
			</p>
		</div>

		<!-- Copyright -->
		<div class="footer-bottom">
			<p>&copy; {today.getFullYear()} MineralWise. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: #0a0a0a;
		color: #e5e5e5;
		margin-top: 4rem;
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1.5rem 1.5rem 1.25rem;
	}

	.footer-top {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
	}

	.footer-top-left {
		display: flex;
		flex-direction: column;
	}

	.footer-logo {
		display: block;
	}

	.footer-social {
		display: flex;
		gap: 0.75rem;
	}

	.footer-social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		color: rgba(255, 255, 255, 0.7);
		transition: color 0.2s;
	}

	.footer-social-link:hover {
		color: #fff;
	}

	.footer-logo-img {
		height: 48px;
		width: auto;
		filter: brightness(0) invert(1);
		opacity: 0.95;
	}

	.footer-newsletter {
		flex: 1;
		min-width: 260px;
		max-width: 360px;
	}

	.footer-newsletter-label {
		font-size: 0.875rem;
		font-weight: 600;
		margin-bottom: 0.25rem;
		color: #fff;
	}

	.footer-newsletter-form {
		display: flex;
		gap: 0.5rem;
	}

	.footer-newsletter-input {
		flex: 1;
		padding: 0.5rem 0.75rem;
		font-size: 0.875rem;
		border: 1px solid rgba(255, 255, 255, 0.25);
		background: rgba(255, 255, 255, 0.08);
		color: #fff;
		border-radius: 0.25rem;
	}

	.footer-newsletter-input::placeholder {
		color: rgba(255, 255, 255, 0.5);
	}

	.footer-newsletter-input:focus {
		outline: none;
		border-color: rgba(255, 255, 255, 0.5);
	}

	.footer-newsletter-btn {
		padding: 0.5rem 1rem;
		font-size: 0.875rem;
		font-weight: 600;
		background: #fff;
		color: #0a0a0a;
		border: none;
		border-radius: 0.25rem;
		cursor: pointer;
		white-space: nowrap;
	}

	.footer-newsletter-btn:hover {
		background: rgba(255, 255, 255, 0.9);
	}

	.footer-nav {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		padding: 1rem 0;
	}

	.footer-col-title {
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #fff;
		margin-bottom: 0.5rem;
	}

	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-col li {
		margin-bottom: 0.125rem;
		line-height: 1.4;
	}

	.footer-col a {
		color: #e5e5e5;
		text-decoration: none;
		font-size: 0.9rem;
		transition: color 0.2s;
	}

	.footer-col a:hover {
		color: #fff;
	}

	.footer-col-social {
		display: flex;
		flex-direction: column;
	}

	.footer-col-social .footer-social {
		margin-top: auto;
		padding-top: 1rem;
	}

	.footer-forum {
		padding: 0.75rem 0;
		border-top: 1px solid rgba(255, 255, 255, 0.12);
		text-align: center;
	}

	.footer-forum p {
		font-size: 0.9rem;
		opacity: 0.9;
		margin: 0;
	}

	.footer-forum a {
		color: #fff;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.footer-forum a:hover {
		opacity: 0.9;
	}

	.footer-bottom {
		padding-top: 0.75rem;
		border-top: 1px solid rgba(255, 255, 255, 0.12);
		text-align: center;
	}

	.footer-bottom p {
		font-size: 0.8rem;
		opacity: 0.7;
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer-top {
			flex-direction: column;
			align-items: stretch;
		}

		.footer-newsletter {
			max-width: none;
		}

		.footer-nav {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
	}
</style>
