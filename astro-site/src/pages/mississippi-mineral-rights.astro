---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Mississippi Mineral Rights | MineralWise";
const metaDescription = "Mississippi Mineral Rights pertaining to oil and gas have been productive since October of 1926 with the drilling of the Amory Petroleum Company #1 Carter. Miss";

const stateName = "Mississippi";
const stateAbbr = "MS";
const description = "Mississippi Mineral Rights pertaining to oil and gas have been productive since October of 1926 with the drilling of the Amory Petroleum Company #1 Carter. Miss";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/mississippi-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
