const description = "Learn why you might not be receiving royalties on your leased mineral rights. Explore the oil and gas production process, top leasing, and division orders, and understand what happens after signing a lease.";

const content = "<div id=\"mm-0\">\n    <section id=\"h4Ea_rIJnjVX_h4Ea_rIJnjVX\"><div><div><div id=\"\"><div><div data-brz-translate-text=\"1\"><h1 data-uniq-id=\"mKkdK\" data-generated-css=\"brz-css-mxI8h\"><span style=\"color: rgba(var(--brz-global-color4),1);\">“I am a currently leased Mineral Owner, yet not currently receiving monthly revenue.”</span></h1><p data-uniq-id=\"gg0sK\" data-generated-css=\"brz-css-kBCBx\"><br></p><p data-uniq-id=\"fuZsI\" data-generated-css=\"brz-css-neYvH\">Signing an oil and gas lease is the first step in the process of receiving royalty from your mineral interests. The articles below will show you what to expect once the production process starts and how to understand the different documents you will receive relating to your oil or gas lease.</p><p data-uniq-id=\"iV4X3\" data-generated-css=\"brz-css-f6mrH\"><br></p><ul><li data-uniq-id=\"wPTPr\" data-generated-css=\"brz-css-mipdx\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"/oil-and-gas-production-nontechnical-language\" data-brz-link-type=\"page\">Production 101</a> – Free article explaining the drilling, completing, and testing of oil and gas wells in nontechnical language. Valuable insight for mineral rights owners.</li></ul><p data-uniq-id=\"aoiCb\" data-generated-css=\"brz-css-d4OMw\"><br></p><ul><li data-uniq-id=\"lNm02\" data-generated-css=\"brz-css-iIw2D\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"/top-leasing\" data-brz-link-type=\"page\">Top Leasing</a> – Top leases cover land upon which a current lease already exists. Provisions in top leases include “first right of refusal”.</li></ul><p data-uniq-id=\"w_eTO\" data-generated-css=\"brz-css-p5Rs8\"><br></p><ul><li data-uniq-id=\"pYPN3\" data-generated-css=\"brz-css-qKQgE\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"/division-order-2\" data-brz-link-type=\"page\">Division Order</a> – Explanation of oil and gas Division Orders for mineral, royalty, and overriding royalty owners. Answers to questions, definitions, and sources for help.</li></ul><p data-uniq-id=\"mpOse\" data-generated-css=\"brz-css-uybqD\"><br></p></div></div></div><div id=\"\"><div><div><div>\n\n<center>\n<div class=\"breadcrumb\">\n    <a href=\"https://mineralwise.com\">Home</a> <span>›</span> \n    <a href=\"/owners-guide\">Owner's Guide</a> <span>›</span> \n    <span>Leased But Not Producing</span>\n</div>\n</center></div></div></div></div></div></div></section>\n    <section id=\"5476867bb5c0d4e2e43a4df2533e422b_5476867bb5c0d4e2e43a4df2533e422b\"><div><div></div><div><div><div><div><div><div id=\"\"><div><picture><source srcset=\"/images/MineralWise-Logo-Transparent.png, /images/MineralWise-Logo-Transparent.png\" media=\"(min-width: 992px)\"><source srcset=\"/images/MineralWise-Logo-Transparent.png, /images/MineralWise-Logo-Transparent.png\" media=\"(min-width: 768px)\"><img srcset=\"/images/MineralWise-Logo-Transparent.png, /images/MineralWise-Logo-Transparent.png\" src=\"/images/MineralWise-Logo-Transparent.png\" loading=\"lazy\" alt=\"\" title=\"MineralWise-Logo-Transparent.png\" draggable=\"false\"></picture></div></div></div></div><div><div><div id=\"\"><div><div data-brz-translate-text=\"1\"><p data-uniq-id=\"j0TjM\" data-generated-css=\"brz-css-pjVpW\"><span style=\"color: rgba(var(--brz-global-color8),1);\">Use of this site constitutes acceptance of our </span><a style=\"color: rgba(var(--brz-global-color8),1);\" href=\"/terms-and-conditions\" data-brz-link-type=\"external\">Terms &amp; Conditions</a><span style=\"color: rgba(var(--brz-global-color8),1);\"> and </span><a style=\"color: rgba(var(--brz-global-color8),1);\" href=\"/privacy-policy\" data-brz-link-type=\"external\">Privacy Policy</a><span style=\"color: rgba(var(--brz-global-color8),1);\">.</span></p><p data-uniq-id=\"n27Va\" data-generated-css=\"brz-css-sHEHX\"><em style=\"color: rgba(var(--brz-global-color8),1);\">© COPYRIGHT 2009-2025 KED INTERESTS, LLC - ALL RIGHTS RESERVED</em></p></