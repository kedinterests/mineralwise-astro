---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Transporter";
const description = "Common carrier by pipeline, railway, truck, motor vehicle, boat, or barge.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Transporter"
		definition="Common carrier by pipeline, railway, truck, motor vehicle, boat, or barge."
		path="/transporter"
		prevTerm={{ href: "/top-lease", label: "Top Lease" }}
		nextTerm={{ href: "/tubing", label: "Tubing" }}
	/>
</BaseLayout>
