import TermPage from '../components/TermPage.astro';

const title = "W-9";
const description = "The IRS (Internal Revenue Service) form used to request someone’s TIN (taxpayer identification number).";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="W-9"
		definition="The IRS (Internal Revenue Service) form used to request someone’s TIN (taxpayer identification number)."
		path="/w-9"
		prevTerm={{ href: "/viscosity", label: "Viscosity" }}
		nextTerm={{ href: "/waterflood-waterflooding", label: "Waterflood Waterflooding" }}
	/>
</BaseLayout>
