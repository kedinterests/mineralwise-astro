---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "First Purchaser";
const description = "The party who first purchases and takes title to the production from an oil or gas well.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="First Purchaser"
		definition="The party who first purchases and takes title to the production from an oil or gas well."
		path="/first-purchaser"
		prevTerm={{ href: "/field-wide-unit", label: "Field-Wide Unit" }}
		nextTerm={{ href: "/first-right-of-refusal", label: "First Right of Refusal" }}
	/>
</BaseLayout>
