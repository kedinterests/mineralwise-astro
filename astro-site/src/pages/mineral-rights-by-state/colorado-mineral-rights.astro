---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import StatePage from '../../components/StatePage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Colorado Mineral Rights | MineralWise";
const metaDescription = "Colorado Mineral Rights have wide ranging values. Colorado's mineral rights cover a wide range of hydrocarbon products including crude oil, natural gas, gold, silver, and coal.";

const stateName = "Colorado";
const stateAbbr = "CO";
const description = "Colorado Mineral Rights have wide ranging values. Colorado's mineral rights cover a wide range of hydrocarbon products including crude oil, natural gas, gold, silver, and coal. The first oil field in Colorado was the Florence oil field discovered in the late 1800's.";

const stats = [];
const majorFields = [
	"Grand Valley Field",
	"Mamm Creek Field",
	"Parachute Field",
	"Piceance Creek Field",
	"Raton Basin Gas Area",
	"Rulison Field",
	"San Juan Basin Gas Area",
	"Wattenberg Field"
];
const companies = [
	"Chevron",
	"HS Resources",
	"Mull Drilling",
	"North American Resources",
	"Patina Oil and Gas",
	"Prima Oil and Gas",
	"Southwestern Production",
	"Texaco",
	"Union Pacific Resources",
	"Walsh Production"
];
const additionalReading = [
	{
		text: "Oil & Gas 101",
		href: "/owners-guide/oil-and-gas-basics-for-mineral-owners",
		external: false
	}
];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/mineral-rights-by-state/colorado-mineral-rights')}>
		<ArticleContent>
			<StatePage
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
				majorFields={majorFields}
				companies={companies}
				additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
