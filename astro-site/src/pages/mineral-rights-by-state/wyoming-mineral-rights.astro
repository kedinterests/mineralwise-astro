---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import StatePage from '../../components/StatePage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Wyoming Mineral Rights | MineralWise";
const metaDescription = "Wyoming mineral rights contribute more than $2.2 billion dollars in the form of taxes to the state and local economies of Wyoming. Wyoming is seventh in oil production, second in gas production, and first in helium production in the United States.";

const stateName = "Wyoming";
const stateAbbr = "WY";
const description = "Wyoming mineral rights contribute more than $2.2 billion dollars in the form of taxes to the state and local economies of Wyoming. Wyoming is seventh in oil production, second in gas production, and first in helium production in the United States.";

const stats = [];
const majorFields = [
	"Bruff Field",
	"Elk Basin",
	"Fogary Creek Field",
	"Garland Field",
	"Hamilton Dome",
	"House Creek Field",
	"Jonah Field",
	"Lake Ridge Field",
	"Lost Soldier Field",
	"Madden Field",
	"Oregon Basin",
	"Painter Reservoir East",
	"Pinedale Field",
	"PRB Coal Bed",
	"Salt Creek Field",
	"Sandard Draw Field",
	"Spring Creek South Field",
	"Wamsutter Field"
];
const companies = [
	"Devon Energy Production",
	"Encana Oil and Gas",
	"Lance Oil & Gas Company",
	"Merit Energy Company",
	"Questar Exploration and Production",
	"Shell Rocky Mountain Production",
	"Ultra Resources",
	"Wexpro Company",
	"Williams Production RMT",
	"Yates Petroleum Corporation"
];
const regulatoryLink = {
	text: "http://wogcc.state.wy.us/",
	href: "http://wogcc.state.wy.us/",
	external: true
};
const additionalReading = [
	{
		text: "Oil & Gas 101",
		href: "/owners-guide/oil-and-gas-basics-for-mineral-owners",
		external: false
	}
];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/mineral-rights-by-state/wyoming-mineral-rights')}>
		<ArticleContent>
			<StatePage
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
				majorFields={majorFields}
				companies={companies}
				regulatoryLink={regulatoryLink}
				additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
