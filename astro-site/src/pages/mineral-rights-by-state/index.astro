---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Comprehensive Guide to Mineral Rights by State | Explore Resources & Information";
const metaDescription = "Learn about mineral rights across all U.S. states, including history, oil & gas production, operators, and major fields. Find insights and discuss related issues with fellow landowners at MineralRightsForum.com.";

const states = [
	{ name: 'Alabama', href: '/mineral-rights-by-state/alabama-mineral-rights' },
	{ name: 'Arkansas', href: '/mineral-rights-by-state/arkansas-mineral-rights' },
	{ name: 'California', href: '/mineral-rights-by-state/california-mineral-rights' },
	{ name: 'Colorado', href: '/mineral-rights-by-state/colorado-mineral-rights' },
	{ name: 'Florida', href: '/mineral-rights-by-state/florida-mineral-rights' },
	{ name: 'Indiana', href: '/mineral-rights-by-state/indiana-mineral-rights' },
	{ name: 'Iowa', href: '/mineral-rights-by-state/iowa-mineral-rights' },
	{ name: 'Kansas', href: '/mineral-rights-by-state/kansas-mineral-rights' },
	{ name: 'Kentucky', href: '/mineral-rights-by-state/kentucky-mineral-rights' },
	{ name: 'Louisiana', href: '/mineral-rights-by-state/louisiana-mineral-rights' },
	{ name: 'Michigan', href: '/mineral-rights-by-state/michigan-mineral-rights' },
	{ name: 'Mississippi', href: '/mineral-rights-by-state/mississippi-mineral-rights' },
	{ name: 'Montana', href: '/mineral-rights-by-state/montana-mineral-rights' },
	{ name: 'Nebraska', href: '/mineral-rights-by-state/nebraska-mineral-rights' },
	{ name: 'New Mexico', href: '/mineral-rights-by-state/new-mexico-mineral-rights' },
	{ name: 'New York', href: '/mineral-rights-by-state/new-york-mineral-rights' },
	{ name: 'North Dakota', href: '/mineral-rights-by-state/north-dakota-mineral-rights' },
	{ name: 'Ohio', href: '/mineral-rights-by-state/ohio-mineral-rights' },
	{ name: 'Oklahoma', href: '/mineral-rights-by-state/oklahoma-mineral-rights' },
	{ name: 'Pennsylvania', href: '/mineral-rights-by-state/pennsylvania-mineral-rights' },
	{ name: 'South Dakota', href: '/mineral-rights-by-state/south-dakota-mineral-rights' },
	{ name: 'Texas', href: '/mineral-rights-by-state/texas-mineral-rights' },
	{ name: 'Utah', href: '/mineral-rights-by-state/utah-mineral-rights' },
	{ name: 'West Virginia', href: '/mineral-rights-by-state/west-virginia-mineral-rights' },
	{ name: 'Wyoming', href: '/mineral-rights-by-state/wyoming-mineral-rights' }
];

// Distribute states into 3 columns (down then across)
const column1 = states.filter((_, i) => i % 3 === 0);
const column2 = states.filter((_, i) => i % 3 === 1);
const column3 = states.filter((_, i) => i % 3 === 2);
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/mineral-rights-by-state')}>
		<ArticleContent>
			<div class="states-landing-page">
				<div class="states-header">
					<h1>Mineral Rights By State</h1>
					<p>Short articles discussing mineral rights by state. Articles include information on history, oil and gas operators, production, and significant fields. If you would like to discuss mineral rights related issues with other landowners across America visit <a href="https://mineralrightsforum.com" target="_blank" rel="noopener noreferrer">MineralRightsForum.com</a>.</p>
				</div>

				<div class="states-grid">
					<div class="states-column">
						{column1.map((state) => (
							<a href={state.href} class="state-link">
								{state.name}
							</a>
						))}
					</div>
					<div class="states-column">
						{column2.map((state) => (
							<a href={state.href} class="state-link">
								{state.name}
							</a>
						))}
					</div>
					<div class="states-column">
						{column3.map((state) => (
							<a href={state.href} class="state-link">
								{state.name}
							</a>
						))}
					</div>
				</div>

				<div class="states-footer">
					<p>Source information presented on these State Mineral Rights pages comes from various sources including Texas State Historical Association, American Association of Petroleum Geologists, Society of Petroleum Engineers, United States Geological Survey, various State Oil and Gas Regulatory Bodies, and various State Geological Surveys.</p>
				</div>
			</div>
		</ArticleContent>
	</PageShell>
</BaseLayout>

<style>
	.states-landing-page {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}

	.states-header {
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 2px solid #e2e8f0;
	}

	.states-header h1 {
		margin: 0 0 1rem 0;
		font-size: 2.5rem;
		font-weight: 700;
		line-height: 1.2;
		color: rgb(var(--gray-dark));
	}

	.states-header p {
		margin: 0;
		font-size: 1.125rem;
		line-height: 1.75rem;
		color: rgb(var(--gray-dark));
	}

	.states-header a {
		color: #0ea5e9;
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.states-header a:hover {
		color: #0284c7;
		text-decoration: underline;
	}

	.states-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin-bottom: 2.5rem;
	}

	.states-column {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: center;
	}

	.state-link {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 1.0625rem;
		font-weight: 600;
		line-height: 1.1;
		padding: 0.5rem 0;
		transition: color 0.2s;
		text-align: center;
	}

	.state-link:hover {
		color: #0ea5e9;
	}

	.states-footer {
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 2px solid #e2e8f0;
	}

	.states-footer p {
		margin: 0;
		font-size: 0.9375rem;
		line-height: 1.625rem;
		color: rgb(var(--gray-dark));
		opacity: 0.8;
	}

	@media (max-width: 768px) {
		.states-landing-page {
			padding: 1.5rem;
		}

		.states-header h1 {
			font-size: 2rem;
		}

		.states-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}
</style>
