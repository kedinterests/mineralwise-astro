---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Operator";
const description = "A company or individual, acting for himself or as an agent for others who has primary responsibility for maintaining well operations and complying with state rules and regulations.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Operator"
		definition="A company or individual, acting for himself or as an agent for others who has primary responsibility for maintaining well operations and complying with state rules and regulations."
		path="/operator"
		prevTerm={{ href: "/operating-expense", label: "Operating Expense" }}
		nextTerm={{ href: "/overriding-royalty-interest-orri", label: "Overriding Royalty Interest Orri" }}
	/>
</BaseLayout>
