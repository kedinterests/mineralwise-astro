		margin-top: 0;
	}

	.content-body p {
		margin-bottom: 1.25rem;
	}

	.content-body p:last-child {
		margin-bottom: 0;
	}

	.content-body ul {
		margin: 1.25rem 0;
		padding-left: 1.5rem;
	}

	.content-body li {
		margin-bottom: 0.75rem;
	}

	.content-body strong {
		color: #1a1a1a;
		font-weight: 600;
	}

	.content-image {
		width: 100%;
		height: 400px;
		object-fit: cover;
		object-position: center;
