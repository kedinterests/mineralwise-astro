	}

	.additional-reading h2 {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}

	.additional-reading ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

