---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Oklahoma Mineral Rights | MineralWise";
const metaDescription = "Oklahoma Mineral Rights cover some of the most resource rich areas in the United States. Oklahoma contains over 7,500 productive formation names. Oklahoma ranks";

const stateName = "Oklahoma";
const stateAbbr = "OK";
const description = "Oklahoma Mineral Rights cover some of the most resource rich areas in the United States. Oklahoma contains over 7,500 productive formation names. Oklahoma ranks";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/oklahoma-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
