---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Royalty";
const description = "Revenue generally received by a mineral owner from the production of oil or gas, free of costs (except taxes).";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Royalty"
		definition="Revenue generally received by a mineral owner from the production of oil or gas, free of costs (except taxes)."
		path="/royalty"
		prevTerm={{ href: "/revenue-statement", label: "Revenue Statement" }}
		nextTerm={{ href: "/royalty-interest", label: "Royalty Interest" }}
	/>
</BaseLayout>
