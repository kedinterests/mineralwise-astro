---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Colorado Mineral Rights | MineralWise";
const metaDescription = "Colorado Mineral Rights have wide ranging values. Colorado's mineral rights cover a wide range of hydrocarbon products including crude oil, natural gas, gold, s";

const stateName = "Colorado";
const stateAbbr = "CO";
const description = "Colorado Mineral Rights have wide ranging values. Colorado's mineral rights cover a wide range of hydrocarbon products including crude oil, natural gas, gold, s";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/colorado-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
