---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Louisiana Mineral Rights | MineralWise";
const metaDescription = "Louisiana Mineral Rights are somewhat unique. Unlike other states, Louisiana mineral rights revert back to the original owner after 10 years from the date of sa";

const stateName = "Louisiana";
const stateAbbr = "LA";
const description = "Louisiana Mineral Rights are somewhat unique. Unlike other states, Louisiana mineral rights revert back to the original owner after 10 years from the date of sa";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/louisiana-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
