---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Producing Mineral Interests";
const description = "A mineral interest upon which production is actively taking place and minerals being removed and marketed. Oil &amp;amp; gas leases often have stipulations that require “commercial quantities” for continuation of a lease.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Producing Mineral Interests"
		definition="A mineral interest upon which production is actively taking place and minerals being removed and marketed. Oil &amp; gas leases often have stipulations that require “commercial quantities” for continuation of a lease."
		path="/producing-mineral-interests"
		prevTerm={{ href: "/producer", label: "Producer" }}
		nextTerm={{ href: "/producing-mineral-owner", label: "Producing Mineral Owner" }}
	/>
</BaseLayout>
