---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Residue Gas";
const description = "Gas remaining after processing and extraction of NGL.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Residue Gas"
		definition="Gas remaining after processing and extraction of NGL."
		path="/residue-gas"
		prevTerm={{ href: "/reservoir-engineering", label: "Reservoir Engineering" }}
		nextTerm={{ href: "/revenue-statement", label: "Revenue Statement" }}
	/>
</BaseLayout>
