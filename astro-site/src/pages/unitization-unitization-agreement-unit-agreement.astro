const title = "Unitization, Unitization Agreement, Unit Agreement";
const description = "Joint operations to maximize recovery among separate operators within a common reservoir.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Unitization, Unitization Agreement, Unit Agreement"
		definition="Joint operations to maximize recovery among separate operators within a common reservoir."
		path="/unitization-unitization-agreement-unit-agreement"
		prevTerm={{ href: "/undeveloped-acreage", label: "Undeveloped Acreage" }}
		nextTerm={{ href: "/upstream", label: "Upstream" }}
	/>
</BaseLayout>
