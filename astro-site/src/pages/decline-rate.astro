---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Decline Rate";
const description = "The rate of change in oil and gas production for a particular well.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Decline Rate"
		definition="The rate of change in oil and gas production for a particular well."
		path="/decline-rate"
		prevTerm={{ href: "/decline-curve", label: "Decline Curve" }}
		nextTerm={{ href: "/defects-in-title", label: "Defects in Title" }}
	/>
</BaseLayout>
