---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Three (3-D) Seismic, Three Dimensional Seismic";
const description = "Advanced method for collecting, processing, and interpreting seismic data in three dimensions. Three-dimensional seismic data is collected from closely spaced lines over an area of interest. The advantages of using three-dimensional seismic include increased resolution as well as improved interpretational tools and data displays.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Three (3-D) Seismic, Three Dimensional Seismic"
		definition="Advanced method for collecting, processing, and interpreting seismic data in three dimensions. Three-dimensional seismic data is collected from closely spaced lines over an area of interest. The advantages of using three-dimensional seismic include increased resolution as well as improved interpretational tools and data displays."
		path="/three-3-d-seismic-three-dimensional-seismic"
		prevTerm={{ href: "/sweet-gas", label: "Sweet Gas" }}
		nextTerm={{ href: "/three-phase-separator", label: "Three Phase Separator" }}
	/>
</BaseLayout>
