---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "New York Mineral Rights | MineralWise";
const metaDescription = "Economic benefit from New York mineral rights date back to November 1865 when Job Moses' Hall Farm Petroleum Company discovered oil in Carrollton Township of Ca";

const stateName = "New York";
const stateAbbr = "NY";
const description = "Economic benefit from New York mineral rights date back to November 1865 when Job Moses' Hall Farm Petroleum Company discovered oil in Carrollton Township of Ca";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/new-york-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
