---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Marathon Oil Company | MineralWise";
const description = "Marathon Oil Company is engaged in the worldwide exploration and production of crude oil and natural gas, as well as the domestic refining, marketing, and transportation of petroleum products. Marathon stock is listed on the NYSE under the symbol MRO.";

const companyDescription = `Marathon Oil Company is engaged in the worldwide exploration and production of crude oil and natural gas, as well as the domestic refining, marketing, and transportation of petroleum products. Marathon stock is listed on the NYSE under the symbol MRO. Headquartered in Houston, Texas, Marathon Oil is among the leading energy industry players, applying innovative technologies to discover valuable energy resources and deliver the highest quality products to the marketplace.

Marathon is a company that strives to bring value and values together. Marathon's Business Development organization is comprised of elements of Strategic Planning and Portfolio Management, as well as focused new business development teams in the International Upstream, North American Upstream and Global Downstream businesses.

Together they are responsible for identifying and capturing new business opportunities that provide a strategic fit with the Company's upstream, downstream and integrated gas businesses. These efforts support Marathon's ongoing ability to meet the energy needs of our customers, while creating long-term shareholder value and growth.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/marathon-oil-company')}>
		<ArticleContent>
			<CompanyPage
				companyName="Marathon Oil Company"
				description={companyDescription}
				logoPath="/images/marathon-oil-.png"
				contactPhone="888-522-8871"
				showProductionVerification={true}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
