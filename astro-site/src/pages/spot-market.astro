---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Spot Market";
const description = "Short term, non-regulated, arms length contract sales of natural gas or crude oil.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Spot Market"
		definition="Short term, non-regulated, arms length contract sales of natural gas or crude oil."
		path="/spot-market"
		prevTerm={{ href: "/sour-gas-h2s", label: "Sour Gas H2s" }}
		nextTerm={{ href: "/stripper-well", label: "Stripper Well" }}
	/>
</BaseLayout>
