---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import OwnerGuideTabs from '../components/OwnerGuideTabs.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Unclaimed Oil &amp; Gas Royalties: Recover Your Funds &amp; Explore Investment Opportunities";
const description = "Learn how to recover unclaimed oil and gas royalties or royalties in suspense. Explore investment basics, risk evaluation, and get started in the oil and gas sector today!";

const heading = "Opportunities For All";
const intro = "Even if you don't currently have mineral interests, you might have unclaimed royalties or royalty in suspense in your name or your spouse's name. The articles below will help you find these unclaimed royalties and also show you how to get in the oil and gas investing arena.";

const tabs = [
	{
		label: "Recover Funds",
		id: "recover",
		articles: [
			{
				title: "Unclaimed Oil and Gas Royalty",
				href: "/unclaimed-oil-and-gas-royalty",
				description: "Explanation of how to recover your unclaimed oil & gas mineral rights and royalties. Includes links to state unclaimed property websites."
			},
			{
				title: "Royalty in Suspense",
				href: "/royalty-in-suspense",
				description: "Discover how oil and gas royalty owners can claim royalty in suspense, suspended funds, suspended royalty and money in suspense."
			}
		]
	},
	{
		label: "Investment Opportunities",
		id: "investment",
		articles: [
			{
				title: "Oil and Gas Investment Basics",
				href: "/oil-and-gas-basics-for-mineral-owners",
				description: "Short article explaining direct oil & gas investment basics for those considering investing in oil/gas wells. Topics include risk evaluation, deal structure."
			}
		]
	}
];
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/opportunities-for-all')}>
		<ArticleContent>
			<OwnerGuideTabs 
				heading={heading}
				intro={intro}
				tabs={tabs}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
