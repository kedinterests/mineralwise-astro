---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Infill Drilling";
const description = "Wells drilled to fill in between established producing wells on a lease.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Infill Drilling"
		definition="Wells drilled to fill in between established producing wells on a lease."
		path="/infill-drilling"
		prevTerm={{ href: "/independent-producer", label: "Independent Producer" }}
		nextTerm={{ href: "/initial-production-ip", label: "Initial Production Ip" }}
	/>
</BaseLayout>
