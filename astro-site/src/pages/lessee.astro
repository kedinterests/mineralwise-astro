---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Lessee";
const description = "The purchaser (taker) of an Oil, Gas and Mineral Lease.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Lessee"
		definition="The purchaser (taker) of an Oil, Gas and Mineral Lease."
		path="/lessee"
		prevTerm={{ href: "/lease-bonus", label: "Lease Bonus" }}
		nextTerm={{ href: "/lessor", label: "Lessor" }}
	/>
</BaseLayout>
