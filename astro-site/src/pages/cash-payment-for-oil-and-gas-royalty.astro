---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import OwnerGuideTabs from '../components/OwnerGuideTabs.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Maximize Your Oil &amp; Gas Royalties: Cash Payment Options for Mineral Rights";
const description = "Discover how to exchange your oil and gas royalties for a lump sum cash payment. Explore opportunities, benefits, and hassle-free options for selling your mineral rights today!";

const heading = "Cash Payment For Oil And Gas Royalty";
const intro = "Why Wait? You Have a Cash Option for Royalties and Mineral Rights. Remember the old saying \"A bird in the hand is worth two in the bush\"? If you're interested in exchanging your oil or gas royalty income stream for a lump sum cash payment, this option is available. Depending on your specific situation, it could make sense for you. Reasons for selling royalties and mineral rights effectively fall into two basic categories – opportunity and need.";

const tabs = [
	{
		label: "Understanding Value",
		id: "value",
		articles: [
			{
				title: "Volume Verification",
				href: "/oil-and-gas-production-volume-verification",
				description: "Short article explaining how oil and gas royalty owners can verify their oil and gas production. Includes links to free state verification"
			},
			{
				title: "Oil & Gas 101: Oil and Gas Basics for the Mineral Owner",
				href: "/oil-and-gas-basics-for-mineral-owners",
				description: "Article explaining the basics of oil and gas production written for mineral rights owners. Topics include drilling, production, pricing and marketing."
			}
		]
	},
	{
		label: "Tax Strategies",
		id: "taxes",
		articles: [
			{
				title: "1031 Exchange for Mineral Rights",
				href: "/1031-exchange-for-mineral-rights",
				description: "Learn what qualifies, how it works, and the benefits of Like-Kind Exchanges which can defer taxes."
			}
		]
	}
];
---

<BaseLayout title={title} description={description} adConfig="none">
	<PageShell breadcrumbs={getBreadcrumbs('/cash-payment-for-oil-and-gas-royalty')}>
		<ArticleContent>
			<OwnerGuideTabs 
				heading={heading}
				intro={intro}
				tabs={tabs}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
