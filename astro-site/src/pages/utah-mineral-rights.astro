---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Utah Mineral Rights | MineralWise";
const metaDescription = "Pat Holohan was the first to drill for oil in 1907 when he found oil in Washington County. Shortly after his discovery, more than 12 companies rushed in to dril";

const stateName = "Utah";
const stateAbbr = "UT";
const description = "Pat Holohan was the first to drill for oil in 1907 when he found oil in Washington County. Shortly after his discovery, more than 12 companies rushed in to dril";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/utah-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
