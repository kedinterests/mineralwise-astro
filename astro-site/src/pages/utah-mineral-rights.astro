---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Utah Mineral Rights | MineralWise";
const metaDescription = "Pat Holohan was the first to drill for oil in 1907 when he found oil in Washington County. Shortly after his discovery, more than 12 companies rushed in to drill 14 more oil wells.";

const stateName = "Utah";
const stateAbbr = "UT";
const description = "Pat Holohan was the first to drill for oil in 1907 when he found oil in Washington County. Shortly after his discovery, more than 12 companies rushed in to drill 14 more oil wells. Utah mineral rights include crude oil and natural gas. Utah ranks 13th in the nation for crude oil production and 8th in the nation for natural gas production. Utah currently has approximately 8,600 wells producing oil and natural gas. Mineral rights in Utah provide substantial economic benefit to the state and it's citizens.";

const stats = [];
const majorFields = [
	"Anschutz Ranch East Field",
	"Bluebell Field",
	"Brundage Canyon Field",
	"Buzzard Bench Field",
	"Drunkards Wash Field",
	"Flat Rock Field",
	"Greater Aneth Field",
	"Helper Field",
	"Monument Butte Field",
	"Natural Buttes Field",
	"Nine Mile Canyon Field",
	"Peter's Point Field",
	"Wonsites Valley Field"
];
const companies = [
	"Anadarko Petroleum",
	"Berry Petroleum",
	"Bill Barrett",
	"Conoco Phillips",
	"El Paso E&P",
	"EOG Resources",
	"Gasco Production",
	"Kerr-McGee",
	"Merit Energy",
	"Newfield Production",
	"Questar Exploration & Production",
	"Resolute Natural Resources",
	"Wolverine Gas & Oil",
	"XTO Energy"
];
const additionalReading = [
	{
		text: "Oil & Gas 101",
		href: "/oil-and-gas-basics-for-mineral-owners",
		external: false
	}
];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/utah-mineral-rights')}>
		<ArticleContent>
			<StatePage
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
				majorFields={majorFields}
				companies={companies}
				additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
