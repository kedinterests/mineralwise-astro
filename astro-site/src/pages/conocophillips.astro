---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "ConocoPhillips | MineralWise";
const description = "ConocoPhillips Company is an international energy corporation with its headquarters located in Houston, Texas. ConocoPhillips stock is traded on the NYSE under the symbol COP. ConocoPhillips is the fifth largest private sector energy corporation in the world. Conoco Inc. was started in 1875 as the Continental Oil and Transportation Co.Based in Ogden, Utah. It is operated in more than 30 countries.";

const companyDescription = `Company is an international energy corporation with its headquarters located in Houston, Texas. ConocoPhillips stock is traded on the NYSE under the symbol COP. ConocoPhillips is the fifth largest private sector energy corporation in the world. Conoco Inc. was started in 1875 as the Continental Oil and Transportation Co.Based in Ogden, Utah. It is operated in more than 30 countries.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/conocophillips')}>
		<ArticleContent>
			<CompanyPage
				companyName="ConocoPhillips"
				description={companyDescription}
				logoPath="/images/conoco.png"
				contactPhone="281-293-1000"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
