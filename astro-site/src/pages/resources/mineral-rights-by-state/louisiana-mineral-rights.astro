---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import StatePage from '../../../components/StatePage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Louisiana Mineral Rights | MineralWise";
const metaDescription = "Louisiana Mineral Rights are somewhat unique. Unlike other states, Louisiana mineral rights revert back to the original owner after 10 years from the date of sale or from the date of last production.";

const stateName = "Louisiana";
const stateAbbr = "LA";
const description = "Louisiana Mineral Rights are somewhat unique. Unlike other states, Louisiana mineral rights revert back to the original owner after 10 years from the date of sale or from the date of last production. Special care must be taken when dealing with Louisiana Mineral Rights in Louisiana because of Louisiana's Napoleonic law system. The first oil well discovered in Louisiana was the Heywood well in 1901.";

const stats = [];
const majorFields = [
	"Bethany-Longstreet Field",
	"Caspiana Field",
	"Elm Grove Field",
	"Lake Washington Field",
	"Logansport-Joaquin Field",
	"Sligo Field",
	"Spider Field",
	"Vernon Field"
];
const companies = [
	"Cabot Oil & Gas",
	"Chesapeake Energy",
	"Cubic Energy",
	"EnCana Corp",
	"GMX Resources",
	"Goodrich Petroleum",
	"Penn Virginia",
	"Petrohawk Energy",
	"XTO Energy"
];
const regulatoryLink = {
	text: "http://dnr.louisiana.gov/",
	href: "http://dnr.louisiana.gov/",
	external: true
};
const additionalReading = [
	{
		text: "Oil & Gas 101",
		href: "/owners-guide/oil-and-gas-basics-for-mineral-owners",
		external: false
	},
	{
		text: "Haynesville Shale Louisiana",
		href: "/resources/shale-plays/haynesville-shale-louisiana",
		external: false
	}
];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/mineral-rights-by-state/louisiana-mineral-rights')}>
		<ArticleContent>
			<StatePage
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
				majorFields={majorFields}
				companies={companies}
				regulatoryLink={regulatoryLink}
				additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
