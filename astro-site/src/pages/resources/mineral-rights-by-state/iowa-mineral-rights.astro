---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import StatePage from '../../../components/StatePage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Iowa Mineral Rights | MineralWise";
const metaDescription = "The value of Iowa mineral rights was influenced slightly beginning in 1963 when oil was first discovered in Washington County. 123 oil wells have since been drilled in Iowa but only 3 have yielded oil.";

const stateName = "Iowa";
const stateAbbr = "IA";
const description = "The value of Iowa mineral rights was influenced slightly beginning in 1963 when oil was first discovered in Washington County. 123 oil wells have since been drilled in Iowa but only 3 have yielded oil. All three of those that have yielded oil are located in Washington County and have produced a total of about 500 barrels. Most mineral rights in Iowa with production potential are located in southeast Iowa, southwest Iowa, and in the flanks of the Mid-continent rift that splits through the state from the central Minnesota border to the southwest corner of Iowa.";

const stats = [];
const majorFields = [];
const companies = [];
const regulatoryLink = {
	text: "http://www.igsb.uiowa.edu/",
	href: "http://www.igsb.uiowa.edu/",
	external: true
};
const additionalReading = [
	{
		text: "Oil & Gas 101",
		href: "/owners-guide/oil-and-gas-basics-for-mineral-owners",
		external: false
	}
];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/mineral-rights-by-state/iowa-mineral-rights')}>
		<ArticleContent>
			<StatePage
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
				regulatoryLink={regulatoryLink}
				additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
