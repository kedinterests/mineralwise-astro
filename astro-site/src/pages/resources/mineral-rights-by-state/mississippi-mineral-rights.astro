---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import StatePage from '../../../components/StatePage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Mississippi Mineral Rights | MineralWise";
const metaDescription = "Mississippi Mineral Rights pertaining to oil and gas have been productive since October of 1926 with the drilling of the Amory Petroleum Company #1 Carter.";

const stateName = "Mississippi";
const stateAbbr = "MS";
const description = "Mississippi Mineral Rights pertaining to oil and gas have been productive since October of 1926 with the drilling of the Amory Petroleum Company #1 Carter. Mississippi minerals also include a wide range of hydrocarbon products including crude oil, natural gas, NGL's, CO2, and coal. The first field discovered in Mississippi was the Amory Field in Monroe County. The top counties by well count are Jasper County, Jefferson Davis County, and Lamar County.";

const stats = [];
const majorFields = [
	"Baxterville Field",
	"Bay Springs Field",
	"Brookhaven Field",
	"Corinne Field",
	"Cranfield Field",
	"East Eucutta Field",
	"East Heidelberg Field",
	"Gwinville Field",
	"Little Creek Field",
	"Mallalieu Field",
	"Martinville Field",
	"McComb Field",
	"Soso Field",
	"Summerland Field",
	"Tinsley Field",
	"Trimble Field"
];
const companies = [
	"Callon Petroleum",
	"Denbury Resources",
	"EOG Resources",
	"Hunt Oil",
	"Mossbacher Energy",
	"Penn Virginia",
	"Shell Oil",
	"Spooner Petroleum",
	"Victor P Smith"
];
const additionalReading = [
	{
		text: "Oil & Gas 101",
		href: "/owners-guide/oil-and-gas-basics-for-mineral-owners",
		external: false
	}
];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/mineral-rights-by-state/mississippi-mineral-rights')}>
		<ArticleContent>
			<StatePage
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
				majorFields={majorFields}
				companies={companies}
				additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
