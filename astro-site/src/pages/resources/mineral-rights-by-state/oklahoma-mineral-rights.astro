---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import StatePage from '../../../components/StatePage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Oklahoma Mineral Rights | MineralWise";
const metaDescription = "Oklahoma Mineral Rights cover some of the most resource rich areas in the United States. Oklahoma contains over 7,500 productive formation names. Oklahoma ranks 5th in the nation for crude oil production.";

const stateName = "Oklahoma";
const stateAbbr = "OK";
const description = "Oklahoma Mineral Rights cover some of the most resource rich areas in the United States. Oklahoma contains over 7,500 productive formation names. Oklahoma ranks 5th in the nation for crude oil production. Oklahoma accounts for about 8% of the total U.S. natural gas production. Over 480,000 wells have been drilled in the state of Oklahoma, and at one time in 1927 it was the largest oil producing region in the world. The first oil well discovered in Oklahoma was the Nellie Johnstone No. 1 in 1897.";

const stats = [];
const majorFields = [
	"Burbank Field",
	"Fitts Field",
	"Golden Trend Field",
	"Hugoton Field",
	"Postle Field",
	"Sho-vel-tum field",
	"Stiles Ranch Field",
	"Strong City District Field"
];
const companies = [
	"Anadarko Petroleum",
	"Chesapeake Energy",
	"Conoco",
	"Devon Energy",
	"Marathon Oil",
	"RKK Production"
];
const regulatoryLink = {
	text: "http://www.occeweb.com/Orawebapps/OCCOraWebAppsone.html",
	href: "http://www.occeweb.com/Orawebapps/OCCOraWebAppsone.html",
	external: true
};
const additionalReading = [
	{
		text: "Oil & Gas 101",
		href: "/owners-guide/oil-and-gas-basics-for-mineral-owners",
		external: false
	},
	{
		text: "Woodford Shale",
		href: "/resources/shale-plays/woodford-shale-oklahoma",
		external: false
	}
];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/mineral-rights-by-state/oklahoma-mineral-rights')}>
		<ArticleContent>
			<StatePage
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
				majorFields={majorFields}
				companies={companies}
				regulatoryLink={regulatoryLink}
				additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
