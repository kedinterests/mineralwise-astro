---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Horizontal Drilling";
const description = "A well of which a portion is drilled horizontally to expose more of the formation surface area to the well bore.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Horizontal Drilling"
		definition="A well of which a portion is drilled horizontally to expose more of the formation surface area to the well bore."
		path="/resources/oil-and-gas-terms/horizontal-drilling"
		prevTerm={{ href: "/resources/oil-and-gas-terms/henry-hub", label: "Henry Hub" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/horizontal-pugh-clause", label: "Horizontal Pugh Clause" }}
	/>
</BaseLayout>
