---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Suspended Funds";
const description = "Money that is held by the operator until certain requirements are met.&amp;nbsp;This often happens when a change in title has taken place.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Suspended Funds"
		definition="Money that is held by the operator until certain requirements are met.&nbsp;This often happens when a change in title has taken place."
		path="/resources/oil-and-gas-terms/suspended-funds"
		prevTerm={{ href: "/resources/oil-and-gas-terms/surface-rights", label: "Surface Rights" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/swab-swabbing", label: "Swab Swabbing" }}
	/>
</BaseLayout>
