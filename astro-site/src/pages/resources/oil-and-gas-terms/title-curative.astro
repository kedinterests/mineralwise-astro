---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Title Curative";
const description = "Measures taken to fix any defects in the chain of title (ownership history), which includes correcting instruments and reconciling title with the use and possession of land.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Title Curative"
		definition="Measures taken to fix any defects in the chain of title (ownership history), which includes correcting instruments and reconciling title with the use and possession of land."
		path="/resources/oil-and-gas-terms/title-curative"
		prevTerm={{ href: "/resources/oil-and-gas-terms/title-abstract", label: "Title Abstract" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/top-lease", label: "Top Lease" }}
	/>
</BaseLayout>
