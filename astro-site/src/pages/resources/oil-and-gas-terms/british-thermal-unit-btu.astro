---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "British Thermal Unit, BTU";
const description = "The amount of heat required to raise the temperature of one pound of water one degree Fahrenheit under standard conditions of pressure and temperature.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="British Thermal Unit, BTU"
		definition="The amount of heat required to raise the temperature of one pound of water one degree Fahrenheit under standard conditions of pressure and temperature."
		path="/resources/oil-and-gas-terms/british-thermal-unit-btu"
		prevTerm={{ href: "/resources/oil-and-gas-terms/brine", label: "Brine" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/btu-factor", label: "BTU Factor" }}
	/>
</BaseLayout>
