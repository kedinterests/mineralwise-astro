---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Infill Drilling";
const description = "Wells drilled to fill in between established producing wells on a lease.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Infill Drilling"
		definition="Wells drilled to fill in between established producing wells on a lease."
		path="/resources/oil-and-gas-terms/infill-drilling"
		prevTerm={{ href: "/resources/oil-and-gas-terms/independent-producer", label: "Independent Producer" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/initial-production-ip", label: "Initial Production Ip" }}
	/>
</BaseLayout>
