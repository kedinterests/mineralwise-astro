---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Easement";
const description = "An easement is a created interest which allows usage for a stated purpose. In oil and gas, this is most commonly for installing and operating pipelines.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Easement"
		definition="An easement is a created interest which allows usage for a stated purpose. In oil and gas, this is most commonly for installing and operating pipelines."
		path="/resources/oil-and-gas-terms/easement"
		prevTerm={{ href: "/resources/oil-and-gas-terms/dry-hole", label: "Dry Hole" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/electric-log", label: "Electric Log" }}
	/>
</BaseLayout>
