---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Blowout Preventor, BP";
const description = "Casinghead equipment that prevents the uncontrolled flow of oil, gas and mud from the well by closing around the drill pipe or sealing the hole.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Blowout Preventor, BP"
		definition="Casinghead equipment that prevents the uncontrolled flow of oil, gas and mud from the well by closing around the drill pipe or sealing the hole."
		path="/resources/oil-and-gas-terms/blowout-preventor-bp"
		prevTerm={{ href: "/resources/oil-and-gas-terms/bcf", label: "BCF" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/bopd", label: "BOPD" }}
	/>
</BaseLayout>
