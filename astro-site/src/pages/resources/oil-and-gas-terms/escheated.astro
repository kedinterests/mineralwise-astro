---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Escheated";
const description = "In today’s usage, this is the process whereby property to which there is no claimant is returned to the state, usually the state comptroller’s office.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Escheated"
		definition="In today’s usage, this is the process whereby property to which there is no claimant is returned to the state, usually the state comptroller’s office."
		path="/resources/oil-and-gas-terms/escheated"
		prevTerm={{ href: "/resources/oil-and-gas-terms/electric-log", label: "Electric Log" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/executive-rights-to-minerals", label: "Executive Rights to Minerals" }}
	/>
</BaseLayout>
