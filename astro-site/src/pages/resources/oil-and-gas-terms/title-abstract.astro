---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Title Abstract";
const description = "A chronological history of the ownership or significant events effecting a particular piece of property.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Title Abstract"
		definition="A chronological history of the ownership or significant events effecting a particular piece of property."
		path="/resources/oil-and-gas-terms/title-abstract"
		prevTerm={{ href: "/resources/oil-and-gas-terms/three-phase-separator", label: "Three Phase Separator" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/title-curative", label: "Title Curative" }}
	/>
</BaseLayout>
