---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Possible Reserves";
const description = "Possible reserves are less certain than Probable reserves and can be estimated with a low degree of certainty. Used to refer to reserves that have a greater than 10% chance of being recovered (P10).";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Possible Reserves"
		definition="Possible reserves are less certain than Probable reserves and can be estimated with a low degree of certainty. Used to refer to reserves that have a greater than 10% chance of being recovered (P10)."
		path="/resources/oil-and-gas-terms/possible-reserves"
		prevTerm={{ href: "/resources/oil-and-gas-terms/porosity", label: "Porosity" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/pounds-per-square-inch-psi", label: "Pounds Per Square Inch Psi" }}
	/>
</BaseLayout>
