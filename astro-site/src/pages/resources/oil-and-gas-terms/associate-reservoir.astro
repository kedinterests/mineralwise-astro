---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Associate Reservoir";
const description = "Oil and gas reservoir with a gas cap. Gas production from these reservoirs is generally restricted in order to preserve the gas cap energy, thereby increasing ultimate recovery.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Associate Reservoir"
		definition="Oil and gas reservoir with a gas cap. Gas production from these reservoirs is generally restricted in order to preserve the gas cap energy, thereby increasing ultimate recovery."
		path="/resources/oil-and-gas-terms/associate-reservoir"
		prevTerm={{ href: "/resources/oil-and-gas-terms/assignment", label: "Assignment" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/bank-draft", label: "Bank Draft" }}
	/>
</BaseLayout>
