---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Farm-In";
const description = "An arrangement whereby an Operator buys in or acquires an interest in a lease owned by another Operator on which oil or gas has been discovered or is being produced. Often farm-ins are negotiated to help the original owner with development costs and to secure for the buyer a source of crude oil or natural gas.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Farm-In"
		definition="An arrangement whereby an Operator buys in or acquires an interest in a lease owned by another Operator on which oil or gas has been discovered or is being produced. Often farm-ins are negotiated to help the original owner with development costs and to secure for the buyer a source of crude oil or natural gas."
		path="/resources/oil-and-gas-terms/farm-in"
		prevTerm={{ href: "/resources/oil-and-gas-terms/extraction-loss", label: "Extraction Loss" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/farmout", label: "Farmout" }}
	/>
</BaseLayout>
