---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Dry Hole";
const description = "Any well that fails to discover oil or gas in paying quantities.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Dry Hole"
		definition="Any well that fails to discover oil or gas in paying quantities."
		path="/resources/oil-and-gas-terms/dry-hole"
		prevTerm={{ href: "/resources/oil-and-gas-terms/dry-gas", label: "Dry Gas" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/easement", label: "Easement" }}
	/>
</BaseLayout>
