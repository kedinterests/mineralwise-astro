---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Oil &amp; Gas “Field”";
const description = "Area of oil and gas production with at least one common reservoir for the entire area.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Oil &amp; Gas “Field”"
		definition="Area of oil and gas production with at least one common reservoir for the entire area."
		path="/resources/oil-and-gas-terms/oil-and-gas-field"
		prevTerm={{ href: "/resources/oil-and-gas-terms/non-producing-mineral-owner", label: "Non Producing Mineral Owner" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/oil-and-gas-mineral-lease", label: "Oil And Gas Mineral Lease" }}
	/>
</BaseLayout>
