---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Participating Royalty Interest";
const description = "A royalty interest giving its owner the right to “participate” in bonuses received and in any oil or gas found.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Participating Royalty Interest"
		definition="A royalty interest giving its owner the right to “participate” in bonuses received and in any oil or gas found."
		path="/resources/oil-and-gas-terms/participating-royalty-interest"
		prevTerm={{ href: "/resources/oil-and-gas-terms/paid-up-lease", label: "Paid Up Lease" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/percentage-depletion", label: "Percentage Depletion" }}
	/>
</BaseLayout>
