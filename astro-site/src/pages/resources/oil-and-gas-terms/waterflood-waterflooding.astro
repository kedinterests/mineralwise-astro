import TermPage from '../../../components/TermPage.astro';

const title = "Waterflood, Waterflooding";
const description = "A form of secondary recovery, the process of injecting water into injection wells causing oil to migrate to adjacent producing wells.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Waterflood, Waterflooding"
		definition="A form of secondary recovery, the process of injecting water into injection wells causing oil to migrate to adjacent producing wells."
		path="/resources/oil-and-gas-terms/waterflood-waterflooding"
		prevTerm={{ href: "/resources/oil-and-gas-terms/w-9", label: "W 9" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/well-site", label: "Well Site" }}
	/>
</BaseLayout>
