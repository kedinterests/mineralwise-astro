---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Extraction Loss";
const description = "The reduction in volume and energy content of natural gas resulting from the removal of natural gas liquid constituents.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Extraction Loss"
		definition="The reduction in volume and energy content of natural gas resulting from the removal of natural gas liquid constituents."
		path="/resources/oil-and-gas-terms/extraction-loss"
		prevTerm={{ href: "/resources/oil-and-gas-terms/exponential-decline", label: "Exponential Decline" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/farm-in", label: "Farm-In" }}
	/>
</BaseLayout>
