---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Primary Term";
const description = "The initial period provided in an oil and gas lease to develop the property. Oil &amp;amp; gas leases ofter have a secondary term referred to as an extension.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Primary Term"
		definition="The initial period provided in an oil and gas lease to develop the property. Oil &amp; gas leases ofter have a secondary term referred to as an extension."
		path="/resources/oil-and-gas-terms/primary-term"
		prevTerm={{ href: "/resources/oil-and-gas-terms/pounds-per-square-inch-psi", label: "Pounds Per Square Inch Psi" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/probable-reserves", label: "Probable Reserves" }}
	/>
</BaseLayout>
