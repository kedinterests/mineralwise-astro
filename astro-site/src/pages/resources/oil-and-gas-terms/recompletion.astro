---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Recompletion";
const description = "The completion for production of an existing well bore in another formation from that in which the well was previously completed.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Recompletion"
		definition="The completion for production of an existing well bore in another formation from that in which the well was previously completed."
		path="/resources/oil-and-gas-terms/recompletion"
		prevTerm={{ href: "/resources/oil-and-gas-terms/ratification", label: "Ratification" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/regulatory-agency", label: "Regulatory Agency" }}
	/>
</BaseLayout>
