---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Commodity Prices";
const description = "Crude oil and natural gas are commodities, thus are priced on a commodity exchange, the New York Mercantile Exchange (NYMEX).";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Commodity Prices"
		definition="Crude oil and natural gas are commodities, thus are priced on a commodity exchange, the New York Mercantile Exchange (NYMEX)."
		path="/resources/oil-and-gas-terms/commodity-prices"
		prevTerm={{ href: "/resources/oil-and-gas-terms/commodities", label: "Commodities" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/completion", label: "Completion" }}
	/>
</BaseLayout>
