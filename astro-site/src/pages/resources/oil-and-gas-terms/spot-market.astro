---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Spot Market";
const description = "Short term, non-regulated, arms length contract sales of natural gas or crude oil.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Spot Market"
		definition="Short term, non-regulated, arms length contract sales of natural gas or crude oil."
		path="/resources/oil-and-gas-terms/spot-market"
		prevTerm={{ href: "/resources/oil-and-gas-terms/sour-gas-h2s", label: "Sour Gas H2s" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/stripper-well", label: "Stripper Well" }}
	/>
</BaseLayout>
