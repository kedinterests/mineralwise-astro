---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Upstream";
const description = "Refers to the searching for and the recovery and production of crude oil and natural gas.&amp;nbsp;Commonly referred to as the exploration and production (E&amp;amp;P) sector.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Upstream"
		definition="Refers to the searching for and the recovery and production of crude oil and natural gas.&nbsp;Commonly referred to as the exploration and production (E&amp;P) sector."
		path="/resources/oil-and-gas-terms/upstream"
		prevTerm={{ href: "/resources/oil-and-gas-terms/unitization-unitization-agreement-unit-agreement", label: "Unitization Unitization Agreement Unit Agreement" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/vertical-pugh-clause", label: "Vertical Pugh Clause" }}
	/>
</BaseLayout>
