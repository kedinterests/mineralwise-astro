---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Exponential Decline";
const description = "A single decline rate that is used for the life of a well.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Exponential Decline"
		definition="A single decline rate that is used for the life of a well."
		path="/resources/oil-and-gas-terms/exponential-decline"
		prevTerm={{ href: "/resources/oil-and-gas-terms/exploratory-well", label: "Exploratory Well" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/extraction-loss", label: "Extraction Loss" }}
	/>
</BaseLayout>
