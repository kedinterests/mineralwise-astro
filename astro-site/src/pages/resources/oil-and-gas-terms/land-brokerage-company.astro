	<TermPage
		term="Land Brokerage Company"
		definition="An organization that offers its services to oil and gas Operators for the purpose of obtaining leases. Often independent landmen work for a land brokerage company."
		path="/resources/oil-and-gas-terms/land-brokerage-company"
		prevTerm={{ href: "/resources/oil-and-gas-terms/intestate-death", label: "Intestate Death" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/land-department", label: "Land Department" }}
	/>
</BaseLayout>
