import TermPage from '../../../components/TermPage.astro';

const title = "Mcfe";
const description = "Mcf of natural gas equivalent, usually determined by using the ratio of six Mcf of natural gas to one Bbl of crude oil, condensate or natural gas liquids.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Mcfe"
		definition="Mcf of natural gas equivalent, usually determined by using the ratio of six Mcf of natural gas to one Bbl of crude oil, condensate or natural gas liquids."
		path="/resources/oil-and-gas-terms/mcfe"
		prevTerm={{ href: "/resources/oil-and-gas-terms/mcf", label: "Mcf" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/mineral-lease", label: "Mineral Lease" }}
	/>
</BaseLayout>
