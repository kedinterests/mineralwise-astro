---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Severance Tax";
const description = "A state tax levied against both royalty and working interest owners upon their pro rata share of oil and gas production. Each state sets its own severance tax rates, and often have special provisions for low rate wells, secondary recovery wells, etc.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Severance Tax"
		definition="A state tax levied against both royalty and working interest owners upon their pro rata share of oil and gas production. Each state sets its own severance tax rates, and often have special provisions for low rate wells, secondary recovery wells, etc."
		path="/resources/oil-and-gas-terms/severance-tax"
		prevTerm={{ href: "/resources/oil-and-gas-terms/severance", label: "Severance" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/severed-minerals", label: "Severed Minerals" }}
	/>
</BaseLayout>
