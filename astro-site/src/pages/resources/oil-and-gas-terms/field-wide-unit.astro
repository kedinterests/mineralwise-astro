---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Field-Wide Unit";
const description = "The combining of all wells and ownership interests within an entire field for the purpose of maximizing the overall benefit to all parties. The practice of field wide unitization is used more often in offshore fields and onshore in fields that require enhanced recovery.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Field-Wide Unit"
		definition="The combining of all wells and ownership interests within an entire field for the purpose of maximizing the overall benefit to all parties. The practice of field wide unitization is used more often in offshore fields and onshore in fields that require enhanced recovery."
		path="/resources/oil-and-gas-terms/field-wide-unit"
		prevTerm={{ href: "/resources/oil-and-gas-terms/field-run-ticket", label: "Field Run Ticket" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/first-purchaser", label: "First Purchaser" }}
	/>
</BaseLayout>
