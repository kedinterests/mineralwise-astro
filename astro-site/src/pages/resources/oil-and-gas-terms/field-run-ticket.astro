---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Field Run Ticket";
const description = "A paper record completed by the purchasers or transporters representative documenting how much crude oil was removed from an oil well location.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Field Run Ticket"
		definition="A paper record completed by the purchasers or transporters representative documenting how much crude oil was removed from an oil well location."
		path="/resources/oil-and-gas-terms/field-run-ticket"
		prevTerm={{ href: "/resources/oil-and-gas-terms/field-rules", label: "Field Rules" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/field-wide-unit", label: "Field-Wide Unit" }}
	/>
</BaseLayout>
