---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "BOPD";
const description = "The abbreviation for barrels of oil per day.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="BOPD"
		definition="The abbreviation for barrels of oil per day."
		path="/resources/oil-and-gas-terms/bopd"
		prevTerm={{ href: "/resources/oil-and-gas-terms/blowout-preventor-bp", label: "Blowout Preventor, BP" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/bottom-hole-pressure-bhp", label: "Bottom Hole Pressure, BHP" }}
	/>
</BaseLayout>
