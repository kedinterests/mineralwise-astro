---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Structural Trap";
const description = "An underground fold or break (or both) which creates an impervious trap where oil and gas can accumulate.&amp;nbsp;Oil will migrate underground through rock until it is “trapped”.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Structural Trap"
		definition="An underground fold or break (or both) which creates an impervious trap where oil and gas can accumulate.&nbsp;Oil will migrate underground through rock until it is “trapped”."
		path="/resources/oil-and-gas-terms/structural-trap"
		prevTerm={{ href: "/resources/oil-and-gas-terms/stripper-well", label: "Stripper Well" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/substandard-acreage", label: "Substandard Acreage" }}
	/>
</BaseLayout>
