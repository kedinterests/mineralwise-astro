---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Well Site";
const description = "The physical location on which an oil or gas well is drilled.&amp;nbsp;The size of the well site generally ranges from about ½ to 2 acres, depending on the foot print of the production facilities needed.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Well Site"
		definition="The physical location on which an oil or gas well is drilled.&nbsp;The size of the well site generally ranges from about ½ to 2 acres, depending on the foot print of the production facilities needed."
		path="/resources/oil-and-gas-terms/well-site"
		prevTerm={{ href: "/resources/oil-and-gas-terms/waterflood-waterflooding", label: "Waterflood Waterflooding" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/wildcat", label: "Wildcat" }}
	/>
</BaseLayout>
