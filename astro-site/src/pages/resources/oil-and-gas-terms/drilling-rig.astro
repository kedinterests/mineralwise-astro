		term="Drilling Rig"
		definition="The equipment used to bore into the earth. Rotary style drilling is what is primarily used in today’s drilling."
		path="/resources/oil-and-gas-terms/drilling-rig"
		prevTerm={{ href: "/resources/oil-and-gas-terms/drilling-mud-drilling-fluid", label: "Drilling Mud, Drilling Fluid" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/dry-gas", label: "Dry Gas" }}
	/>
</BaseLayout>
