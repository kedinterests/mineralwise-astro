---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Salt Water Disposal Well, SWD";
const description = "Well used for the purpose of injecting produced water back into the ground.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Salt Water Disposal Well, SWD"
		definition="Well used for the purpose of injecting produced water back into the ground."
		path="/resources/oil-and-gas-terms/salt-water-disposal-well-swd"
		prevTerm={{ href: "/resources/oil-and-gas-terms/royalty-statement", label: "Royalty Statement" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/secondary-recovery", label: "Secondary Recovery" }}
	/>
</BaseLayout>
