---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Non-Producing Mineral Owner";
const description = "An owner of minerals that are not currently being produced and sold.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Non-Producing Mineral Owner"
		definition="An owner of minerals that are not currently being produced and sold."
		path="/resources/oil-and-gas-terms/non-producing-mineral-owner"
		prevTerm={{ href: "/resources/oil-and-gas-terms/non-participating-royalty-interest", label: "Non Participating Royalty Interest" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/oil-and-gas-field", label: "Oil &amp; Gas “Field”" }}
	/>
</BaseLayout>
