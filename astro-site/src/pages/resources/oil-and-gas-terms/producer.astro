---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Producer";
const description = "A producer of oil and gas, also sometimes referred to as an Operator, or the Oil Company.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Producer"
		definition="A producer of oil and gas, also sometimes referred to as an Operator, or the Oil Company."
		path="/resources/oil-and-gas-terms/producer"
		prevTerm={{ href: "/resources/oil-and-gas-terms/processing-plant", label: "Processing Plant" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/producing-mineral-interests", label: "Producing Mineral Interests" }}
	/>
</BaseLayout>
