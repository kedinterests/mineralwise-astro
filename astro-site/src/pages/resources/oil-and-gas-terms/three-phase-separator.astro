import TermPage from '../../../components/TermPage.astro';

const title = "Three Phase Separator";
const description = "A separator located near the wellhead which separates oil, water, and gas.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Three Phase Separator"
		definition="A separator located near the wellhead which separates oil, water, and gas."
		path="/resources/oil-and-gas-terms/three-phase-separator"
		prevTerm={{ href: "/resources/oil-and-gas-terms/three-3-d-seismic-three-dimensional-seismic", label: "Three 3 D Seismic Three Dimensional Seismic" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/title-abstract", label: "Title Abstract" }}
	/>
</BaseLayout>
