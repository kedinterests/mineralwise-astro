---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Horizontal Pugh Clause";
const description = "A clause often added to an oil lease to limit holding non producing lands beyond primary term of a lease. Also known as a Freestone Rider or a Pugh Clause.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Horizontal Pugh Clause"
		definition="A clause often added to an oil lease to limit holding non producing lands beyond primary term of a lease. Also known as a Freestone Rider or a Pugh Clause."
		path="/resources/oil-and-gas-terms/horizontal-pugh-clause"
		prevTerm={{ href: "/resources/oil-and-gas-terms/horizontal-drilling", label: "Horizontal Drilling" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/hydraulic-fracturing-fracture-fracing-fracking-frac-job", label: "Hydraulic Fracturing, Fracture, Fracing, Fracking, Frac Job" }}
	/>
</BaseLayout>
