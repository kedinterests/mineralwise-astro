---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Fuel and Shrinkage";
const description = "The difference between the amounts of gas produced at the wellhead and the gas that enters a pipeline for sale. The losses include those from the separation process, field use, as well as fuel, flare gas and plant liquids extraction.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Fuel and Shrinkage"
		definition="The difference between the amounts of gas produced at the wellhead and the gas that enters a pipeline for sale. The losses include those from the separation process, field use, as well as fuel, flare gas and plant liquids extraction."
		path="/resources/oil-and-gas-terms/fuel-and-shrinkage"
		prevTerm={{ href: "/resources/oil-and-gas-terms/fresh-water", label: "Fresh Water" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/gas-lift", label: "Gas Lift" }}
	/>
</BaseLayout>
