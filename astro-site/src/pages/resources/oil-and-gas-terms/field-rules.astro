---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Field Rules";
const description = "Spacing and production rules mandated by the state for a common reservoir in an area.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Field Rules"
		definition="Spacing and production rules mandated by the state for a common reservoir in an area."
		path="/resources/oil-and-gas-terms/field-rules"
		prevTerm={{ href: "/resources/oil-and-gas-terms/farmout", label: "Farmout" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/field-run-ticket", label: "Field Run Ticket" }}
	/>
</BaseLayout>
