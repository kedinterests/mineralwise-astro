---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Christmas Tree, Wellhead";
const description = "The system of pipes, valves, gauges and related equipment located on the well at ground level which controls the flow of gas and other petroleum products produced from the well.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Christmas Tree, Wellhead"
		definition="The system of pipes, valves, gauges and related equipment located on the well at ground level which controls the flow of gas and other petroleum products produced from the well."
		path="/resources/oil-and-gas-terms/christmas-tree-wellhead"
		prevTerm={{ href: "/resources/oil-and-gas-terms/check-meter", label: "Check Meter" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/co2", label: "CO2" }}
	/>
</BaseLayout>
