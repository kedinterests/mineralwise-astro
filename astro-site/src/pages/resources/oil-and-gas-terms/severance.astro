---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "Severance";
const description = "The separation of a mineral or royalty interest from other interests in that land.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Severance"
		definition="The separation of a mineral or royalty interest from other interests in that land."
		path="/resources/oil-and-gas-terms/severance"
		prevTerm={{ href: "/resources/oil-and-gas-terms/separator", label: "Separator" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/severance-tax", label: "Severance Tax" }}
	/>
</BaseLayout>
