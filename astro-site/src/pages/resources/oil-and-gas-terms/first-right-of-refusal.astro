---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "First Right of Refusal";
const description = "A provision in leases stating that the operator has the right to top lease before any third party does. (This in effect is an option – the option to review and preempt a transaction by another party).";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="First Right of Refusal"
		definition="A provision in leases stating that the operator has the right to top lease before any third party does. (This in effect is an option – the option to review and preempt a transaction by another party)."
		path="/resources/oil-and-gas-terms/first-right-of-refusal"
		prevTerm={{ href: "/resources/oil-and-gas-terms/first-purchaser", label: "First Purchaser" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/flush-production", label: "Flush Production" }}
	/>
</BaseLayout>
