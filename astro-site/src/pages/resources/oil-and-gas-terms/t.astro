---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Fragment } from 'astro/jsx-runtime';

const title = "Oil and Gas Terms - T | MineralWise";
const description = "Browse MineralWise oil and gas terms beginning with T, with plain-language definitions for mineral and royalty owners.";

const content = "<div>";
---

<BaseLayout title={title} description={description}>
	<article class="content-wrapper">
		<div class="content-section">
			<Fragment set:html={content} />
		</div>
	</article>
</BaseLayout>
