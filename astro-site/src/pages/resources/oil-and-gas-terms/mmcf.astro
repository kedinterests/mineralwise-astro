---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TermPage from '../../../components/TermPage.astro';

const title = "MMcf";
const description = "One million cubic feet; a measurement of gas volume only.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="MMcf"
		definition="One million cubic feet; a measurement of gas volume only."
		path="/resources/oil-and-gas-terms/mmcf"
		prevTerm={{ href: "/resources/oil-and-gas-terms/mmbtu", label: "Mmbtu" }}
		nextTerm={{ href: "/resources/oil-and-gas-terms/natural-gas-liquids-ngl", label: "Natural Gas Liquids Ngl" }}
	/>
</BaseLayout>
