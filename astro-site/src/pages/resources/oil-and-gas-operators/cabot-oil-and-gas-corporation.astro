---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import CompanyPage from '../../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Cabot Oil & Gas Corporation | MineralWise";
const description = "Cabot Oil & Gas Corporation";

const companyDescription = `is a leading North American oil and gas exploration and production company. Cabot stock trades on the NYSE under the symbol COG. Cabot is headquartered in Houston TX. The company’s reserves are located in several basins including the Rocky Mountain and Mid-Continent, and the Gulf Coast (South and East Texas to North Louisiana). As of December 31, 2008 Cabot has approximately 1.9 Tcfe in proved reserves in three core regions: Gulf Coast, West (Rocky Mountains and Mid-Continent) and East. Approximately 97% of reserves and 95% of production are natural gas. Cabot's Charleston WV office oversees its development and production in the Marcellus shale within the Appalachian basin. Cabot Oil and Gas also operates approximately 3,200 miles of pipeline and 4 billion cubic feet of gas storage capacity.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/oil-and-gas-operators/cabot-oil-and-gas-corporation')}>
		<ArticleContent>
			<CompanyPage
				companyName="Cabot Oil & Gas Corporation"
				description={companyDescription}
				logoPath="/images/cabot-oil-gas.jpg"
				contactPhone="800-434-3985"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
