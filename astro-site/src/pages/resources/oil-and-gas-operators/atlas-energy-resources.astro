---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import CompanyPage from '../../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Atlas Energy Resources | MineralWise";
const description = "Atlas Energy Resources";

const companyDescription = `is one of the largest independent natural gas producers in the Eastern United States. Atlas Energy stock and its subsidiaries are traded on the NYSE under the symbols ATN, ATLS, APL, and AHD. Atlas Energy's oil and gas drilling operations focus on the Appalachian Basin and northern Michigan's Antrim Basin. The company operates more than 7,600 oil and gas wells in Pennsylvania, Ohio, Tennessee and New York.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/oil-and-gas-operators/atlas-energy-resources')}>
		<ArticleContent>
			<CompanyPage
				companyName="Atlas Energy Resources"
				description={companyDescription}
				logoPath="/images/atlas-energy-resources.jpg"
				contactPhone="1-877-280-"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
