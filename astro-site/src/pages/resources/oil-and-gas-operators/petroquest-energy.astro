---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import CompanyPage from '../../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "PetroQuest Energy | MineralWise";
const description = "PetroQuest Energy";

const companyDescription = `is an oil and gas exploration and production company based in the United States. PetroQuest stock is publicly traded and listed on the NYSE under the symbol PQ. PetroQuest focuses on the following geographic areas for oil and natural gas production: East Texas, Arkoma Basin, South Louisiana, and the Gulf of Mexico.

PetroQuest is also active in the Woodford and Fayetteville shale plays of the Arkoma Basin. Approximately 75% of PetroQuest's budget is devoted to onshore operations.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/oil-and-gas-operators/petroquest-energy')}>
		<ArticleContent>
			<CompanyPage
				companyName="PetroQuest Energy"
				description={companyDescription}
				logoPath="/images/petroquest.jpg"
				contactPhone="(337) 232-7028"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
