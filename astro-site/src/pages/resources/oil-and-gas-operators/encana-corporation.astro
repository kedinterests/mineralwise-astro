---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import CompanyPage from '../../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Encana Corporation | MineralWise";
const description = "Encana Corporation";

const companyDescription = `is a large oil and gas company focusing on 9 natural gas and 4 oil producing resource plays within North America. Encana stock trades on the NYSE under the symbol ECA. Encana operates heavily in East Texas, the Fort Worth basin in north TX, Wyoming, and the Piceance basin of CO.

The East Texas play targets the Deep Bossier and Cotton Valley zones. This is a tight gas multi-zone play requiring careful application of technology.

The Fort Worth resource play is located in north Texas. Encana has a significant land position containing almost 103,000 net acres and stretches across a 15-county area inclusive of the Barnett Shale.

The Jonah Field is a key resource play located south of Pinedale, Wyoming. During 2008, production averaged 603 net million cubic feet per day.

The Piceance basin is located in northwest Colorado. Encana entered the Piceance basin in 2001 with the acquisition of the Mamm Creek field. The position was further strengthened by acquiring Tom Brown Inc. in 2004.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/oil-and-gas-operators/encana-corporation')}>
		<ArticleContent>
			<CompanyPage
				companyName="Encana Corporation"
				description={companyDescription}
				logoPath="/images/encana.png"
				contactPhone="1-877-386-2200"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
