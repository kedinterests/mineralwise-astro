---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import CompanyPage from '../../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "StatoilHydro | MineralWise";
const description = "StatoilHydro";

const companyDescription = `is an international oil and gas company headquartered in Norway. StatoilHydro stock is traded on the NYSE under the symbol STO. Stat Oil Hydro has a 32.5% interest in the Marcellus Shale in partnership with Chesapeake Energy. This interest, managed from it's Houston office, covers more than 1.8 million acres in the Appalachian region of the United States including interests in Pennsylvania, West Virginia, New York, and Ohio. The company also has interests in fields in Canada, Mexico, Venezuela, Algeria, Libya, and Angola.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/oil-and-gas-operators/statoilhydro')}>
		<ArticleContent>
			<CompanyPage
				companyName="StatoilHydro"
				description={companyDescription}
				logoPath="/images/statoilhydro.png"
				contactPhone="(713) 918-8200"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
