---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import CompanyPage from '../../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Chief Oil & Gas | MineralWise";
const description = "Chief Oil & Gas";

const companyDescription = `is a privately held independent oil and gas company. Chief Oil & Gas drills and operates in the Appalachian Basin, northern Texas, and central Utah. The company also holds over 500,000 acres in the Marcellus Shale region of New York, Pennsylvania, Ohio, Maryland, and West Virginia.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/oil-and-gas-operators/chief-oil-and-gas')}>
		<ArticleContent>
			<CompanyPage
				companyName="Chief Oil & Gas"
				description={companyDescription}
				logoPath="/images/chief-oil-gas.jpg"
				contactPhone="(214) 265-9590"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
