---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import CompanyPage from '../../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Yuma Exploration and Production Co., Inc. | MineralWise";
const description = "Yuma Exploration and Production Co., Inc.";

const companyDescription = `Yuma Exploration is an American oil and gas exploration and production company with headquarters in Houston, Texas. Yuma, founded in 1983, operates primarily in southeast Texas and Louisiana.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/oil-and-gas-operators/yuma-exploration-and-production-co-inc')}>
		<ArticleContent>
			<CompanyPage
				companyName="Yuma Exploration and Production Co., Inc."
				description={companyDescription}
				logoPath="/images/yuma.png"
				contactPhone="(713) 968-7068"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
