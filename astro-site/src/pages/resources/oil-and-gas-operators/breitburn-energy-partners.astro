---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import CompanyPage from '../../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Breitburn Energy Partners | MineralWise";
const description = "Breitburn Energy Partners";

const companyDescription = `is an independent Oil and gas partnership with headquarters in Los Angeles, California. Breitburn is traded on the Nasdaq at BBEP.&nbsp;BreitBurn Energy Partners L.P.&nbsp;is organized as an oil and gas limited partnership, focused on the acquisition, exploitation and development of oil and gas properties for the purpose of generating cash flow.

The company started in 1997 and has oilfield operations in the L.A. Basin, the Wind River and Big Horn Basins in central Wyoming, the Antrim Shale in Michigan, the Sunniland trend in Florida, and the New Albany Shale in Indiana and Kentucky.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/oil-and-gas-operators/breitburn-energy-partners')}>
		<ArticleContent>
			<CompanyPage
				companyName="Breitburn Energy Partners"
				description={companyDescription}
				logoPath="/images/Breitburn-energy-partners.jpg"
				contactPhone="(713) 437-8000"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
