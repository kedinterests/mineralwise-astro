---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageShell from '../../../components/PageShell.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import CompanyPage from '../../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../../data/hierarchy';

const title = "Crimson Resource Management | MineralWise";
const description = "Crimson Resources is a private oil and gas exploration and production company with headquarters in Denver, Colorado. The Company was founded in 1986.";

const companyDescription = `Crimson Resources is a private oil and gas exploration and production company with headquarters in Denver, Colorado. The Company was founded in 1986.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/resources/oil-and-gas-operators/crimson-resource-management')}>
		<ArticleContent>
			<CompanyPage
				companyName="Crimson Resource Management"
				description={companyDescription}
				logoPath="/images/crimson.png"
				contactPhone="(303) 892-9333"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
