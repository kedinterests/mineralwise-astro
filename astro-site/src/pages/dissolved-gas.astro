---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Dissolved Gas";
const description = "Commonly referred to as solution gas.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Dissolved Gas"
		definition="Commonly referred to as solution gas."
		path="/dissolved-gas"
		prevTerm={{ href: "/discovery-well", label: "Discovery Well" }}
		nextTerm={{ href: "/division-order", label: "Division Order" }}
	/>
</BaseLayout>
