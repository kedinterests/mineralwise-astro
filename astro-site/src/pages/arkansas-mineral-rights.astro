---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Arkansas Mineral Rights | MineralWise";
const metaDescription = "Arkansas Mineral Rights produce the most economic impact to the state through the production of natural gas minerals. In recent years, the Fayetteville Shale has become a major play in the Arkansas mineral rights arena.";

const stateName = "Arkansas";
const stateAbbr = "AR";
const description = "Arkansas Mineral Rights produce the most economic impact to the state through the production of natural gas minerals. In recent years, the Fayetteville Shale has become a major play in the Arkansas mineral rights arena. Because of the advances in horizontal drilling technology and hydraulic fracturing, Arkansas mineral rights covering the Fayetville Shale are now economically viable.";

const stats = [];
const majorFields = [
	"Alta-Jones Well",
	"Anadarko Well",
	"Arklan Well",
	"Beavers Well",
	"Dismang Well",
	"Gaither Well",
	"Jameson Well",
	"Mulliniks Well",
	"Reyes Salinas Well",
	"Whisehunt Well"
];
const companies = [
	"Chesapeake",
	"Hallwood Petroleum",
	"KCS Resources",
	"One TEC Operating",
	"Petrohawk Operating",
	"SEECO",
	"XTO Energy"
];
const regulatoryLink = {
	text: "http://www.aogc.state.ar.us/",
	href: "http://www.aogc.state.ar.us/",
	external: true
};
const additionalReading = [
	{
		text: "Oil & Gas 101",
		href: "/oil-and-gas-basics-for-mineral-owners",
		external: false
	},
	{
		text: "Fayetteville Shale Arkansas",
		href: "/directory/shale-plays/fayetteville-shale-arkansas",
		external: false
	}
];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/arkansas-mineral-rights')}>
		<ArticleContent>
			<StatePage
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
				majorFields={majorFields}
				companies={companies}
				regulatoryLink={regulatoryLink}
				additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
