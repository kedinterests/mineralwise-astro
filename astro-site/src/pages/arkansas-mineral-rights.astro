---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Arkansas Mineral Rights | MineralWise";
const metaDescription = "Arkansas Mineral Rights produce the most economic impact to the state through the production of natural gas minerals. In recent years, the Fayetteville Shale ha";

const stateName = "Arkansas";
const stateAbbr = "AR";
const description = "Arkansas Mineral Rights produce the most economic impact to the state through the production of natural gas minerals. In recent years, the Fayetteville Shale ha";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
