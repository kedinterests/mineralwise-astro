---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import { getBreadcrumbs, pageHierarchy } from '../data/hierarchy';
import { readFileSync } from 'fs';
import { join } from 'path';
import { fileURLToPath } from 'url';

const title = "Top Oil and Gas Companies | Comprehensive List of Leading Energy Providers";
const description = "Discover a comprehensive list of leading oil and gas companies, including Chevron, BP, ConocoPhillips, Chesapeake Energy, and more. Explore key players in the energy industry driving innovation and global fuel solutions.";

// Get all companies from hierarchy
const companies = Object.entries(pageHierarchy)
	.filter(([path, node]) => node.parent === '/oil-gas-operators')
	.map(([path, node]) => ({
		path,
		name: node.label,
		slug: path.replace(/^\//, '')
	}));

// Extract logo paths from company pages
const __filename = fileURLToPath(import.meta.url);
// __filename is the full path to this file, so __dirname is the pages directory
const pagesDir = join(__filename, '..');

interface Company {
	path: string;
	name: string;
	logoPath: string | null;
}

const companyData: Company[] = [];

// Try to extract logo paths, but always include all companies
for (const company of companies) {
	let logoPath: string | null = null;
	
	try {
		const filePath = join(pagesDir, `${company.slug}.astro`);
		// Safety check - only read files in our pages directory
		if (filePath.includes('src/pages') && !filePath.includes('node_modules')) {
			const content = readFileSync(filePath, 'utf-8');
			const logoMatch = content.match(/logoPath="([^"]+)"/);
			if (logoMatch) {
				logoPath = logoMatch[1];
			}
		}
	} catch (err) {
		// File might not exist or be unreadable, continue without logo
	}
	
	// Always add the company, with or without logo
	companyData.push({
		path: company.path,
		name: company.name,
		logoPath
	});
}

// Sort alphabetically by name
companyData.sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-gas-operators')}>
		<ArticleContent>
			<div class="operators-page">
				<h1>Oil & Gas Operators</h1>
				<p class="intro">Browse our comprehensive directory of leading oil and gas companies operating across the United States.</p>
				
				{companyData.length > 0 ? (
					<div class="companies-grid">
						{companyData.map((company) => (
							<a href={company.path} class="company-card">
								<div class="company-logo-wrapper">
									{company.logoPath ? (
										<img 
											src={company.logoPath} 
											alt={`${company.name} logo`}
											loading="lazy"
										/>
									) : (
										<div class="no-logo">{company.name.charAt(0)}</div>
									)}
								</div>
								<div class="company-name">{company.name}</div>
							</a>
						))}
					</div>
				) : (
					<p>Loading companies...</p>
				)}
			</div>
		</ArticleContent>
	</PageShell>
</BaseLayout>

<style>
	.operators-page {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}

	.operators-page h1 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}

	.intro {
		font-size: 1.125rem;
		color: #666;
		margin-bottom: 2.5rem;
		line-height: 1.6;
	}

	.companies-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 2rem;
		margin-top: 2rem;
	}

	@media (min-width: 768px) {
		.companies-grid {
			grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
			gap: 2.5rem;
		}
	}

	@media (min-width: 1024px) {
		.companies-grid {
			grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
			gap: 3rem;
		}
	}

	.company-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-decoration: none;
		color: inherit;
		padding: 1.5rem;
		border-radius: 12px;
		background: #f9fafb;
		border: 2px solid transparent;
		transition: all 0.3s ease;
		cursor: pointer;
		text-align: center;
	}

	.company-card:hover {
		border-color: #3b82f6;
		background: white;
		transform: translateY(-4px);
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
	}

	.company-logo-wrapper {
		width: 100%;
		height: 140px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 1rem;
		background: white;
		border-radius: 8px;
		padding: 1rem;
		overflow: hidden;
	}

	.company-logo-wrapper img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		transition: transform 0.3s ease;
	}

	.company-card:hover .company-logo-wrapper img {
		transform: scale(1.05);
	}

	.no-logo {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2rem;
		font-weight: 700;
	}

	.company-name {
		font-size: 1rem;
		font-weight: 600;
		color: #1a1a1a;
		line-height: 1.4;
		word-wrap: break-word;
		transition: color 0.3s ease;
	}

	.company-card:hover .company-name {
		color: #3b82f6;
	}

	@media (max-width: 640px) {
		.operators-page {
			padding: 1.5rem;
		}

		.operators-page h1 {
			font-size: 2rem;
		}

		.companies-grid {
			grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
			gap: 1.5rem;
		}

		.company-logo-wrapper {
			height: 120px;
		}
	}
</style>
