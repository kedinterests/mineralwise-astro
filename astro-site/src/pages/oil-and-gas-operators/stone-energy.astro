---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Stone Energy | MineralWise";
const description = "Stone Energy";

const companyDescription = `is an oil and gas exploration and production company with headquarters in Lafayette, Louisiana. The Company's primary operations are in West Virginia and Texas. Stone Energy's stock can be found listed on the NYSE as SGY.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/stone-energy')}>
		<ArticleContent>
			<CompanyPage
				companyName="Stone Energy"
				description={companyDescription}
				logoPath="/images/stone-energy.jpg"
				contactPhone="(337) 237-0410"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
