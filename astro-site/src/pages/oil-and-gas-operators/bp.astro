---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "BP | MineralWise";
const description = "BP is a multinational oil company with headquarters in London, United Kingdom. BP stock is listed on the NYSE under the symbol BP. BP was founded in 1909 as the Anglo-Persian Oil Company by William Knox D'Arcy.&nbsp;BP currently has exploration and production undertakings in 30 countries, and operates 16 refineries with a combined output of 2.3 million barrels of oil per day.";

const companyDescription = `is a multinational oil company with headquarters in London, United Kingdom. BP stock is listed on the NYSE under the symbol BP. BP was founded in 1909 as the Anglo-Persian Oil Company by William Knox D'Arcy.&nbsp;BP currently has exploration and production undertakings in 30 countries, and operates 16 refineries with a combined output of 2.3 million barrels of oil per day.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/bp')}>
		<ArticleContent>
			<CompanyPage
				companyName="BP"
				description={companyDescription}
				logoPath="/images/BP.jpg"
				contactPhone="(800) 732-6626"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
