---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "SandRidge Energy, Inc. | MineralWise";
const description = "SandRidge Energy, Inc.";

const companyDescription = `SandRidge Energy is an oil and gas production and exploration company with headquarters in Oklahoma City, Oklahoma. The Company operates in West Texas, the Mid-Continent, the Permian Basin the Gulf Coast, and the Cotton Valley Trend East Texas. SandRidge Energy is listed on the NYSE as SD.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/sandridge-energy-inc')}>
		<ArticleContent>
			<CompanyPage
				companyName="SandRidge Energy, Inc."
				description={companyDescription}
				logoPath="/images/sandridge.png"
				contactPhone="(405) 429-5500"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
