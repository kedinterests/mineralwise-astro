---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Williams Energy | MineralWise";
const description = "Williams Energy";

const companyDescription = `is a natural gas exploration and production company with headquarters in Tulsa, Oklahoma. The Company's primary areas of operation include the Piceance, Paradox, and San Juan Basins; the Arkoma Basin; the Marcellus and Barnett shales. Williams Energy's stock is listed on the NYSE as WMB.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/williams-energy')}>
		<ArticleContent>
			<CompanyPage
				companyName="Williams Energy"
				description={companyDescription}
				logoPath="/images/williams-energy.png"
				contactPhone="(800) 945-5426"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
