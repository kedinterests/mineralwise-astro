---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Swift Energy Operating, L.L.C. | MineralWise";
const description = "Swift Energy Operating, L.L.C.";

const companyDescription = `Swift Energy is a American oil and gas exploration and production company with headquarters in Houston, Texas. The Company was founded in 1979 by Aubrey Swift. Swift Energy's stock is listed on the XNYS as SFY. The Company's primary areas of operation are in South Texas,&nbsp;Southeast Louisiana, South Louisiana, and Central Louisiana/East Texas.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/swift-energy-operating-llc')}>
		<ArticleContent>
			<CompanyPage
				companyName="Swift Energy Operating, L.L.C."
				description={companyDescription}
				logoPath="/images/swift-energy.jpg"
				contactPhone="(281) 874-2700"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
