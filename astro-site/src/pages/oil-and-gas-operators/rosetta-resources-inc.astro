---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Rosetta Resources, Inc. | MineralWise";
const description = "Rosetta Resources, Inc.";

const companyDescription = `Rosetta Resources is an oil and gas exploration and production company with headquarters in Houston, Texas. The Company's primary areas of operation are in South Texas, the San Juan Basin of New Mexico, the DJ Basin of Colorado, the Sacramento Basin of California, and the Alberta Basin of Montana. Rosetta's stock is listed on the NASDAQ as ROSE.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/rosetta-resources-inc')}>
		<ArticleContent>
			<CompanyPage
				companyName="Rosetta Resources, Inc."
				description={companyDescription}
				logoPath="/images/rosetta-resources.png"
				contactPhone="1-800-526-2112"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
