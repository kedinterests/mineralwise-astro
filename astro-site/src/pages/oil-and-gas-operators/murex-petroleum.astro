---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Murex Petroleum | MineralWise";
const description = "Murex Petroleum";

const companyDescription = `is an oil and gas exploration and production company based in Houston Texas. Murex Petroleum operates in North Dakota, South Dakota, and the Rocky Mountain Region. Murex Petroleum also has non operating working interests in North Dakota, Montana, and Oklahoma.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/murex-petroleum')}>
		<ArticleContent>
			<CompanyPage
				companyName="Murex Petroleum"
				description={companyDescription}
				logoPath="/images/murex.png"
				contactPhone="(281) 590-3313"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
