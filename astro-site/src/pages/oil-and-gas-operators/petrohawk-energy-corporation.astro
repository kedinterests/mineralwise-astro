---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Petrohawk Energy Corporation | MineralWise";
const description = "Petrohawk Energy Corporation";

const companyDescription = `is engaged in the exploration, development, and production of oil and natural gas. Petrohawk stock is traded on the NYSE under the symbol HK. As of the end of December 2008, Petrohawk Energy had proved reserves of approximately 1.4 TCFe (trillion cubic feet equivalent). The Company’s proved reserves are 94% gas. Of this Petrohawk gas, 56% is developed.

Production as of late 2009 is approximately 483 Mmcfe per day. Petrohawk focuses on drilling and developing properties within its core operating areas in: North Louisiana (Haynesville shale), East Texas (Haynesville shale), Arkansas (Fayetteville shale), South Texas (Eagle Ford shale), and in the Anadarko basin, Arkoma basin and Permian basin regions.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/petrohawk-energy-corporation')}>
		<ArticleContent>
			<CompanyPage
				companyName="Petrohawk Energy Corporation"
				description={companyDescription}
				logoPath="/images/petrohawk.png"
				contactPhone="(832) 204-2799"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
