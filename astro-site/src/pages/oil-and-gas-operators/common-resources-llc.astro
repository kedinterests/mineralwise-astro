---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Common Resources, L.L.C. | MineralWise";
const description = "Common Resources, L.L.C.";

const companyDescription = `Common Resources in an oil and gas exploration and production company with headquarters in The Woodlands, Texas. The Company's primary areas of operation include West Texas, The Gulf Coast, and the Mid-continent region.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/common-resources-llc')}>
		<ArticleContent>
			<CompanyPage
				companyName="Common Resources, L.L.C."
				description={companyDescription}
				logoPath="/images/common-resources.png"
				contactPhone="(281) 363-9200"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
