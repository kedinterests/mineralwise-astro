---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "EnerGulf Resources Inc | MineralWise";
const description = "EnerGulf Resources Inc";

const companyDescription = `EnerGulf Resources Inc. is a Houston, Texas-Vancouver, BC, based oil and gas exploration company. EnerGulf stock trades on the Toronto Venture Exchange (TSX) under the symbol ENG and the Frankfurt Exchange under the symbol EKS.

It also has offices in Kinshasa, Democratic Republic of Congo. Its wholly owned subsidiaries include the following: EnerGulf Corporation (Texas), EnerGulf Africa Ltd., EnerGulf Nambia Ltd., EnerGulf DRC, Ltd. and EnerGulf Congo, SARL.

EnerGulf Resources is a publicly traded international oil and gas exploration and production company focused on maximizing shareholder value by targeting high impact opportunities in the world most prospective hydrocarbon regions.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/energulf-resources-inc')}>
		<ArticleContent>
			<CompanyPage
				companyName="EnerGulf Resources Inc"
				description={companyDescription}
				logoPath="/images/energulf.jpg"
				contactPhone="(713) 942-6559"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
