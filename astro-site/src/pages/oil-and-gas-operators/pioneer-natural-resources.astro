---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Pioneer Natural Resources | MineralWise";
const description = "Pioneer Natural Resources";

const companyDescription = `is a large independent oil and gas exploration and production company. Pioneer stock trades on the NYSE under the symbol PXD. Pioneer Natural produces oil and gas in multiple operating areas including: the West Texas Spraberry, the South Texas Edwards and Eagle Ford shale, the Barnett shale of North Texas, Alaska, as well as international locations. Pioneer is also pursuing several emerging resource plays in the Lower 48. Pioneer has international operations in Tunisia and South Africa.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/pioneer-natural-resources')}>
		<ArticleContent>
			<CompanyPage
				companyName="Pioneer Natural Resources"
				description={companyDescription}
				logoPath="/images/pioneer-natural.png"
				contactPhone="(972) 444-9001"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
