---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Newfield Exploration Company | MineralWise";
const description = "Newfield Exploration Company";

const companyDescription = `Newfield Exploration Company is an independent crude oil and natural gas exploration and production company headquartered in Houston, Texas. Newfield Exploration stock is listed on the NYSE under the symbol NFX. Joe B. Foster, former Chairman of Tenneco Oil Company, founded Newfield in 1988. The Company was capitalized with $9 million by an investment group led by Charles Duncan, the University of Texas endowment funds and the founding employees. The areas of operations include the Anadarko and Arkoma Basins of the Mid-Continent, the Rocky Mountains, onshore Texas and the Gulf of Mexico. The international areas of operation include offshore Malaysia and China.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/newfield-exploration-company')}>
		<ArticleContent>
			<CompanyPage
				companyName="Newfield Exploration Company"
				description={companyDescription}
				logoPath="/images/newfield-exploration.png"
				contactPhone="1-800-318-7850"
				showProductionVerification={true}
				showCashPayment={true}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
