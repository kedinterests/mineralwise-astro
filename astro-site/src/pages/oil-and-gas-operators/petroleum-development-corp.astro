---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Petroleum Development Corp. | MineralWise";
const description = "Petroleum Development Corp.";

const companyDescription = `is an independent oil and gas exploration and production company with headquarters in Denver, Colorado. PDC's stock is listed on the NASDAQ-GS as PETD. The Company's operations are primarily in the Appalachian Basin and Rocky Mountain regions. Founded in 1969, over 80% of the PDC Energy's production comes from natural gas. The Company has proved reserves of 720 Bcfe.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/petroleum-development-corp')}>
		<ArticleContent>
			<CompanyPage
				companyName="Petroleum Development Corp."
				description={companyDescription}
				logoPath="/images/petroleum.jpg"
				contactPhone="(303) 860-5800"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
