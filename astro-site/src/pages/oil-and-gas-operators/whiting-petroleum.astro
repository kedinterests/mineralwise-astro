---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Whiting Petroleum | MineralWise";
const description = "Whiting Petroleum";

const companyDescription = `is an oil and gas exploration and production company based in Denver Colorado. Whiting Petroleum stock is listed on the NYSE under the symbol WLL. Whiting Petroleum focuses its exploration and production activities on the following areas: the Permian Basin of west Texas and New Mexico, the Rocky Mountains, the Mid-Continent area, and the Gulf Coast, and Michigan Basins.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/whiting-petroleum')}>
		<ArticleContent>
			<CompanyPage
				companyName="Whiting Petroleum"
				description={companyDescription}
				logoPath="/images/whiting-petroleum.png"
				contactPhone="(303) 837-1661"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
