---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import CompanyPage from '../../components/CompanyPage.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Cimarex Energy | MineralWise";
const description = "Cimarex Energy";

const companyDescription = `is an oil and gas exploration and production company based in Denver Colorado. Cimarex stock is listed on the NYSE under the symbol XEC. Cimarex focuses its exploration and production activities in the Permian Basin, Gulf Coast, and Mid-Continent regions. At the end of 2008 Cimarex Energy had total reserves equaling 1.34 trillion cubic feet, 80% natural gas, of which 81% is developed.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/oil-and-gas-operators/cimarex-energy')}>
		<ArticleContent>
			<CompanyPage
				companyName="Cimarex Energy"
				description={companyDescription}
				logoPath="/images/cimarex-energy.jpg"
				contactPhone="(918) 295-1757"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
