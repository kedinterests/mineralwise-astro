---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/bossier-shale-texas')}>
		<ArticleContent>
			<ShalePlayPage
				shaleName={shaleName}
				state={state}
				description={descriptionText}
				companies={companies}
				geology={geology}
				counties={counties}additionalReading={additionalReading}
