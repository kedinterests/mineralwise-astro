---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import { getBreadcrumbs, pageHierarchy } from '../data/hierarchy';

const title = "Comprehensive Guide to U.S. Shale Plays: Locations, Resources, and Information";
const description = "Explore a detailed overview of major U.S. shale plays, including Bakken, Eagle Ford, Marcellus, Utica, and more. Learn about their locations, resources, and energy potential across states like Texas, North Dakota, Pennsylvania, and beyond. Stay informed with expert insights.";

// Get all shale plays from hierarchy
const shalePlays = Object.entries(pageHierarchy)
	.filter(([path, node]) => node.parent === '/shale-plays')
	.map(([path, node]) => ({
		path,
		name: node.label
	}));

// Sort alphabetically by name
shalePlays.sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/shale-plays')}>
		<ArticleContent>
			<div class="shale-plays-page">
				<h1>Shale Plays</h1>
				<p class="intro">Explore our comprehensive directory of major U.S. shale plays, including detailed information about their locations, geology, companies, and energy potential.</p>
				
				{shalePlays.length > 0 ? (
					<div class="shale-plays-grid">
						{shalePlays.map((shale) => (
							<a href={shale.path} class="shale-card">
								<div class="shale-name">{shale.name}</div>
							</a>
						))}
					</div>
				) : (
					<p>Loading shale plays...</p>
				)}
			</div>
		</ArticleContent>
	</PageShell>
</BaseLayout>

<style>
	.shale-plays-page {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}

	.shale-plays-page h1 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}

	.intro {
		font-size: 1.125rem;
		color: #666;
		margin-bottom: 2.5rem;
		line-height: 1.6;
	}

	.shale-plays-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: 1rem 1.5rem;
		margin-top: 2rem;
	}

	@media (min-width: 768px) {
		.shale-plays-grid {
			grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
			gap: 1.25rem 2rem;
		}
	}

	@media (min-width: 1024px) {
		.shale-plays-grid {
			grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
			gap: 1.5rem 2.5rem;
		}
	}

	.shale-card {
		display: flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		color: inherit;
		padding: 1.25rem 1.75rem;
		border-radius: 12px;
		background: #f9fafb;
		border: 2px solid transparent;
		transition: all 0.3s ease;
		cursor: pointer;
		text-align: center;
		min-height: 65px;
	}

	.shale-card:hover {
		border-color: #0ea5e9;
		background: white;
		transform: translateY(-4px);
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
	}

	.shale-name {
		font-size: 1.125rem;
		font-weight: 600;
		color: #1a1a1a;
		line-height: 1.4;
		word-wrap: break-word;
		transition: color 0.3s ease;
	}

	.shale-card:hover .shale-name {
		color: #0ea5e9;
	}

	@media (max-width: 640px) {
		.shale-plays-page {
			padding: 1.5rem;
		}

		.shale-plays-page h1 {
			font-size: 2rem;
		}

		.shale-plays-grid {
			grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
			gap: 0.875rem 1.25rem;
		}

		.shale-card {
			padding: 1rem 1.25rem;
			min-height: 60px;
		}

		.shale-name {
			font-size: 1rem;
		}
	}
</style>
