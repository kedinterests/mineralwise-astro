---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Separator";
const description = "Apparatus that separates oil, gases, and water contained in the effluent from a production well.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Separator"
		definition="Apparatus that separates oil, gases, and water contained in the effluent from a production well."
		path="/separator"
		prevTerm={{ href: "/sedimentary-rock", label: "Sedimentary Rock" }}
		nextTerm={{ href: "/severance", label: "Severance" }}
	/>
</BaseLayout>
