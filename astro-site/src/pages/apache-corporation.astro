---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Apache Corporation | MineralWise";
const description = "Apache Corporation";

const companyDescription = `is an American independent oil and gas corporation. Apache stock is listed on the NYSE under the symbol APA. It is headquartered in Suite 100 at 1 Post Oak Central in the Uptown district of Houston, Texas. Apache Oil Corporation is founded in 1954 in Minneapolis, Minnesota, by Truman Anderson, Raymond Plank and Charles Arnao. The company reserves are roughly half oil and half natural gas. The company's exploration and production is concentrated in the United States, Canada, Egypt, Australia, North Sea and Argentina.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/apache-corporation')}>
		<ArticleContent>
			<CompanyPage
				companyName="Apache Corporation"
				description={companyDescription}
				logoPath="/images/apache.png"
				contactPhone="(800) 272-2434"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
