---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Kansas Mineral Rights | MineralWise";
const metaDescription = "Kansas mineral rights owners benefit from both oil and gas production. Natural gas mineral rights were first exploited in Kansas in 1922 in Seward county in the";

const stateName = "Kansas";
