---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "South Dakota Mineral Rights | MineralWise";
const metaDescription = "South Dakota Mineral Rights and their influence goes back to the late 1800's when natural gas was first discovered there. Crude oil was not discovered until 195";

const stateName = "South Dakota";
const stateAbbr = "SD";
const description = "South Dakota Mineral Rights and their influence goes back to the late 1800's when natural gas was first discovered there. Crude oil was not discovered until 195";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/south-dakota-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
