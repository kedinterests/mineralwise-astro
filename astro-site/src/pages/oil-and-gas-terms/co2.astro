---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "CO2";
const description = "Abbreviation for carbon dioxide.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="CO2"
		definition="Abbreviation for carbon dioxide."
		path="/oil-and-gas-terms/co2"
		prevTerm={{ href: "/oil-and-gas-terms/christmas-tree-wellhead", label: "Christmas Tree, Wellhead" }}
		nextTerm={{ href: "/oil-and-gas-terms/commercial-well-aka-producing-well", label: "Commercial Well (aka Producing Well)" }}
	/>
</BaseLayout>
