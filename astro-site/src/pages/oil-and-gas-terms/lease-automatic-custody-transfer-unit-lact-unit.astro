---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Lease Automatic Custody Transfer Unit, LACT Unit";
const description = "A system providing for the automatic measurement, sampling, and transfer of oil from the lease location into a pipeline.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Lease Automatic Custody Transfer Unit, LACT Unit"
		definition="A system providing for the automatic measurement, sampling, and transfer of oil from the lease location into a pipeline."
		path="/oil-and-gas-terms/lease-automatic-custody-transfer-unit-lact-unit"
		prevTerm={{ href: "/oil-and-gas-terms/lease", label: "Lease" }}
		nextTerm={{ href: "/oil-and-gas-terms/lease-bonus", label: "Lease Bonus" }}
	/>
</BaseLayout>
