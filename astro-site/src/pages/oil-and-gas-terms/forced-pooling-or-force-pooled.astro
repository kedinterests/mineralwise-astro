	<TermPage
		term="Forced Pooling or Force Pooled"
		definition="The act of being forced by state law into participation in an oil and/or gas producing unit. Often referred to as Force Pooled."
		path="/oil-and-gas-terms/forced-pooling-or-force-pooled"
		prevTerm={{ href: "/oil-and-gas-terms/flush-production", label: "Flush Production" }}
		nextTerm={{ href: "/oil-and-gas-terms/formation", label: "Formation" }}
	/>
</BaseLayout>
