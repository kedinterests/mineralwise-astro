---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Developmental Well";
const description = "A well drilled to a known producing formation in an existing oil field.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Developmental Well"
		definition="A well drilled to a known producing formation in an existing oil field."
		path="/oil-and-gas-terms/developmental-well"
		prevTerm={{ href: "/oil-and-gas-terms/depletion-allowance", label: "Depletion Allowance" }}
		nextTerm={{ href: "/oil-and-gas-terms/direct-participation", label: "Direct Participation" }}
	/>
</BaseLayout>
