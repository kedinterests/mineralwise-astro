---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Curative";
const description = "The process that clears a title or straightens out any defects in the title chain.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Curative"
		definition="The process that clears a title or straightens out any defects in the title chain."
		path="/oil-and-gas-terms/curative"
		prevTerm={{ href: "/oil-and-gas-terms/cubic-foot-of-gas-standard-cubic-foot-of-gas", label: "Cubic Foot of Gas, Standard Cubic Foot of Gas" }}
		nextTerm={{ href: "/oil-and-gas-terms/d-and-a", label: "D&amp;A" }}
	/>
</BaseLayout>
