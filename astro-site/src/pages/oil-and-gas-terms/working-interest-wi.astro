---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Working Interest, WI";
const description = "Interest(s) in a mineral property.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Working Interest, WI"
		definition="Interest(s) in a mineral property."
		path="/oil-and-gas-terms/working-interest-wi"
		prevTerm={{ href: "/oil-and-gas-terms/wildcat", label: "Wildcat" }}
		nextTerm={{ href: "/oil-and-gas-terms/workover", label: "Workover" }}
	/>
</BaseLayout>
