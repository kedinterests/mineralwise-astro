---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Depletion";
const description = "With respect to oil and gas production, the process by which a producing reservoir is depleted (or produced) of it’s hydrocarbon.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Depletion"
		definition="With respect to oil and gas production, the process by which a producing reservoir is depleted (or produced) of it’s hydrocarbon."
		path="/oil-and-gas-terms/depletion"
		prevTerm={{ href: "/oil-and-gas-terms/delay-rental", label: "Delay Rental" }}
		nextTerm={{ href: "/oil-and-gas-terms/depletion-allowance", label: "Depletion Allowance" }}
	/>
</BaseLayout>
