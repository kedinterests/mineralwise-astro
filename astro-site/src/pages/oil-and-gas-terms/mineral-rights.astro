---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Mineral Rights";
const description = "The ownership of the minerals on or under the surface, with the owner having the right to capture or recover and the right to delegate owner rights to another party to recover mineral by negotiating a lease agreement.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Mineral Rights"
		definition="The ownership of the minerals on or under the surface, with the owner having the right to capture or recover and the right to delegate owner rights to another party to recover mineral by negotiating a lease agreement."
		path="/oil-and-gas-terms/mineral-rights"
		prevTerm={{ href: "/oil-and-gas-terms/mineral-owner", label: "Mineral Owner" }}
		nextTerm={{ href: "/oil-and-gas-terms/mineral-title", label: "Mineral Title" }}
	/>
</BaseLayout>
