---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Pumper, Lease Operator, Gauger";
const description = "An employee of an Operator who is responsible for maintaining and reporting the daily production.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Pumper, Lease Operator, Gauger"
		definition="An employee of an Operator who is responsible for maintaining and reporting the daily production."
		path="/oil-and-gas-terms/pumper-lease-operator-gauger"
		prevTerm={{ href: "/oil-and-gas-terms/pugh-clause", label: "Pugh Clause" }}
		nextTerm={{ href: "/oil-and-gas-terms/qualified-intermediary", label: "Qualified Intermediary" }}
	/>
</BaseLayout>
