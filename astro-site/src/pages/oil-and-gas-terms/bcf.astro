		prevTerm={{ href: "/oil-and-gas-terms/basic-sediment-and-water-bs-and-w", label: "Basic Sediment and Water, BS&amp;W" }}
		nextTerm={{ href: "/oil-and-gas-terms/blowout-preventor-bp", label: "Blowout Preventor, BP" }}
	/>
</BaseLayout>
