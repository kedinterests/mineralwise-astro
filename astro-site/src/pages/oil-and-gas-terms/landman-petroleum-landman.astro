---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Landman, Petroleum Landman";
const description = "A person, male or female, whose role is that of contacting mineral rights owners regarding the leasing of their mineral interests for oil and gas production. Landmen often are independent contractors.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Landman, Petroleum Landman"
		definition="A person, male or female, whose role is that of contacting mineral rights owners regarding the leasing of their mineral interests for oil and gas production. Landmen often are independent contractors."
		path="/oil-and-gas-terms/landman-petroleum-landman"
		prevTerm={{ href: "/oil-and-gas-terms/land-department", label: "Land Department" }}
		nextTerm={{ href: "/oil-and-gas-terms/lease", label: "Lease" }}
	/>
</BaseLayout>
