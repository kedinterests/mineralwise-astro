---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Pounds Per Square Inch, PSI";
const description = "An English system of measure of the amount of pressure on an area that is 1 inch square.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Pounds Per Square Inch, PSI"
		definition="An English system of measure of the amount of pressure on an area that is 1 inch square."
		path="/oil-and-gas-terms/pounds-per-square-inch-psi"
		prevTerm={{ href: "/oil-and-gas-terms/possible-reserves", label: "Possible Reserves" }}
		nextTerm={{ href: "/oil-and-gas-terms/primary-term", label: "Primary Term" }}
	/>
</BaseLayout>
