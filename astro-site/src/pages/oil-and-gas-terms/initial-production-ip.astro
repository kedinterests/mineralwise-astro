---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Initial Production, IP";
const description = "The rate of initial flow from a well.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Initial Production, IP"
		definition="The rate of initial flow from a well."
		path="/oil-and-gas-terms/initial-production-ip"
		prevTerm={{ href: "/oil-and-gas-terms/infill-drilling", label: "Infill Drilling" }}
		nextTerm={{ href: "/oil-and-gas-terms/injection-well", label: "Injection Well" }}
	/>
</BaseLayout>
