---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Sedimentary Rock";
const description = "Rock made up of aggregated sediments.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Sedimentary Rock"
		definition="Rock made up of aggregated sediments."
		path="/oil-and-gas-terms/sedimentary-rock"
		prevTerm={{ href: "/oil-and-gas-terms/secondary-recovery", label: "Secondary Recovery" }}
		nextTerm={{ href: "/oil-and-gas-terms/separator", label: "Separator" }}
	/>
</BaseLayout>
