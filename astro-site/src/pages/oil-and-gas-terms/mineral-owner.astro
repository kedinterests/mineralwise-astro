---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Mineral Owner";
const description = "Owner of the rights and interests in a mineral estate (where interests in a landed estate have been severed) along with the right to execute a lease on the same.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Mineral Owner"
		definition="Owner of the rights and interests in a mineral estate (where interests in a landed estate have been severed) along with the right to execute a lease on the same."
		path="/oil-and-gas-terms/mineral-owner"
		prevTerm={{ href: "/oil-and-gas-terms/mineral-lease", label: "Mineral Lease" }}
		nextTerm={{ href: "/oil-and-gas-terms/mineral-rights", label: "Mineral Rights" }}
	/>
</BaseLayout>
