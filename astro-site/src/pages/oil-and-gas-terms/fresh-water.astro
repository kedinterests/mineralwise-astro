---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Fresh Water";
const description = "With respect to oil and gas production, fresh water which is found at shallower depths, is differentiated from salt water or brine which is usually found along with hydrocarbons. Fresh water or water of certain purities is needed for hydraulic fracturing.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Fresh Water"
		definition="With respect to oil and gas production, fresh water which is found at shallower depths, is differentiated from salt water or brine which is usually found along with hydrocarbons. Fresh water or water of certain purities is needed for hydraulic fracturing."
		path="/oil-and-gas-terms/fresh-water"
		prevTerm={{ href: "/oil-and-gas-terms/free-water-knockout", label: "Free Water Knockout" }}
		nextTerm={{ href: "/oil-and-gas-terms/fuel-and-shrinkage", label: "Fuel and Shrinkage" }}
	/>
</BaseLayout>
