---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Perforations";
const description = "Holes within and through casing and cement into the productive formation.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Perforations"
		definition="Holes within and through casing and cement into the productive formation."
		path="/oil-and-gas-terms/perforations"
		prevTerm={{ href: "/oil-and-gas-terms/percentage-depletion", label: "Percentage Depletion" }}
		nextTerm={{ href: "/oil-and-gas-terms/permeability", label: "Permeability" }}
	/>
</BaseLayout>
