---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Mcf";
const description = "One thousand cubic feet of natural gas measured at standard pressure and temperature conditions.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Mcf"
		definition="One thousand cubic feet of natural gas measured at standard pressure and temperature conditions."
		path="/oil-and-gas-terms/mcf"
		prevTerm={{ href: "/oil-and-gas-terms/lessor", label: "Lessor" }}
		nextTerm={{ href: "/oil-and-gas-terms/mcfe", label: "Mcfe" }}
	/>
</BaseLayout>
