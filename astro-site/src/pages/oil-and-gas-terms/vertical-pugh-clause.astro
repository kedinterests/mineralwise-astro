---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Vertical Pugh Clause";
const description = "Limits an operators ability to hold all depths of minerals with producing formations.&amp;nbsp;Deals with depths of the minerals instead of areal extent addressed in a traditional Pugh Clause.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Vertical Pugh Clause"
		definition="Limits an operators ability to hold all depths of minerals with producing formations.&nbsp;Deals with depths of the minerals instead of areal extent addressed in a traditional Pugh Clause."
		path="/oil-and-gas-terms/vertical-pugh-clause"
		prevTerm={{ href: "/oil-and-gas-terms/upstream", label: "Upstream" }}
		nextTerm={{ href: "/oil-and-gas-terms/viscosity", label: "Viscosity" }}
	/>
</BaseLayout>
