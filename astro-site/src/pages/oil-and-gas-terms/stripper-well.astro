---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Stripper Well";
const description = "A mature well which is at or toward the end of its economic life.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Stripper Well"
		definition="A mature well which is at or toward the end of its economic life."
		path="/oil-and-gas-terms/stripper-well"
		prevTerm={{ href: "/oil-and-gas-terms/spot-market", label: "Spot Market" }}
		nextTerm={{ href: "/oil-and-gas-terms/structural-trap", label: "Structural Trap" }}
	/>
</BaseLayout>
