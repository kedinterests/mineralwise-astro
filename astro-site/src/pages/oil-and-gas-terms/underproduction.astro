---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Underproduction";
const description = "Production that is less than the allowable assigned to a proration unit.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Underproduction"
		definition="Production that is less than the allowable assigned to a proration unit."
		path="/oil-and-gas-terms/underproduction"
		prevTerm={{ href: "/oil-and-gas-terms/tubing", label: "Tubing" }}
		nextTerm={{ href: "/oil-and-gas-terms/undeveloped-acreage", label: "Undeveloped Acreage" }}
	/>
</BaseLayout>
