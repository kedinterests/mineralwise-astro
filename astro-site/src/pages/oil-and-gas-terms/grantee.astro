---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Grantee";
const description = "The person receiving lands, minerals, etc.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Grantee"
		definition="The person receiving lands, minerals, etc."
		path="/oil-and-gas-terms/grantee"
		prevTerm={{ href: "/oil-and-gas-terms/geophone", label: "Geophone" }}
		nextTerm={{ href: "/oil-and-gas-terms/gun-barrel-separator", label: "Gun Barrel Separator" }}
	/>
</BaseLayout>
