---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Gun Barrel Separator";
const description = "A vertical separator located near the wellhead which separates oil, water, and gas.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Gun Barrel Separator"
		definition="A vertical separator located near the wellhead which separates oil, water, and gas."
		path="/oil-and-gas-terms/gun-barrel-separator"
		prevTerm={{ href: "/oil-and-gas-terms/grantee", label: "Grantee" }}
		nextTerm={{ href: "/oil-and-gas-terms/harmonic-decline", label: "Harmonic Decline" }}
	/>
</BaseLayout>
