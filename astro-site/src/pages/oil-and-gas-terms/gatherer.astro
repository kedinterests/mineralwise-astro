---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Gatherer";
const description = "Includes any pipeline, truck, motor vehicle, boat, barge, or person authorized to gather or accept oil, gas, or geothermal resources from lease production or lease storage.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Gatherer"
		definition="Includes any pipeline, truck, motor vehicle, boat, barge, or person authorized to gather or accept oil, gas, or geothermal resources from lease production or lease storage."
		path="/oil-and-gas-terms/gatherer"
		prevTerm={{ href: "/oil-and-gas-terms/gas-oil-ratio-gor", label: "Gas Oil Ratio, GOR" }}
		nextTerm={{ href: "/oil-and-gas-terms/gathering-line", label: "Gathering Line" }}
	/>
</BaseLayout>
