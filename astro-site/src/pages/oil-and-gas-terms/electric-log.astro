---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Electric Log";
const description = "A subsurface recording that indicates a well’s rock formation characteristics by illustrating its responses to electric current.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Electric Log"
		definition="A subsurface recording that indicates a well’s rock formation characteristics by illustrating its responses to electric current."
		path="/oil-and-gas-terms/electric-log"
		prevTerm={{ href: "/oil-and-gas-terms/easement", label: "Easement" }}
		nextTerm={{ href: "/oil-and-gas-terms/escheated", label: "Escheated" }}
	/>
</BaseLayout>
