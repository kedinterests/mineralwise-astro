---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Cost Depletion";
const description = "One of the two calculation methodologies allowed by the IRS for calculating the depletion allowance on oil and gas royalty revenue. The other methodology is called percentage depletion.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Cost Depletion"
		definition="One of the two calculation methodologies allowed by the IRS for calculating the depletion allowance on oil and gas royalty revenue. The other methodology is called percentage depletion."
		path="/oil-and-gas-terms/cost-depletion"
		prevTerm={{ href: "/oil-and-gas-terms/contiguous-tract", label: "Contiguous Tract" }}
		nextTerm={{ href: "/oil-and-gas-terms/crude-oil", label: "Crude Oil" }}
	/>
</BaseLayout>
