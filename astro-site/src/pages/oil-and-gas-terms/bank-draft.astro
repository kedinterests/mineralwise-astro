---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Bank Draft";
const description = "An instrument guaranteeing payment to a party within a certain time window, so long as certain conditions are met.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Bank Draft"
		definition="An instrument guaranteeing payment to a party within a certain time window, so long as certain conditions are met."
		path="/oil-and-gas-terms/bank-draft"
		prevTerm={{ href: "/oil-and-gas-terms/associate-reservoir", label: "Associate Reservoir" }}
		nextTerm={{ href: "/oil-and-gas-terms/barrel-bbl", label: "Barrel, Bbl" }}
	/>
</BaseLayout>
