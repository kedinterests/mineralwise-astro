---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPage from '../../components/TermPage.astro';

const title = "Casinghead Gas";
const description = "The gas that is produced along with the crude oil.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Casinghead Gas"
		definition="The gas that is produced along with the crude oil."
		path="/oil-and-gas-terms/casinghead-gas"
		prevTerm={{ href: "/oil-and-gas-terms/casing", label: "Casing" }}
		nextTerm={{ href: "/oil-and-gas-terms/check-meter", label: "Check Meter" }}
	/>
</BaseLayout>
