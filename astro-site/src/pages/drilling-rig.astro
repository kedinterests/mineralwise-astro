---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Drilling Rig";
const description = "The equipment used to bore into the earth. Rotary style drilling is what is primarily used in today’s drilling.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Drilling Rig"
		definition="The equipment used to bore into the earth. Rotary style drilling is what is primarily used in today’s drilling."
		path="/drilling-rig"
		prevTerm={{ href: "/drilling-mud-drilling-fluid", label: "Drilling Mud, Drilling Fluid" }}
		nextTerm={{ href: "/dry-gas", label: "Dry Gas" }}
	/>
</BaseLayout>
