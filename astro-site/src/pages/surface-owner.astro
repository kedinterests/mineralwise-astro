---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Surface Owner";
const description = "Owner of the rights and interests in a surface estate.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Surface Owner"
		definition="Owner of the rights and interests in a surface estate."
		path="/surface-owner"
		prevTerm={{ href: "/surface-estate", label: "Surface Estate" }}
		nextTerm={{ href: "/surface-rights", label: "Surface Rights" }}
	/>
</BaseLayout>
