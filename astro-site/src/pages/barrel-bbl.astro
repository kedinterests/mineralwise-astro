---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Barrel, Bbl";
const description = "In the oil and gas industry, a barrel is 42 U.S. gallons measured at 60º Fahrenheit.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Barrel, Bbl"
		definition="In the oil and gas industry, a barrel is 42 U.S. gallons measured at 60º Fahrenheit."
		path="/barrel-bbl"
		prevTerm={{ href: "/bank-draft", label: "Bank Draft" }}
		nextTerm={{ href: "/basic-sediment-and-water-bs-and-w", label: "Basic Sediment and Water, BS&amp;W" }}
	/>
</BaseLayout>
