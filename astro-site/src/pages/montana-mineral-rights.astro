---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Montana Mineral Rights | MineralWise";
const metaDescription = "Montana Mineral Rights value varies widely across the state. Montana's mineral rights produce a wide range of hydrocarbon products including crude oil, natural ";

const stateName = "Montana";
const stateAbbr = "MT";
const description = "Montana Mineral Rights value varies widely across the state. Montana's mineral rights produce a wide range of hydrocarbon products including crude oil, natural ";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/montana-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
