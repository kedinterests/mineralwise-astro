---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "California Mineral Rights | MineralWise";
const metaDescription = "California Mineral Rights date back to the early days of oil and gas exploration. At one point in America";

const stateName = "California";
const stateAbbr = "CA";
const description = "California Mineral Rights date back to the early days of oil and gas exploration. At one point in America";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/california-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
