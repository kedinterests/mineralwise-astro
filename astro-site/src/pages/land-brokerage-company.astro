---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Land Brokerage Company";
const description = "An organization that offers its services to oil and gas Operators for the purpose of obtaining leases. Often independent landmen work for a land brokerage company.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Land Brokerage Company"
		definition="An organization that offers its services to oil and gas Operators for the purpose of obtaining leases. Often independent landmen work for a land brokerage company."
		path="/land-brokerage-company"
		prevTerm={{ href: "/intestate-death", label: "Intestate Death" }}
		nextTerm={{ href: "/land-department", label: "Land Department" }}
	/>
</BaseLayout>
