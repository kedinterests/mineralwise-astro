---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Receive a No-Obligation Cash Proposal for Your Mineral Interests | KED Interests, LLC";
const description = "Discover the value of your mineral interests with KED Interests, LLC. Get a free, secure, and no-obligation cash proposal evaluated in-house by trusted professionals. Contact us today!";
---

<head>
	<meta name="robots" content="noindex, nofollow" />
</head>

<BaseLayout title={title} description={description} adConfig="none">
	<PageShell breadcrumbs={getBreadcrumbs('/offer')}>
		<ArticleContent>
			<div class="content-page">
				<h1>Receive a Free, No Obligation Cash Proposal</h1>

				<div class="content-body">
					<p>We will need certain information to help us estimate a value for your mineral interests. Please fill out this information completely. Your information will remain private and secure. We evaluate your interests in-house, and make purchases for our own account (i.e., our business is not that of selling "leads".) We value personal interaction with our clients. We will call to speak with you personally before proceeding with an evaluation.</p>

					<div id="form" class="form-section">
						<h2>Request your no-obligation, cash proposal</h2>
						<p>Fill out the form below and we will get back to you soon.</p>
						<iframe
							aria-label="Receive Cash Proposal - MineralWise"
							title="Receive Cash Proposal - MineralWise"
							class="zoho-form"
							src="https://forms.zohopublic.com/kedinterestsllc/form/ReceiveCashProposalMineralWise/formperma/veMc3DbHc4HmORjCb2YBCKKoSFnIK5RoN30BiOYJ0n8"
						></iframe>
					</div>
				</div>
			</div>
		</ArticleContent>
	</PageShell>
</BaseLayout>

<style>
	.content-page {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}

	.content-page h1 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		color: #1a1a1a;
	}

	.content-body {
		font-size: 1.0625rem;
		line-height: 1.8;
		color: #374151;
	}

	.content-body h2 {
		font-size: 1.75rem;
		font-weight: 700;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}

	.content-body h2:first-of-type {
		margin-top: 0;
	}

	.content-body p {
		margin-bottom: 1.25rem;
	}

	.form-section {
		margin-top: 2rem;
	}

	.zoho-form {
		width: 100%;
		height: 1200px;
		border: none;
		margin-top: 1rem;
		border-radius: 8px;
	}

	@media (max-width: 640px) {
		.content-page {
			padding: 1.5rem;
		}

		.content-page h1 {
			font-size: 2rem;
		}

		.content-body h2 {
			font-size: 1.5rem;
		}
	}
</style>
