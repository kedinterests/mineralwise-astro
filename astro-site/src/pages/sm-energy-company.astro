---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "SM Energy Company | MineralWise";
const description = "SM Energy Company (the new name for St. Mary Land & Exploration) is an oil and gas exploration and production company based in Denver, Colorado. SM Energy stock is listed on the NYSE under the symbol SM. The Company focuses on development and production in the following regions: Mid-Continent, Rocky Mountain, ArkLaTex, Permian Basin, and the Gulf Coast. At the end of 2008 SM Energy had natural gas reserves totaling 865.5 billion cubic feet.";

const companyDescription = `(the new name for St. Mary Land & Exploration) is an oil and gas exploration and production company based in Denver, Colorado. SM Energy stock is listed on the NYSE under the symbol SM. The Company focuses on development and production in the following regions: Mid-Continent, Rocky Mountain, ArkLaTex, Permian Basin, and the Gulf Coast. At the end of 2008 SM Energy had natural gas reserves totaling 865.5 billion cubic feet.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/sm-energy-company')}>
		<ArticleContent>
			<CompanyPage
				companyName="SM Energy Company"
				description={companyDescription}
				logoPath="/images/sm-energy.png"
				contactPhone="(303) 861-8140"
				contactLabel="Contact Information for Royalty Owners"
				showProductionVerification={true}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
