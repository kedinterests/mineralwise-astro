---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Depletion Allowance";
const description = "The tax deduction allowed by the IRS for royalty and mineral owners to offset the decrease in value of a capital investment caused by the production (depletion) of minerals.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Depletion Allowance"
		definition="The tax deduction allowed by the IRS for royalty and mineral owners to offset the decrease in value of a capital investment caused by the production (depletion) of minerals."
		path="/depletion-allowance"
		prevTerm={{ href: "/depletion", label: "Depletion" }}
		nextTerm={{ href: "/developmental-well", label: "Developmental Well" }}
	/>
</BaseLayout>
