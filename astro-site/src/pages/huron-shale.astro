---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import ShalePlayPage from '../components/ShalePlayPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Huron Shale | MineralWise";
const description = "The Huron Shale is located in the Appalachian Basin in West Virginia and Kentucky.Huron Shale CompaniesSignificant producers within the Huron Shale are:EQT Corp.Equitable ResourcesExco (XCO) ResourcesRange Resources.Huron Shale GeologyThe Huron Shale is a geological formation ranging from 200 to 2,000 feet thick and is found at depths of 4,000 to 5,000 feet.Huron Shale LocationThe Huron Shale is located in the following counties of West Virginia:Braxton County WVCabell County WVCalhoun County WVClay County WVFayette County WVJackson County WVKanawha County WVLincoln County WVLogan County WVMason County WVMingo County WVNicholas County WVPleasants County WVPutnam County WVRaleigh County WVRitchie County WVRoane County WVTyler County WVWayne County WVWirt County WVWood County WVWyoming County WVThe Huron Shale is located in the following counties of Kentucky:Boyd County KYFloyd County KYJohnson County KYLawrence County KYMartin County KYPike County KYAdditional ReadingOil &amp;amp; Gas 101 – General information for mineral rights owners.";

const shaleName = "Huron Shale";
const state = undefined;
const descriptionText = "The Huron Shale is located in the Appalachian Basin in West Virginia and Kentucky.";

const companies = [
	"EQT Corp.",
	"Equitable Resources",
	"Exco (XCO) Resources",
	"Range Resources."
];

const geology = "";

const counties = [
	"Braxton County WV",
	"Cabell County WV",
	"Calhoun County WV",
	"Clay County WV",
	"Fayette County WV",
	"Jackson County WV",
	"Kanawha County WV",
	"Lincoln County WV",
	"Logan County WV",
	"Mason County WV",
	"Mingo County WV",
	"Nicholas County WV",
	"Pleasants County WV",
	"Putnam County WV",
	"Raleigh County WV",
	"Ritchie County WV",
	"Roane County WV",
	"Tyler County WV",
	"Wayne County WV",
	"Wirt County WV",
	"Wood County WV",
	"Wyoming County WV"
];

const additionalReading = [
	{
		"text": "Oil & Gas 101",
		"href": "/oil-and-gas-basics-for-mineral-owners",
		"external": false
	}
];
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/huron-shale')}>
		<ArticleContent>
			<ShalePlayPage
				shaleName={shaleName}
				state={state}
				description={descriptionText}
				companies={companies}
				geology={geology}
				counties={counties}additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
