---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Regulatory Agency";
const description = "The body within each state that administers oil and gas policy set by state government. These bodies serve as the repository for public data related to oil and gas operations within the state.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Regulatory Agency"
		definition="The body within each state that administers oil and gas policy set by state government. These bodies serve as the repository for public data related to oil and gas operations within the state."
		path="/regulatory-agency"
		prevTerm={{ href: "/recompletion", label: "Recompletion" }}
		nextTerm={{ href: "/reserve-pit-mud-pit", label: "Reserve Pit Mud Pit" }}
	/>
</BaseLayout>
