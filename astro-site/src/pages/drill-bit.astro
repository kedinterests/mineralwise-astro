---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Drill Bit";
const description = "The item placed at the end of the drilling string used in drilling into the earth. Drill bits cut and chip small pieces of rock as the pipe rotates.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Drill Bit"
		definition="The item placed at the end of the drilling string used in drilling into the earth. Drill bits cut and chip small pieces of rock as the pipe rotates."
		path="/drill-bit"
		prevTerm={{ href: "/downstream", label: "Downstream" }}
		nextTerm={{ href: "/drill-string", label: "Drill String" }}
	/>
</BaseLayout>
