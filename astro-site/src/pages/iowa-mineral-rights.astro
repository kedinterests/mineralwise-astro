---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Iowa Mineral Rights | MineralWise";
const metaDescription = "The value of Iowa mineral rights was influenced slightly beginning in 1963 when oil was first discovered in Washington County. 123 oil wells have since been dri";

const stateName = "Iowa";
const stateAbbr = "IA";
const description = "The value of Iowa mineral rights was influenced slightly beginning in 1963 when oil was first discovered in Washington County. 123 oil wells have since been dri";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/iowa-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
