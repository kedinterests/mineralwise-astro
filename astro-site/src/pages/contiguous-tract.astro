---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Contiguous Tract";
const description = "A tract of land of which there is a continuous and unbroken perimeter.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Contiguous Tract"
		definition="A tract of land of which there is a continuous and unbroken perimeter."
		path="/contiguous-tract"
		prevTerm={{ href: "/condensate-lease-condensate", label: "Condensate, Lease Condensate" }}
		nextTerm={{ href: "/cost-depletion", label: "Cost Depletion" }}
	/>
</BaseLayout>
