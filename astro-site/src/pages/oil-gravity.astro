---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Oil Gravity";
const description = "A measure of an oil’s density. Gravity is a widely used indicator of a crude oil’s worth. The less dense oils are of greater value.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Oil Gravity"
		definition="A measure of an oil’s density. Gravity is a widely used indicator of a crude oil’s worth. The less dense oils are of greater value."
		path="/oil-gravity"
		prevTerm={{ href: "/oil-and-gas-mineral-lease", label: "Oil And Gas Mineral Lease" }}
		nextTerm={{ href: "/oil-well", label: "Oil Well" }}
	/>
</BaseLayout>
