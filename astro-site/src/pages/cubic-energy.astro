---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Cubic Energy | MineralWise";
const description = "Cubic Energy";

const companyDescription = `is an oil and gas exploration and production company based in Dallas Texas. Cubic Energy stock is listed on the AMEX under the symbol QBC. Cubic Energy focuses its exploration and development mainly in Louisiana and Texas. Cubic Energy’s Louisiana exploration and production takes place mainly in DeSoto Parish and Caddo Parish, targeting the Cotton Valley formation. The company also holds positions in the Bossier shale and Haynesville shale.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/cubic-energy')}>
		<ArticleContent>
			<CompanyPage
				companyName="Cubic Energy"
				description={companyDescription}
				logoPath="/images/cubic-energy.png"
				contactPhone="(972) 686-0369"
				showProductionVerification={true}
				showCashPayment={true}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
