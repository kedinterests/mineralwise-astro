---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Compression";
const description = "Often natural gas from the wellhead must be compressed to a higher pressure in order to increase its pressure enough in order to get it into pipelines for further transportation to market.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Compression"
		definition="Often natural gas from the wellhead must be compressed to a higher pressure in order to increase its pressure enough in order to get it into pipelines for further transportation to market."
		path="/compression"
		prevTerm={{ href: "/completion", label: "Completion" }}
		nextTerm={{ href: "/condensate-lease-condensate", label: "Condensate, Lease Condensate" }}
	/>
</BaseLayout>
