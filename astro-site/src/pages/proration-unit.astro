---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Proration Unit";
const description = "Acreage allocated to a well, usually by a government authority, that can be drained by a well in a specific formation or depth.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Proration Unit"
		definition="Acreage allocated to a well, usually by a government authority, that can be drained by a well in a specific formation or depth."
		path="/proration-unit"
		prevTerm={{ href: "/progressing-or-progressive-cavity-pump", label: "Progressing Or Progressive Cavity Pump" }}
		nextTerm={{ href: "/proven-reserves", label: "Proven Reserves" }}
	/>
</BaseLayout>
