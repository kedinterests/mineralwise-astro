---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Substandard Acreage";
const description = "Amount of acreage that is less than the standard amount for a proration unit for a field.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Substandard Acreage"
		definition="Amount of acreage that is less than the standard amount for a proration unit for a field."
		path="/substandard-acreage"
		prevTerm={{ href: "/structural-trap", label: "Structural Trap" }}
		nextTerm={{ href: "/surface-casing", label: "Surface Casing" }}
	/>
</BaseLayout>
