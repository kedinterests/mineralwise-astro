---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Workover";
const description = "Operations on a producing well to restore or increase production.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Workover"
		definition="Operations on a producing well to restore or increase production."
		path="/workover"
		prevTerm={{ href: "/working-interest-wi", label: "Working Interest Wi" }}
	/>
</BaseLayout>
