---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Chesapeake Energy | MineralWise";
const description = "Chesapeake Energy is the most active driller of new wells in the United States and one of the nation's largest producers of natural gas. Chesapeake stock is traded on the NYSE under the symbol CHK.";

const companyDescription = `is the most active driller of new wells in the United States and one of the nation's largest producers of natural gas. Chesapeake stock is traded on the NYSE under the symbol CHK. Chesapeake Energy focuses on drilling and developing onshore U.S. natural gas reserves in north-central Texas (Barnett Shale), East Texas (Haynesville Shale), Louisiana (Fayetteville Shale), and the Appalachian Basin (Marcellus Shale). Chesapeake Energy also actively drills in other areas including the Mid-Continent, Appalachian Basin, Permian Basin, South Texas, Gulf Coast, and East Texas.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/chesapeake-energy')}>
		<ArticleContent>
			<CompanyPage
				companyName="Chesapeake Energy"
				description={companyDescription}
				logoPath="/images/chesaoeake-energy.png"
				contactPhone="(877) CHK-1GAS"
				showProductionVerification={true}
				additionalSections={[
					{
						title: "Newsletter Signup",
						content: `<p>Stay informed. Sign up now for our monthly Oil and Gas Mineral Services Newsletter and receive the free guide "Maximizing Your Minerals". Simply enter your email address in the newsletter sign up box on the right sidebar of this page and click subscribe.</p>`
					}
				]}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
