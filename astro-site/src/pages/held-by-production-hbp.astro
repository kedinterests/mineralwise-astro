---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Held By Production, HBP";
const description = "Mineral lease provision that extends the right to operate a lease as long as the property produces a minimum quantity of oil &amp;amp; gas.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Held By Production, HBP"
		definition="Mineral lease provision that extends the right to operate a lease as long as the property produces a minimum quantity of oil &amp; gas."
		path="/held-by-production-hbp"
		prevTerm={{ href: "/harmonic-decline", label: "Harmonic Decline" }}
		nextTerm={{ href: "/henry-hub", label: "Henry Hub" }}
	/>
</BaseLayout>
