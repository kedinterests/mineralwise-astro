---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Lease";
const description = "The generic name for an Oil, Gas and Mineral Lease (OGML).";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Lease"
		definition="The generic name for an Oil, Gas and Mineral Lease (OGML)."
		path="/lease"
		prevTerm={{ href: "/landman-petroleum-landman", label: "Landman Petroleum Landman" }}
		nextTerm={{ href: "/lease-automatic-custody-transfer-unit-lact-unit", label: "Lease Automatic Custody Transfer Unit Lact Unit" }}
	/>
</BaseLayout>
