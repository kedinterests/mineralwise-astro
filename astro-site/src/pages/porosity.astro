---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Porosity";
const description = "Percentage of the rock volume that can be occupied by oil, gas or water.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Porosity"
		definition="Percentage of the rock volume that can be occupied by oil, gas or water."
		path="/porosity"
		prevTerm={{ href: "/pooled-unit", label: "Pooled Unit" }}
		nextTerm={{ href: "/possible-reserves", label: "Possible Reserves" }}
	/>
</BaseLayout>
