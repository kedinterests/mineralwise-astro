---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Mineral Lease";
const description = "An instrument which sets out the terms by which one party leases the right to explore and produce (if found) certain minerals within a specific tract or tracts of land. In the oil and gas industry, this is sometimes referred to as an Oil, Gas, and Mineral Lease (OGML)";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Mineral Lease"
		definition="An instrument which sets out the terms by which one party leases the right to explore and produce (if found) certain minerals within a specific tract or tracts of land. In the oil and gas industry, this is sometimes referred to as an Oil, Gas, and Mineral Lease (OGML)"
		path="/mineral-lease"
		prevTerm={{ href: "/mcfe", label: "Mcfe" }}
		nextTerm={{ href: "/mineral-owner", label: "Mineral Owner" }}
	/>
</BaseLayout>
