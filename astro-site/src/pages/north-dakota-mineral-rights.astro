---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "North Dakota Mineral Rights | MineralWise";
const metaDescription = "Oil was first discovered in North Dakota in 1951. Mineral rights in this sparsely populated region bordering Canada did not receive much attention until the dis";

const stateName = "North Dakota";
const stateAbbr = "ND";
const description = "Oil was first discovered in North Dakota in 1951. Mineral rights in this sparsely populated region bordering Canada did not receive much attention until the dis";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/north-dakota-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
