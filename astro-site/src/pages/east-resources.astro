---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "East Resources | MineralWise";
const description = "East Resources";

const companyDescription = `is an oil and gas drilling company based in Pennsylvania. East Resources is active in the Appalachian Basin with over 1 million acres of oil and gas rights where it is the largest oil producer. East Resources is one of the most active drillers of the Ordovician Black River gas plays of south central New York. The company also holds over 175,000 acres of oil and gas properties in the Rocky Mountain Regions of Utah, Colorado, and Wyoming.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/east-resources')}>
		<ArticleContent>
			<CompanyPage
				companyName="East Resources"
				description={companyDescription}
				logoPath="/images/east-resources.png"
				contactPhone="(724) 772-8600"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
