---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/utica-shale-new-york')}>
		<ArticleContent>
			<ShalePlayPage
				shaleName={shaleName}
				state={state}
				description={descriptionText}
				companies={companies}
				geology={geology}
				counties={counties}additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
