---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Hilcorp Energy Co. | MineralWise";
const description = "Hilcorp Energy Co.";

const companyDescription = `Hilcorp Energy is a privately held oil and gas company with headquarters in Houston, Texas.&nbsp;Its primary operating areas are the Gulf Coast region of the United States and Wyoming’s Powder River Basin. Hilcorp'sbeginnings startedin 1989 and recently surpassed 20 years of producing oil and gas.&nbsp;Since 1989 Hilcorp has grown to be one of the largest privately-held E&P companies in the country. It's basic business model is that of acquiring and then exploiting properties in areas where it believes it can add significant value to already in place reserves.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/hilcorp-energy-co')}>
		<ArticleContent>
			<CompanyPage
				companyName="Hilcorp Energy Co."
				description={companyDescription}
				logoPath="/images/hilcorp.jpg"
				contactPhone="(713) 209-2400"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
