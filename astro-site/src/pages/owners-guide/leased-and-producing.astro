---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import OwnerGuideTabs from '../../components/OwnerGuideTabs.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Comprehensive Guide to Managing Leased and Producing Mineral Rights";
const description = "Learn everything about managing leased and producing mineral rights, from royalty statements and taxes to oil &amp; gas measurement, surface rights, and revenue management. Explore tax-saving strategies and production verification tips for mineral owners.";

const heading = "Leased and Producing";
const intro = "Producing mineral rights require constant management. If you are a Mineral Owner under lease and currently receive monthly revenue. The articles below will help you with everything from understanding taxes to how to read your royalty statement.";

const tabs = [
	{
		label: "General Topics",
		id: "general",
		articles: [
			{
				title: "Oil & Gas Measurement",
				href: "/oil-gas-measurement",
				description: "Explanation of how oil and gas is measured at the lease and how it relates to payment for royalty owners or mineral owners. Defines MMBTU, MCF, BBL and more."
			},
			{
				title: "Royalty Management",
				href: "/oil-and-gas-royalty-management",
				description: "Explains how to manage oil and gas royalties. Covers topics like mineral rights fragmentation and estate cleanup."
			},
			{
				title: "Royalty Statements",
				href: "/oil-and-gas-royalty-statement",
				description: "Learn how to read and understand your oil and gas royalty statement. Explains terms like decimal interest, deductions, MCF, and BTU factor."
			},
			{
				title: "Surface Rights",
				href: "/surface-rights-vs-mineral-rights-in-oil-gas-leasing",
				description: "Learn the basic differences between surface and mineral rights."
			},
			{
				title: "Volume Verification",
				href: "/oil-and-gas-production-volume-verification",
				description: "Short article explaining how oil and gas royalty owners can verify their oil and gas production. Includes links to free state verification"
			},
			{
				title: "What is Fracking?",
				href: "/what-is-fracking",
				description: "Hydraulic Fracturing defined through the eyes of a mineral owner."
			}
		]
	},
	{
		label: "Taxes & Deductions",
		id: "taxes",
		articles: [
			{
				title: "Royalty Taxes",
				href: "/royalty-taxes",
				description: "Explains the tax on royalty and how these relate to mineral rights and royalty owners. See the articles below for additional detail."
			},
			{
				title: "Oil Severance Tax",
				href: "/oil-severance-tax",
				description: "A detailed explanation of the oil severance tax."
			},
			{
				title: "Gas Severance Tax",
				href: "/gas-severance-tax",
				description: "A detailed explanation of the gas severance tax."
			},
			{
				title: "County Ad Valorem Tax",
				href: "/ad-valorem-taxes",
				description: "Learn what it is and how/when it applies."
			},
			{
				title: "Depletion Allowance",
				href: "/depletion-allowance-2",
				description: "Learn about this royalty tax saving strategy."
			},
			{
				title: "Income Taxes",
				href: "/oil-gas-mineral-and-royalty-income-taxes",
				description: "Basic guidance for navigating your federal income taxes."
			},
			{
				title: "1031 Exchange for Mineral Rights",
				href: "/1031-exchange-for-mineral-rights",
				description: "Learn what qualifies, how it works, and the benefits."
			}
		]
	}
];
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/owners-guide/leased-and-producing')}>
		<ArticleContent>
			<OwnerGuideTabs 
				heading={heading}
				intro={intro}
				tabs={tabs}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
