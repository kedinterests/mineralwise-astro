---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import OwnerGuideTabs from '../../components/OwnerGuideTabs.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Understanding Leased Mineral Rights: What to Expect When Not Receiving Monthly Revenue";
const description = "Learn why you might not be receiving royalties on your leased mineral rights. Explore the oil and gas production process, top leasing, and division orders, and understand what happens after signing a lease.";

const heading = "I am a currently leased Mineral Owner, yet not currently receiving monthly revenue.";
const intro = "Signing an oil and gas lease is the first step in the process of receiving royalty from your mineral interests. The articles below will show you what to expect once the production process starts and how to understand the different documents you will receive relating to your oil or gas lease.";

const tabs = [
	{
		label: "Understanding the Process",
		id: "process",
		articles: [
			{
				title: "Production 101",
				href: "/oil-and-gas-production-nontechnical-language",
				description: "Free article explaining the drilling, completing, and testing of oil and gas wells in nontechnical language. Valuable insight for mineral rights owners."
			},
			{
				title: "Top Leasing",
				href: "/top-leasing",
				description: "Top leases cover land upon which a current lease already exists. Provisions in top leases include \"first right of refusal\"."
			},
			{
				title: "Division Order",
				href: "/division-order-2",
				description: "Explanation of oil and gas Division Orders for mineral, royalty, and overriding royalty owners. Answers to questions, definitions, and sources for help."
			}
		]
	}
];
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/owners-guide/leased-but-not-producing')}>
		<ArticleContent>
			<OwnerGuideTabs 
				heading={heading}
				intro={intro}
				tabs={tabs}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
