---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import OwnerGuideTabs from '../../components/OwnerGuideTabs.astro';
import { getBreadcrumbs } from '../../data/hierarchy';

const title = "Comprehensive Guide for Mineral Rights Owners | Lease, Royalties, & Sale Tips";
const description = "Explore the ultimate resource for mineral rights owners. Learn about leasing, unclaimed royalties, well production, and selling mineral rights. Start with actionable advice and maximize your property's value today!";

const heading = "Owner's Guide";
const intro = "The Owner's Guide is a practical, action oriented resource for mineral rights owners. The Guide contains information for those already leased, and those who are contemplating or negotiating a lease offer. It also includes advice and guidance for owners whose leases are not producing, for those wondering if they have unclaimed mineral rights, and for mineral rights owners considering the sale of mineral rights royalties. Be prepared—with the Owner's Guide.";

const tabs = [
	{
		label: "Guide Sections",
		id: "sections",
		articles: [
			{
				title: "Oil & Gas Basics",
				href: "/owners-guide/oil-and-gas-basics-for-mineral-owners",
				description: "General information for mineral rights owners. Start here if you're a newbie."
			},
			{
				title: "Leased And Producing",
				href: "/owners-guide/leased-and-producing",
				description: "Articles designed to assist owners with questions or issues related to a producing well."
			},
			{
				title: "Unleased Mineral Owner",
				href: "/owners-guide/unleased-mineral-owner",
				description: "Articles containing information about how to attract oil or gas drilling on your property, and understanding the value of your mineral rights."
			},
			{
				title: "Leased But Not Producing",
				href: "/owners-guide/leased-but-not-producing",
				description: "Information for mineral rights owners who have newly-leased property."
			},
			{
				title: "Lease Proposals",
				href: "/owners-guide/lease-proposals",
				description: "Articles and guidelines for evaluating and understanding lease proposals."
			},
			{
				title: "Opportunities",
				href: "/owners-guide/opportunities-for-all",
				description: "Articles about discovering unclaimed royalties in your name."
			},
			{
				title: "Prefer Cash Payment",
				href: "/owners-guide/cash-payment-for-oil-and-gas-royalty",
				description: "Information on estimating the value of your mineral interests and the possible sale of your mineral rights."
			}
		]
	}
];
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/owners-guide')}>
		<ArticleContent>
			<OwnerGuideTabs 
				heading={heading}
				intro={intro}
				tabs={tabs}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
