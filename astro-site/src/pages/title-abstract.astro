---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Title Abstract";
const description = "A chronological history of the ownership or significant events effecting a particular piece of property.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Title Abstract"
		definition="A chronological history of the ownership or significant events effecting a particular piece of property."
		path="/title-abstract"
		prevTerm={{ href: "/three-phase-separator", label: "Three Phase Separator" }}
		nextTerm={{ href: "/title-curative", label: "Title Curative" }}
	/>
</BaseLayout>
