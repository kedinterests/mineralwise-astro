---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Working Interest, WI";
const description = "Interest(s) in a mineral property.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Working Interest, WI"
		definition="Interest(s) in a mineral property."
		path="/working-interest-wi"
		prevTerm={{ href: "/wildcat", label: "Wildcat" }}
		nextTerm={{ href: "/workover", label: "Workover" }}
	/>
</BaseLayout>
