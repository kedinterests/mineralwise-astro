---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Delay Rental";
const description = "Yearly payments made to Lessor during the primary term to compensate for delayed drilling.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Delay Rental"
		definition="Yearly payments made to Lessor during the primary term to compensate for delayed drilling."
		path="/delay-rental"
		prevTerm={{ href: "/dehydration", label: "Dehydration" }}
		nextTerm={{ href: "/depletion", label: "Depletion" }}
	/>
</BaseLayout>
