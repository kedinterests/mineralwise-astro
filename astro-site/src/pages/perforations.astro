---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Perforations";
const description = "Holes within and through casing and cement into the productive formation.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Perforations"
		definition="Holes within and through casing and cement into the productive formation."
		path="/perforations"
		prevTerm={{ href: "/percentage-depletion", label: "Percentage Depletion" }}
		nextTerm={{ href: "/permeability", label: "Permeability" }}
	/>
</BaseLayout>
