---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Contact Us | MineralWise";
const description = "Get in touch with MineralWise. We love hearing from our visitors. Contact us with any questions about mineral rights, royalties, or our services.";
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/contact-us')}>
		<ArticleContent>
			<div class="contact-page">
				<h1>Contact Us</h1>
				<p class="intro">
					Thank you for visiting MineralWise.com. We love hearing from our visitors. Contact us with the form below.
				</p>
				
				<div class="contact-form-wrapper">
					<iframe 
						aria-label="Contact Us - MineralWise" 
						frameborder="0" 
						src="https://forms.zohopublic.com/kedinterestsllc/form/ContactForm/formperma/rAZ-xoda_pHeATUiqHq34EatYO_6iKnJOdwsYkQRPSQ"
						title="Contact Form"
					></iframe>
				</div>
			</div>
		</ArticleContent>
	</PageShell>
</BaseLayout>

<style>
	.contact-page {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}

	.contact-page h1 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}

	.intro {
		font-size: 1.125rem;
		color: #666;
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	.contact-form-wrapper {
		width: 100%;
		border-radius: 8px;
		overflow: hidden;
		background: #f9fafb;
		border: 1px solid #e5e7eb;
	}

	.contact-form-wrapper iframe {
		width: 100%;
		height: 750px;
		border: none;
		display: block;
	}

	@media (max-width: 640px) {
		.contact-page {
			padding: 1.5rem;
		}

		.contact-page h1 {
			font-size: 2rem;
		}

		.contact-form-wrapper iframe {
			height: 600px;
		}
	}
</style>
