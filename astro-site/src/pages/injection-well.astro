---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Injection Well";
const description = "Well used to inject fluids (usually water) into a subsurface formation.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Injection Well"
		definition="Well used to inject fluids (usually water) into a subsurface formation."
		path="/injection-well"
		prevTerm={{ href: "/initial-production-ip", label: "Initial Production Ip" }}
		nextTerm={{ href: "/intangible-drilling-costs-idc", label: "Intangible Drilling Costs Idc" }}
	/>
</BaseLayout>
