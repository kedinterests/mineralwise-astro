---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Berry Petroleum Company | MineralWise";
const description = "Berry Petroleum Company is an independent energy company engaged in drilling for, developing, and producing crude oil and natural gas. Berry Petroleum stock trades on the NYSE under the symbol BRY.";

const companyDescription = `is an independent energy company engaged in drilling for, developing, and producing crude oil and natural gas. Berry Petroleum stock trades on the NYSE under the symbol BRY. Publicly traded since 1987, Berry traces its roots in California heavy oil production back to 1909. Currently, Berry's principal reserves and producing properties are in California, Utah (Uinta basin) and Colorado (Piceance and DJ basins). Berry's reserve mix is approximately 70% crude oil and 30% natural gas.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/berry-petroleum-company')}>
		<ArticleContent>
			<CompanyPage
				companyName="Berry Petroleum Company"
				description={companyDescription}
				logoPath="/images/berry-petroleum-company.gif"
				contactPhone="(303) 999-4400"
				showProductionVerification={true}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
