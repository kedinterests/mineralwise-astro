import BaseLayout from '../layouts/BaseLayout.astro';
import { Fragment } from 'astro/jsx-runtime';

const title = "Check for Unclaimed Oil and Gas Royalties in Your State - Find and Claim Now";
const description = "Discover unclaimed oil and gas royalties that may belong to you. Learn how to search for your unclaimed funds by state and claim your rightful money with an easy process. Don’t miss out on potential royalty earnings!";

const content = "<div id=\"mm-0\">\n    <section id=\"mYRUyHLEDeIn_mYRUyHLEDeIn\"><div><div><div id=\"\"><div><div data-brz-translate-text=\"1\"><h1 data-generated-css=\"brz-css-eGJKX\" data-uniq-id=\"p6Spx\"><span style=\"color: rgba(var(--brz-global-color2),1);\">You May Have a Check for Unclaimed Royalties Waiting</span></h1></div></div></div><div><div><div><div><div id=\"\"><div><picture><source srcset=\"https://cloud-1de12d.becdn.net/media/original/4e89c95a0709a69544e7a107d3d66273/unclaimed.jpg, https://cloud-1de12d.becdn.net/media/original/4e89c95a0709a69544e7a107d3d66273/unclaimed.jpg\" media=\"(min-width: 992px)\"><source srcset=\"https://cloud-1de12d.becdn.net/media/original/4e89c95a0709a69544e7a107d3d66273/unclaimed.jpg, https://cloud-1de12d.becdn.net/media/original/4e89c95a0709a69544e7a107d3d66273/unclaimed.jpg\" media=\"(min-width: 768px)\"><img srcset=\"https://cloud-1de12d.becdn.net/media/original/4e89c95a0709a69544e7a107d3d66273/unclaimed.jpg, https://cloud-1de12d.becdn.net/media/original/4e89c95a0709a69544e7a107d3d66273/unclaimed.jpg\" src=\"https://cloud-1de12d.becdn.net/media/original/4e89c95a0709a69544e7a107d3d66273/unclaimed.jpg\" loading=\"lazy\" alt=\"\" title=\"unclaimed.jpg\" draggable=\"false\"></picture></div></div></div></div><div><div><div id=\"\"><div><div data-brz-translate-text=\"1\"><p data-uniq-id=\"u92XJ\" data-generated-css=\"brz-css-oTt2B\"><span style=\"color: rgb(31, 31, 31);\"> Did you know that many people have unclaimed oil and gas royalties of which they are not aware? And you may be one of them. Each state government is responsible to maintain and administer an account containing unclaimed funds whose owners cannot be found, or to which there is questionable ownership. And it’s not chump change – it’s millions and millions and millions of unclaimed royalties. State statutes allow suspended royalty funds to be handed over to the state government after a prolonged period. In effect, the law allows oil companies to off load the responsibility of administration over these oil and gas royalties after a period of 3-10 years, depending on the state. At this point the oil company gives the state whatever records it has, and the responsibility of administering these funds is transferred to the state. These funds now become part of that state’s Unclaimed Property. The article “Royalty in Suspense” discusses how individuals can access money owed them that is held by oil and gas companies which has not yet been handed over (escheated) to the state.</span></p></div></div></div></div></div></div></div><div id=\"\"><div><div data-brz-translate-text=\"1\"><p data-generated-css=\"brz-css-jZOFs\" data-uniq-id=\"i2KsV\"><span style=\"color: rgba(var(--brz-global-color2),1);\">There are a myriad of reasons why unclaimed money ends up here - among the most common are invalid mailing addresses, simple misspellings, or a minor title issue. Common unclaimed properties that end up with the state are utility deposits, insurance dividends, oil and gas royalty payments and stock dividends.</span></p><p data-generated-css=\"brz-css-biBco\" data-uniq-id=\"msNEn\"></p><h2 data-generated-css=\"brz-css-v9347\" data-uniq-id=\"xalP7\"><span style=\"color: rgba(var(--brz-global-color2),1);\">Find Your Unclaimed Oil and Gas Royalty, It's Easy</span></h2><p data-generated-css=\"brz-css-seRDL\" data-uniq-id=\"rVlKG\"><span style=\"color: rgba(var(--brz-global-color2),1);\">With today’s technology, it is easy and quick to check your name or your company name for unclaimed royalty funds that may be owed you. You’ll have to jump through a few hoops with the state to get your unclaimed money, but the process is generally not too burdensome. And of course, it may be that the payoff will be well worth the time!</span></p><p data-generated-css=\"brz-css-e81VY\" data-uniq-id=\"hvyUP\"></p><p data-generated-css=\"brz-css-tWoWG\" data-uniq-id=\"n0IVS\"><span style=\"color: rgba(var(--brz-global-color2),1);\">If you would like to discuss mineral rights related issues with other landowners visit </span><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"https://mineralrightsforum.com\" data-brz-link-type=\"external\">MineralRightsForum.com</a><span style=\"color: rgba(var(--brz-global-color2),1);\">.</span></p><p data-generated-css=\"brz-css-qPqvI\" data-uniq-id=\"cTXAr\"></p><p data-generated-css=\"brz-css-xl4YN\" data-uniq-id=\"ovA_h\"><span style=\"color: rgba(var(--brz-global-color2),1);\">To find your unclaimed oil and gas royalty, click on your state from the list below.</span></p></div></div></div><div><div><div><div><div id=\"\"><div><div data-brz-translate-text=\"1\"><ul><li data-generated-css=\"brz-css-zUeG5\" data-uniq-id=\"hTDEh\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"http://www.moneyquestalabama.com/\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Alabama Unclaimed Oil and Gas Royalty</a></li><li data-generated-css=\"brz-css-ipZ5u\" data-uniq-id=\"kkX87\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"https://www.ark.org/auditor/unclprop/index.php/search/searchCrit\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Arkansas Unclaimed Oil and Gas Royalty</a></li><li data-generated-css=\"brz-css-iTbOJ\" data-uniq-id=\"xLJ3q\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"https://ucpi.sco.ca.gov/ucp/\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">California Unclaimed Oil and Gas Royalty</a></li><li data-generated-css=\"brz-css-zk1JE\" data-uniq-id=\"ix36l\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"http://www.fltreasurehunt.org/ControlServlet?ActionForm=GotoNewPublicSearch\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Florida Unclaimed Oil and Gas Royalty</a></li><li data-generated-css=\"brz-css-rxXLB\" data-uniq-id=\"twD_P\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"https://icash.illinois.gov/\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Illinois Unclaimed Oil and Gas Royalty</a></li><li data-generated-css=\"brz-css-pAWRj\" data-uniq-id=\"wM8x8\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"http://www.kansascash.com/prodweb/up/disclaimer_page.php\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Kansas Unclaimed Oil and Gas Royalty</a></li><li data-generated-css=\"brz-css-saB1q\" data-uniq-id=\"caR4e\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"https://treasurer.nebraska.gov/up/default.aspx\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Nebraska Unclaimed Oil and Gas Royalty</a></li><li data-generated-css=\"brz-css-tR1VU\" data-uniq-id=\"yZJ0x\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"http://revenue.mt.gov/home/businesses/unclaimed_property.aspx\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Montana Unclaimed Oil and Gas Royalty</a></li></ul></div></div></div></div></div><div><div><div id=\"\"><div><div data-brz-translate-text=\"1\"><ul><li data-uniq-id=\"x7ff1\" data-generated-css=\"brz-css-mbGvW\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"https://treasurer.nebraska.gov/up/default.aspx\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Nebraska Unclaimed Oil and Gas Royalty</a></li><li data-uniq-id=\"a7WKb\" data-generated-css=\"brz-css-darKH\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"http://www.osc.state.ny.us/ouf/index.htm\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">New York Unclaimed Oil and Gas Royalty</a></li><li data-uniq-id=\"ofedc\" data-generated-css=\"brz-css-ezEs5\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"http://www.com.ohio.gov/unfd/TreasureHunt.aspx\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Ohio Unclaimed Oil and Gas Royalty</a></li><li data-uniq-id=\"rO3kz\" data-generated-css=\"brz-css-aBNr0\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"https://www.ok.gov/unclaimed/index.php\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Oklahoma Unclaimed Oil and Gas Royalty</a></li><li data-uniq-id=\"n98Dr\" data-generated-css=\"brz-css-pEWVa\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"http://www.patreasury.org/unclaimedProperty.html\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Pennsylvania Unclaimed Oil and Gas Royalty</a></li><li data-uniq-id=\"fkJjv\" data-generated-css=\"brz-css-dMEKz\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"http://www.window.state.tx.us/up/\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Texas Unclaimed Oil and Gas Royalty</a></li><li data-uniq-id=\"yuNGf\" data-generated-css=\"brz-css-fX3eG\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"https://www.wvsto.com/Unclaimed-Property/Search-Claim\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">West Virginia Unclaimed Oil and Gas Royalty</a></li><li data-uniq-id=\"y9FnR\" data-generated-css=\"brz-css-iCkNt\" style=\"color: rgba(var(--brz-global-color1),1);\"><a style=\"color: rgba(var(--brz-global-color1),1);\" href=\"http://treasurer.state.wy.us/upsearch.asp\" data-brz-link-type=\"external\" target=\"_blank\" rel=\"noreferrer noopener\">Wyoming Unclaimed Oil and Gas Royalty</a></li></ul><p data-uniq-id=\"fl1sG\" data-generated-css=\"brz-css-juCtl\"><br></p></div></div></div></div></div></div></div><div id=\"\"><div><div data-brz-translate-text=\"1\"><p data-generated-css=\"brz-css-kevn8\" data-uniq-id=\"meKqC\"><strong>Additional Reading</strong></p><ul><li data-generated-css=\"brz-css-kN14F\" data-uniq-id=\"pko7U\"><a href=\"/cash-payment-for-oil-and-gas-royalty\" data-brz-link-type=\"page\">Cash payment for oil and gas royalty</a><span> – Learn how to exchange your oil and gas royalties or mineral rights for cash. </span></li><li data-generated-css=\"brz-css-dWxt1\" data-uniq-id=\"mImdr\"><a href=\"/division-order-2\" data-brz-link-type=\"page\">Division Order</a><span> – Explanation of oil and gas Division Orders for mineral, royalty, and overriding royalty owners. Answers to questions, definitions, and sources for help.</span></li></ul></div></div></div></div></div></section>\n    <section id=\"5476867bb5c0d4e2e43a4df2533e422b_5476867bb5c0d4e2e43a4df2533e422b\"><div><div></div><div><div><div><div><div><div id=\"\"><div><picture><source srcset=\"https://cloud-1de12d.becdn.net/media/original/488fd98860cfae6b4691a5a995cb88d2/MineralWise-Logo-Transparent.png, https://cloud-1de12d.becdn.net/media/original/488fd98860cfae6b4691a5a995cb88d2/MineralWise-Logo-Transparent.png\" media=\"(min-width: 992px)\"><source srcset=\"https://cloud-1de12d.becdn.net/media/original/488fd98860cfae6b4691a5a995cb88d2/MineralWise-Logo-Transparent.png, https://cloud-1de12d.becdn.net/media/original/488fd98860cfae6b4691a5a995cb88d2/MineralWise-Logo-Transparent.png\" media=\"(min-width: 768px)\"><img srcset=\"ht