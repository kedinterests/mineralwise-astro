---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Michigan Mineral Rights | MineralWise";
const metaDescription = "Michigan Mineral Rights contain a vast resource of hydrocarbon. Michigan state geologist Alexander Winchell was the first to report the presence of oil and natu";

const stateName = "Michigan";
const stateAbbr = "MI";
const description = "Michigan Mineral Rights contain a vast resource of hydrocarbon. Michigan state geologist Alexander Winchell was the first to report the presence of oil and natu";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/michigan-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
