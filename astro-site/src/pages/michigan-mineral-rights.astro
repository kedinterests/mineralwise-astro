---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Michigan Mineral Rights | MineralWise";
const metaDescription = "Michigan Mineral Rights contain a vast resource of hydrocarbon. Michigan state geologist Alexander Winchell was the first to report the presence of oil and natural gas in 1860.";

const stateName = "Michigan";
const stateAbbr = "MI";
const description = "Michigan Mineral Rights contain a vast resource of hydrocarbon. Michigan state geologist Alexander Winchell was the first to report the presence of oil and natural gas in 1860. The first oil was discovered in Saginaw in 1925, and in 1928 Mt. Pleasant's oil field helped that city to become the \"Oil Capitol of Michigan\". Currently Michigan is the 12th largest natural gas producer and the 17th largest crude oil producer in the United States. The abundant mineral rights resources protected Michigan from much of the Great Depression.";

const stats = [];
const majorFields = [
	"Beaver Creek Field",
	"East Norwich Field",
	"Enterprise Field",
	"Kawkawlin Field",
	"Rich Field",
	"Rose City Field",
	"Springdale Township Field",
	"Walker Oil Field",
	"White River Field",
	"Williams Field"
];
const companies = [
	"Dart Oil and Gas",
	"Howard Energy",
	"Jordan Development",
	"Mercury Exploration",
	"Merit Energy",
	"Muskegon Development",
	"Omimex Energy",
	"Quicksilver Resources",
	"Summit Petroleum",
	"White River Production"
];
const regulatoryLink = {
	text: "http://www.michigan.gov/deq/",
	href: "http://www.michigan.gov/deq/",
	external: true
};
const additionalReading = [
	{
		text: "Oil & Gas 101",
		href: "/owners-guide/oil-and-gas-basics-for-mineral-owners",
		external: false
	}
];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/michigan-mineral-rights')}>
		<ArticleContent>
			<StatePage
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
				majorFields={majorFields}
				companies={companies}
				regulatoryLink={regulatoryLink}
				additionalReading={additionalReading}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
