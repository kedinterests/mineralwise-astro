		margin-top: 2.5rem;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}

	.content-body h2:first-of-type {
		margin-top: 0;
	}

	.content-body p {
		margin-bottom: 1.25rem;
	}

	.content-body p:last-child {
		margin-bottom: 0;
	}

	.content-body ul {
		margin: 1.25rem 0;
		padding-left: 1.5rem;
	}

	.content-body li {
		margin-bottom: 0.75rem;
	}

	.content-body a {
		color: #0ea5e9;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.content-body a:hover {
		color: #0284c7;
		text-decoration: underline;
	}

	.content-body strong {
