---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Abandoned Well";
const description = "A well no longer in use, whether dry, inoperable or no longer productive.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Abandoned Well"
		definition="A well no longer in use, whether dry, inoperable or no longer productive."
		path="/abandoned-well"
		nextTerm={{ href: "/acre-feet", label: "Acre-Feet" }}
	/>
</BaseLayout>
