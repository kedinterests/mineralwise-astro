---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Top Lease";
const description = "An oil and gas lease which becomes effective only after the expiration (or termination) of an existing lease upon the subject land tract.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Top Lease"
		definition="An oil and gas lease which becomes effective only after the expiration (or termination) of an existing lease upon the subject land tract."
		path="/top-lease"
		prevTerm={{ href: "/title-curative", label: "Title Curative" }}
		nextTerm={{ href: "/transporter", label: "Transporter" }}
	/>
</BaseLayout>
