---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "MMBtu";
const description = "One million British thermal units; a measurement of heating value.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="MMBtu"
		definition="One million British thermal units; a measurement of heating value."
		path="/mmbtu"
		prevTerm={{ href: "/mineral-title", label: "Mineral Title" }}
		nextTerm={{ href: "/mmcf", label: "Mmcf" }}
	/>
</BaseLayout>
