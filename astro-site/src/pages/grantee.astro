---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Grantee";
const description = "The person receiving lands, minerals, etc.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Grantee"
		definition="The person receiving lands, minerals, etc."
		path="/grantee"
		prevTerm={{ href: "/geophone", label: "Geophone" }}
		nextTerm={{ href: "/gun-barrel-separator", label: "Gun Barrel Separator" }}
	/>
</BaseLayout>
