---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Pounds Per Square Inch, PSI";
const description = "An English system of measure of the amount of pressure on an area that is 1 inch square.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Pounds Per Square Inch, PSI"
		definition="An English system of measure of the amount of pressure on an area that is 1 inch square."
		path="/pounds-per-square-inch-psi"
		prevTerm={{ href: "/possible-reserves", label: "Possible Reserves" }}
		nextTerm={{ href: "/primary-term", label: "Primary Term" }}
	/>
</BaseLayout>
