---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Royalty Statement";
const description = "Account of finances that details a wells production and prices received.&amp;nbsp;Mineral Owners receive these monthly or as revenue crosses certain thresholds depending on the state and operator.This glossary of common oil and gas terms and definitions will aid newcomers as well as experienced royalty owners or mineral owners with the terminology used in the Oil and Gas industry. We also have a page of Oil and Gas Abbreviations and Acronyms. These are some of the most commonly used oil and gas terms. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Royalty Statement"
		definition="Account of finances that details a wells production and prices received.&nbsp;Mineral Owners receive these monthly or as revenue crosses certain thresholds depending on the state and operator."
		path="/royalty-statement"
		prevTerm={{ href: "/royalty-percentage", label: "Royalty Percentage" }}
		nextTerm={{ href: "/salt-water-disposal-well-swd", label: "Salt Water Disposal Well Swd" }}
	/>
</BaseLayout>
