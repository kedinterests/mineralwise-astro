---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Swab, Swabbing";
const description = "The process of mechanically pulling (or lifting) liquids from a well bore.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Swab, Swabbing"
		definition="The process of mechanically pulling (or lifting) liquids from a well bore."
		path="/swab-swabbing"
		prevTerm={{ href: "/suspended-funds", label: "Suspended Funds" }}
		nextTerm={{ href: "/sweet-gas", label: "Sweet Gas" }}
	/>
</BaseLayout>
