---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Slawson Exploration | MineralWise";
const description = "Slawson Exploration";

const companyDescription = `is an oil and gas exploration and production company based in Wichita Kansas. Slawson has drilled over 3,500 wells. Slawson Exploration focuses on the Northern Rockies, California, the Anadarko Basin, Gulf Coast, South Texas, and Western Kansas.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/slawson-exploration')}>
		<ArticleContent>
			<CompanyPage
				companyName="Slawson Exploration"
				description={companyDescription}
				logoPath="/images/slawson.png"
				contactPhone="(713) 759-1311"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
