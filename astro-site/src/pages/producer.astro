---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Producer";
const description = "A producer of oil and gas, also sometimes referred to as an Operator, or the Oil Company.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Producer"
		definition="A producer of oil and gas, also sometimes referred to as an Operator, or the Oil Company."
		path="/producer"
		prevTerm={{ href: "/processing-plant", label: "Processing Plant" }}
		nextTerm={{ href: "/producing-mineral-interests", label: "Producing Mineral Interests" }}
	/>
</BaseLayout>
