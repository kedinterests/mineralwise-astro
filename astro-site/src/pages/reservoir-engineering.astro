---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Reservoir Engineering";
const description = "The application of scientific and engineering principles to the production from a developed reservoir for maximum economic return.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Reservoir Engineering"
		definition="The application of scientific and engineering principles to the production from a developed reservoir for maximum economic return."
		path="/reservoir-engineering"
		prevTerm={{ href: "/reservoir", label: "Reservoir" }}
		nextTerm={{ href: "/residue-gas", label: "Residue Gas" }}
	/>
</BaseLayout>
