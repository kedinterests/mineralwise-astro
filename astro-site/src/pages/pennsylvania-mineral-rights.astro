---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Pennsylvania Mineral Rights | MineralWise";
const metaDescription = "Pennsylvania Mineral Rights have a rich history all the way back to 1859 in Titusville, PA when the first successful oil well was drilled in America. The Drake ";

const stateName = "Pennsylvania";
const stateAbbr = "PA";
const description = "Pennsylvania Mineral Rights have a rich history all the way back to 1859 in Titusville, PA when the first successful oil well was drilled in America. The Drake ";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/pennsylvania-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
