---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import OwnerGuideTabs from '../components/OwnerGuideTabs.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Maximize Your Oil and Gas Lease Proposal – Expert Tips for Mineral Owners";
const description = "Unlock the full potential of your oil and gas mineral rights. Learn expert tips, avoid common mistakes, and negotiate the best lease terms with our comprehensive guide to oil and gas leasing.";

const heading = "I just received an oil and gas lease proposal…";
const intro = "Each day, mineral owners are contacted with a proposal regarding leasing oil and gas mineral interests. Unfortunately many of them don't do their homework and miss available upside. However, those willing to do a little homework can maximize the benefits from their mineral rights. The articles below will guide you through the oil and gas leasing process. If you would like to discuss mineral rights related issues with other landowners visit MineralRightsForum.com.";

const tabs = [
	{
		label: "Lease Basics",
		id: "basics",
		articles: [
			{
				title: "Oil & Gas Lease Forms",
				href: "/oil-gas-lease-forms",
				description: "Is there a \"Standard\" oil & gas lease form? We discuss this common misconception."
			},
			{
				title: "Pugh Clause",
				href: "/pugh-clause-2",
				description: "Article discussing the merits and uses of the Pugh Clause in oil and gas leasing. Explains vertical Pugh Clauses and alternatives to the Pugh Clause."
			},
			{
				title: "Non-Participating Royalty Interest",
				href: "/non-participating-royalty-interest-npri",
				description: "Learn what a NPRI is and reasons one might be assigned."
			},
			{
				title: "Bank Sight Drafts",
				href: "/bank-drafts-oil-and-gas-leasing",
				description: "Short article describing how bank sight drafts work in oil and gas leasing. Includes a sample form 30 day draft, and alternatives to drafts."
			}
		]
	},
	{
		label: "Negotiation Tips",
		id: "negotiation",
		articles: [
			{
				title: "Oil & Gas Leasing: 10 Things To Make Sure You Do",
				href: "/oil-and-gas-leasing-top-10-things-to-do",
				description: "Discover valuable tips for negotiating an oil and gas lease. Avoid costly mistakes when negotiating your oil and gas lease."
			},
			{
				title: "Oil & Gas Leases: 10 Common Mistakes During Mineral Lease Negotiation",
				href: "/oil-and-gas-leases-10-common-mistakes-during-mineral-lease-negotiation",
				description: "10 common mistakes to avoid when negotiating an oil & gas lease. A sister article, 10 Things To Make Sure You Do, is also available."
			}
		]
	}
];
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/lease-proposals')}>
		<ArticleContent>
			<OwnerGuideTabs 
				heading={heading}
				intro={intro}
				tabs={tabs}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
