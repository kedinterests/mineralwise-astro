---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Sedimentary Rock";
const description = "Rock made up of aggregated sediments.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Sedimentary Rock"
		definition="Rock made up of aggregated sediments."
		path="/sedimentary-rock"
		prevTerm={{ href: "/secondary-recovery", label: "Secondary Recovery" }}
		nextTerm={{ href: "/separator", label: "Separator" }}
	/>
</BaseLayout>
