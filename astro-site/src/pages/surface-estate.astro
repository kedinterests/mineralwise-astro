---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Surface Estate";
const description = "Rights and interests in the surface of land as opposed to the mineral estate.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Surface Estate"
		definition="Rights and interests in the surface of land as opposed to the mineral estate."
		path="/surface-estate"
		prevTerm={{ href: "/surface-casing", label: "Surface Casing" }}
		nextTerm={{ href: "/surface-owner", label: "Surface Owner" }}
	/>
</BaseLayout>
