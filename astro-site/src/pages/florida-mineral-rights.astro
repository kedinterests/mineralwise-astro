---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Florida Mineral Rights | MineralWise";
const metaDescription = "Florida mineral rights are wide and varied. Florida’s first producing oil well, the Sunniland No. 1, was drilled in September 1943 by the Humble Oil Co. This we";

const stateName = "Florida";
const stateAbbr = "FL";
const description = "Florida mineral rights are wide and varied. Florida’s first producing oil well, the Sunniland No. 1, was drilled in September 1943 by the Humble Oil Co. This we";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/florida-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
