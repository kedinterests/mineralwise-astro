---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Vaquero Energy, Inc. | MineralWise";
const description = "Vaquero Energy, Inc.";

const companyDescription = `Vaquero Energy is a privately-held oil and gas exploration and production company with headquarters in Bakersfield, California. The Company was founded in 2000.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/vaquero-energy-inc')}>
		<ArticleContent>
			<CompanyPage
				companyName="Vaquero Energy, Inc."
				description={companyDescription}
				logoPath="/images/vaquero-energy-inc.jpg"
				contactPhone="(661) 616-0600"
				showProductionVerification={true}
				showCashPayment={true}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
