---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/starwind/button/Button.astro';
import { Fragment } from 'astro/jsx-runtime';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'home');
if (!page) {
	throw new Error('Home page content not found');
}

const { Content } = await render(page);
const { title, description, heroTitle, heroTagline } = page.data;
---

<BaseLayout title={title} description={description} adConfig="home">
	<Fragment slot="head">
		<link rel="preload" href="/images/hero-768.webp" as="image" type="image/webp" media="(max-width: 768px)" />
		<link rel="preload" href="/images/hero.webp" as="image" type="image/webp" media="(min-width: 769px)" />
	</Fragment>
	<style>
		:global(main) {
			width: 100% !important;
			max-width: 100% !important;
			padding: 0 !important;
		}
		.ad-slot {
			display: flex;
			justify-content: center;
			margin: 1rem 0;
			min-height: 50px;
			background: white;
		}
		.ad-slot.ad-ac {
			padding: 1.5rem 0;
		}
		/* Reserve space to prevent CLS - aspect-ratio + min-height */
		.hero-section {
			aspect-ratio: 2 / 1;
			max-height: 550px;
		}
		#hero-background {
			background: #1a1a1a;
		}
		#hero-background picture,
		#hero-background img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			object-position: center 30%;
		}
		#hero-background picture {
			display: block;
			position: absolute;
			inset: 0;
		}
		#hero-background img {
			display: block;
			position: absolute;
			inset: 0;
		}
		@media (max-width: 767px) {
			.hero-section {
				aspect-ratio: 4 / 3;
				min-height: 375px;
			}
			.hero-content {
				max-width: 100%;
				margin-left: 0;
				margin-right: 35% ;
			}
		}
		.hero-cta-btn {
			background: var(--accent) !important;
			color: white !important;
		}
		.hero-cta-btn:hover {
			background: var(--accent-dark) !important;
			color: white !important;
		}
		.home-content :global(h2) {
			font-size: 1.5rem;
			font-weight: 800;
			margin-top: 2.5rem;
			margin-bottom: 1rem;
			color: rgb(17 24 39);
		}
		.home-content :global(h2:first-child) {
			margin-top: 0;
			font-size: 2.25rem;
		}
		.home-content :global(p) {
			font-size: 1.125rem;
			line-height: 1.75;
			color: rgb(55 65 81);
			margin-bottom: 1rem;
		}
		:global(.dark) .home-content :global(h2) {
			color: white;
		}
		:global(.dark) .home-content :global(p) {
			color: rgb(209 213 219);
		}
	</style>
	
	<!-- Hero Section with Full-Width Background -->
	<section class="hero-section relative flex items-center w-full overflow-hidden">
		<!-- Background Image - Optimized WebP, responsive srcset -->
		<div id="hero-background" class="absolute inset-0">
			<picture class="block absolute inset-0">
				<source
					type="image/webp"
					srcset="
						/images/hero-480.webp 480w,
						/images/hero-768.webp 768w,
						/images/hero-1200.webp 1200w,
						/images/hero.webp 1536w
					"
					sizes="100vw"
				/>
				<img
					src="/images/hero.webp"
					alt=""
					width="1536"
					height="1024"
					loading="eager"
					decoding="sync"
				/>
			</picture>
		</div>
		
		<!-- Gradient Overlay from Left to Right -->
		<div class="absolute inset-0" style="background: linear-gradient(to right, black 0%, transparent 80%);"></div>		
		<!-- Content Container - Left Side (where gradient is darkest) -->
		<div class="hero-content relative z-10 container mx-auto px-4 max-w-7xl w-full">
			<div class="max-w-2xl text-white">
				<h1 class="text-3xl md:text-7xl font-black mb-6 tracking-tight text-white" set:html={heroTitle?.replace(/\n/g, '<br />') ?? 'Insight for<br />Mineral Owners'} />
				<p class="text-lg md:text-2xl mb-8 font-light text-white">
					{heroTagline ?? "Empowering mineral rights owners with education, opportunity, and insights."}
				</p>
				<Button href="/owners-guide" variant="primary" size="lg" class="hero-cta-btn px-8 py-4 text-lg font-semibold">
					Mineral Owners Start Here
				</Button>
			</div>
		</div>
	</section>

	<!-- Main Content Section -->
	<section class="mt-8 md:mt-16 pt-4 bg-white dark:bg-neutral-950 w-full">
		<div class="container mx-auto px-4 max-w-6xl">
			<!-- Two Column Layout: Mineral Rights Text + Sticky Questions -->
			<div class="grid grid-cols-1 md:grid-cols-[60%_40%] gap-12 mb-16" id="content-scroll-container">
				<!-- Left Column - Mineral Rights Content (CMS-editable) -->
				<div class="space-y-6 home-content">
					<div class="h-1 w-60 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full mb-6"></div>
					<Content />
				</div>

				<!-- Right Column - Sticky Questions Section -->
				<div id="sticky-questions" class="space-y-6">
					<div class="bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800 rounded-sm p-8 border border-gray-200 dark:border-gray-700 shadow-lg">
						<h2 class="text-3xl md:text-4xl font-black mb-4 text-gray-900 dark:text-white text-center">
							Questions about Mineral Rights?
						</h2>
						<p class="text-lg text-gray-600 dark:text-gray-400 mb-6 text-center">
							Click the link that best describes<br>your situation.
						</p>
						<ul class="space-y-4">
							<li>
								<a href="/owners-guide/leased-and-producing" class="group flex items-start gap-3 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:underline font-semibold text-lg transition-colors">
									<span class="mt-2.5 h-2 w-2 shrink-0 rounded-full bg-blue-600 dark:bg-blue-400"></span>
									<span>My mineral rights are leased and producing.</span>
								</a>
							</li>
							<li>
								<a href="/owners-guide/unleased-mineral-owner" class="group flex items-start gap-3 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:underline font-semibold text-lg transition-colors">
									<span class="mt-2.5 h-2 w-2 shrink-0 rounded-full bg-blue-600 dark:bg-blue-400"></span>
									<span>I am an un-leased mineral rights owner.</span>
								</a>
							</li>
							<li>
								<a href="/owners-guide/leased-but-not-producing" class="group flex items-start gap-3 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:underline font-semibold text-lg transition-colors">
									<span class="mt-2.5 h-2 w-2 shrink-0 rounded-full bg-blue-600 dark:bg-blue-400"></span>
									<span>My mineral rights are leased but not producing.</span>
								</a>
							</li>
							<li>
								<a href="/owners-guide/lease-proposals" class="group flex items-start gap-3 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:underline font-semibold text-lg transition-colors">
									<span class="mt-2.5 h-2 w-2 shrink-0 rounded-full bg-blue-600 dark:bg-blue-400"></span>
									<span>I just received an oil or gas lease proposal - what's next?</span>
								</a>
							</li>
							<li>
								<a href="/offer" class="group flex items-start gap-3 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:underline font-semibold text-lg transition-colors">
									<span class="mt-2.5 h-2 w-2 shrink-0 rounded-full bg-blue-600 dark:bg-blue-400"></span>
									<span>I am interested in a cash payment for my minerals.</span>
								</a>
							</li>
						</ul>
					</div>
				</div>
			</div>

		</div>
	</section>

	<script>
		// Sticky questions section
		function initStickyQuestions() {
			const container = document.getElementById('content-scroll-container');
			const stickyElement = document.getElementById('sticky-questions');
			
			if (!container || !stickyElement) return;
			
			function updateSticky() {
				const containerRect = container.getBoundingClientRect();
				const stickyRect = stickyElement.getBoundingClientRect();
				const headerHeight = 80; // Approximate header height
				
				// Calculate when to stop being sticky (when container bottom reaches sticky element bottom)
				const containerBottom = containerRect.bottom;
				const stickyBottom = stickyRect.bottom;
				const shouldStick = containerRect.top <= headerHeight && containerBottom > stickyBottom;
				
				if (shouldStick) {
					stickyElement.style.position = 'sticky';
					stickyElement.style.top = `${headerHeight}px`;
				} else {
					stickyElement.style.position = 'relative';
					stickyElement.style.top = '0';
				}
			}
			
			let ticking = false;
			function onScroll() {
				if (!ticking) {
					window.requestAnimationFrame(() => {
						updateSticky();
						ticking = false;
					});
					ticking = true;
				}
			}
			
			window.addEventListener('scroll', onScroll, { passive: true });
			updateSticky(); // Initial call
		}
		
		// Initialize when DOM is ready
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initStickyQuestions);
		} else {
			initStickyQuestions();
		}
	</script>
</BaseLayout>
