---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Brine";
const description = "Another word for salt water.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Brine"
		definition="Another word for salt water."
		path="/brine"
		prevTerm={{ href: "/bottom-hole-pressure-bhp", label: "Bottom Hole Pressure, BHP" }}
		nextTerm={{ href: "/british-thermal-unit-btu", label: "British Thermal Unit, BTU" }}
	/>
</BaseLayout>
