---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Surface Rights";
const description = "The set of rights associated with the surface of the land only, as differentiated from mineral rights.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Surface Rights"
		definition="The set of rights associated with the surface of the land only, as differentiated from mineral rights."
		path="/surface-rights"
		prevTerm={{ href: "/surface-owner", label: "Surface Owner" }}
		nextTerm={{ href: "/suspended-funds", label: "Suspended Funds" }}
	/>
</BaseLayout>
