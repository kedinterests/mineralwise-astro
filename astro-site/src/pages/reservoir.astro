---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Reservoir";
const description = "A porous, permeable sedimentary rock containing oil and gas.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Reservoir"
		definition="A porous, permeable sedimentary rock containing oil and gas."
		path="/reservoir"
		prevTerm={{ href: "/reserve-pit-mud-pit", label: "Reserve Pit Mud Pit" }}
		nextTerm={{ href: "/reservoir-engineering", label: "Reservoir Engineering" }}
	/>
</BaseLayout>
