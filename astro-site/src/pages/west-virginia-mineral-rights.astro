---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "West Virginia Mineral Rights | MineralWise";
const metaDescription = "West Virginia Mineral Rights have a history that goes back to the time when Indians primarily occupied the land. Native Americans called natural gas vents \\\\";

const stateName = "West Virginia";
const stateAbbr = "WV";
const description = "West Virginia Mineral Rights have a history that goes back to the time when Indians primarily occupied the land. Native Americans called natural gas vents \\\\";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/west-virginia-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
