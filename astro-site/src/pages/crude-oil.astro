---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Crude Oil";
const description = "Raw, liquid petroleum as it comes out of the ground as distinguished from refined oils manufactured from it.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Crude Oil"
		definition="Raw, liquid petroleum as it comes out of the ground as distinguished from refined oils manufactured from it."
		path="/crude-oil"
		prevTerm={{ href: "/cost-depletion", label: "Cost Depletion" }}
		nextTerm={{ href: "/cubic-foot-of-gas-standard-cubic-foot-of-gas", label: "Cubic Foot of Gas, Standard Cubic Foot of Gas" }}
	/>
</BaseLayout>
