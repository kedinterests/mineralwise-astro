---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Pooled Unit";
const description = "Unit created by combining separate mineral interests under the pooling clause of a lease or agreement.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Pooled Unit"
		definition="Unit created by combining separate mineral interests under the pooling clause of a lease or agreement."
		path="/pooled-unit"
		prevTerm={{ href: "/play", label: "Play" }}
		nextTerm={{ href: "/porosity", label: "Porosity" }}
	/>
</BaseLayout>
