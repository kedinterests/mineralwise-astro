---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Probable Reserves";
const description = "Probable reserves are less certain than Proved reserves and can be estimated with a degree of certainty sufficient to indicate that they are more likely to be recovered than not. Used to refer to reserves that have a 50% or greater chance of being produced (P50).";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Probable Reserves"
		definition="Probable reserves are less certain than Proved reserves and can be estimated with a degree of certainty sufficient to indicate that they are more likely to be recovered than not. Used to refer to reserves that have a 50% or greater chance of being produced (P50)."
		path="/probable-reserves"
		prevTerm={{ href: "/primary-term", label: "Primary Term" }}
		nextTerm={{ href: "/processing-plant", label: "Processing Plant" }}
	/>
</BaseLayout>
