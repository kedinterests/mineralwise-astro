---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Shell Oil Company | MineralWise";
const description = "The Royal Dutch/Shell Group popularly known as Shell Oil Company is one of the largest major oil companies. Shell Oil stock is listed on the NYSE under the symbol RDS.A. The head office in the U.S. is in Houston, Texas. Shell Oil Company services include oil production and exploration motor oil, and credit cards.";

const companyDescription = `The Royal Dutch/Shell Group popularly known as Shell Oil Company is one of the largest major oil companies. Shell Oil stock is listed on the NYSE under the symbol RDS.A. The head office in the U.S. is in Houston, Texas. Shell Oil Company services include oil production and exploration motor oil, and credit cards.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/shell-oil-company')}>
		<ArticleContent>
			<CompanyPage
				companyName="Shell Oil Company"
				description={companyDescription}
				logoPath="/images/shell-oil-.png"
				contactPhone="(281) 544-2600"
				showProductionVerification={true}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
