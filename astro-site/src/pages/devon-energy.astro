---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Devon Energy | MineralWise";
const description = "Devon Energy is one of the top 10 public independent oil and gas producers based in the United States. Devon Energy stock is listed on the NYSE under the symbol DVN. Headquartered in Oklahoma City, Devon has approximately 5,500 employees worldwide.";

const companyDescription = `Devon Energy is one of the top 10 public independent oil and gas producers based in the United States. Devon Energy stock is listed on the NYSE under the symbol DVN. Headquartered in Oklahoma City, Devon has approximately 5,500 employees worldwide. Devon is a Fortune 500 company and is included in the S&P 500 Index. Devon Energy Corporation produces oil and natural gas onshore and offshore in the United States, in Canada and internationally. The company's portfolio of oil and gas properties provides stable, environmentally responsible production and a platform for future growth.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/devon-energy')}>
		<ArticleContent>
			<CompanyPage
				companyName="Devon Energy"
				description={companyDescription}
				logoPath="/images/devon-energy.png"
				contactPhone="(405) 228-4800"
				showProductionVerification={true}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
