---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Advertise on MineralWise | Reach America's Mineral Owners with Targeted Ads";
const description = "Maximize your business visibility with MineralWise! Discover effective advertising options like display ads starting at $995/month or targeted Google AdWords placements. Connect with America's mineral owners today!";
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/advertising')}>
		<ArticleContent>
			<div class="advertising-page">
				<h1>Advertise on MineralWise</h1>
				<p class="intro">
					Want to reach America's mineral owners? We provide several advertising options, one of which will likely fit your needs:
				</p>

				<ul class="advertising-options">
					<li>
						<strong><em>Display Advertising</em></strong> – Designed for broad brand recognition through image ads that drive traffic to your website. Starting at $995 per month. It's easier than you may think.
					</li>
					<li>
						<strong><em>Targeted Placement via Google AdWords</em></strong> – Designate MineralWise as a targeted Placement within your AdWords campaign.
					</li>
				</ul>

				<p class="connect-text">
					We are happy to discuss growing your business reaching America's mineral owners. Connect with us through the form below.
				</p>
				
				<div class="advertising-form-wrapper">
					<iframe 
						aria-label="MineralWise - Advertising" 
						frameborder="0" 
						src="https://forms.zohopublic.com/kedinterestsllc/form/MineralWiseAdvertising/formperma/etZvM0gK5qGJolKGx-8fHuqMMAsNcKFaNSkJNYAyUcc"
						title="Advertising Form"
					></iframe>
				</div>
			</div>
		</ArticleContent>
	</PageShell>
</BaseLayout>

<style>
	.advertising-page {
		background: white;
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
	}

	.advertising-page h1 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}

	.intro {
		font-size: 1.125rem;
		color: #666;
		margin-bottom: 1.5rem;
		line-height: 1.6;
	}

	.advertising-options {
		list-style: none;
		padding: 0;
		margin: 0 0 2rem 0;
	}

	.advertising-options li {
		font-size: 1.0625rem;
		line-height: 1.7;
		color: #374151;
		margin-bottom: 1.25rem;
		padding-left: 1.5rem;
		position: relative;
	}

	.advertising-options li:before {
		content: "•";
		color: #0ea5e9;
		font-weight: bold;
		font-size: 1.5rem;
		position: absolute;
		left: 0;
		line-height: 1.2;
	}

	.advertising-options li:last-child {
		margin-bottom: 0;
	}

	.advertising-options strong {
		color: #1a1a1a;
		font-weight: 600;
	}

	.connect-text {
		font-size: 1.0625rem;
		color: #374151;
		margin-bottom: 2rem;
		line-height: 1.7;
	}

	.advertising-form-wrapper {
		width: 100%;
		border-radius: 8px;
		overflow: hidden;
		background: #f9fafb;
		border: 1px solid #e5e7eb;
	}

	.advertising-form-wrapper iframe {
		width: 100%;
		height: 1100px;
		border: none;
		display: block;
	}

	@media (max-width: 640px) {
		.advertising-page {
			padding: 1.5rem;
		}

		.advertising-page h1 {
			font-size: 2rem;
		}

		.advertising-options li {
			padding-left: 1.25rem;
			font-size: 1rem;
		}

		.advertising-form-wrapper iframe {
			height: 900px;
		}
	}
</style>
