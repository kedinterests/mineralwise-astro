---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Shut In Royalty";
const description = "Payment to royalty owners under the terms of a lease which allows the lessee to defer production from a well capable of producing but shut in for lack of a market.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Shut In Royalty"
		definition="Payment to royalty owners under the terms of a lease which allows the lessee to defer production from a well capable of producing but shut in for lack of a market."
		path="/shut-in-royalty"
		prevTerm={{ href: "/severed-minerals", label: "Severed Minerals" }}
		nextTerm={{ href: "/sight-draft", label: "Sight Draft" }}
	/>
</BaseLayout>
