---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Commodities";
const description = "Widely produced products whose quality is indistinguishable regardless of where it comes from. Examples include agricultural products, energy products, metals, currencies etc.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Commodities"
		definition="Widely produced products whose quality is indistinguishable regardless of where it comes from. Examples include agricultural products, energy products, metals, currencies etc."
		path="/commodities"
		prevTerm={{ href: "/commercial-well-aka-producing-well", label: "Commercial Well (aka Producing Well)" }}
		nextTerm={{ href: "/commodity-prices", label: "Commodity Prices" }}
	/>
</BaseLayout>
