---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Fragment } from 'astro/jsx-runtime';

const title = "Directory | MineralWise";
const description = "Explore the MineralWise directory of oil and gas operators, fields, and shale plays for research and contact information.";

const content = "<div>\n    <section id=\"kwlCmwdWzAvr_kwlCmwdWzAvr\"><div><div><div><div><div><h1><span>Directory</span></h1></div></div></div><div><div><div><p><span>The  Directory includes contact information and  general data about oil and gas Operators, information on oil and gas  fields in your area, and articles about the  various natural shale plays.</span></p><p></p><ul><li><span style=\"color: rgb(12, 42, 233);\">Research Your Operator</span><span> – Learn more about your Operator - includes contact information, history, volume verification, and other tips for royalty owners.</span></li><li><span style=\"color: rgb(12, 42, 233);\">Field Profiles</span><span> – Includes geographical data, production zones, and active companies within specific fields.</span></li><li><span style=\"color: rgb(12, 42, 233);\">Shale Plays</span><span> – Includes a list of Producers within each shale play, as well as geological and county location information.</span></li></ul></div></div></div></div></div></section>";
---

<BaseLayout title={title} description={description}>
	<article class="content-wrapper">
		<div class="content-section">
			<Fragment set:html={content} />
		</div>
	</article>
</BaseLayout>
