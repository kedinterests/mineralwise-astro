---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Initial Production, IP";
const description = "The rate of initial flow from a well.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Initial Production, IP"
		definition="The rate of initial flow from a well."
		path="/initial-production-ip"
		prevTerm={{ href: "/infill-drilling", label: "Infill Drilling" }}
		nextTerm={{ href: "/injection-well", label: "Injection Well" }}
	/>
</BaseLayout>
