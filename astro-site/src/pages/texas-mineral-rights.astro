---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import StatePage from '../components/StatePage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "Texas Mineral Rights | MineralWise";
const metaDescription = "Texas Mineral Rights have a long history going back to the time when Texas was under the Spanish and Mexican flags. Texas mineral rights are even written in the";

const stateName = "Texas";
const stateAbbr = "TX";
const description = "Texas Mineral Rights have a long history going back to the time when Texas was under the Spanish and Mexican flags. Texas mineral rights are even written in the";

const stats = [];
const majorFields = [];
const companies = [];

const additionalReading = [];
---

<BaseLayout title={title} description={metaDescription}>
	<PageShell breadcrumbs={getBreadcrumbs('/texas-mineral-rights')}>
		<ArticleContent>
			<StatePage 
				stateName={stateName}
				stateAbbr={stateAbbr}
				description={description}
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
