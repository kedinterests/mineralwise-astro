---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Defects in Title";
const description = "Items which are or appear to be problematic with respect to having a clear title. Clear title would be a title with no questions or encumbrances as relating to ownership.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Defects in Title"
		definition="Items which are or appear to be problematic with respect to having a clear title. Clear title would be a title with no questions or encumbrances as relating to ownership."
		path="/defects-in-title"
		prevTerm={{ href: "/decline-rate", label: "Decline Rate" }}
		nextTerm={{ href: "/dehydration", label: "Dehydration" }}
	/>
</BaseLayout>
