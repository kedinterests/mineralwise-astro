---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import ArticleContent from '../components/ArticleContent.astro';
import CompanyPage from '../components/CompanyPage.astro';
import { getBreadcrumbs } from '../data/hierarchy';

const title = "J-W Operating Co. (Cohort Energy) | MineralWise";
const description = "J-W Operating Co. (Cohort Energy)";

const companyDescription = `Cohort Energy Company, a wholly owned subsidiary of J-W Operating Company, is a domestically oriented Exploration and Production company with most of its activities in the Ark-La-Tex, East Texas, North Texas, Rocky Mountains, and Gulf Coast regions.

Cohort Energy Company is based in Dallas, TX and is continually searching for high quality, multi-well opportunities.&nbsp;The company&nbsp;specializes in unconventional gas plays such as the tight gas sands and shale formations of North Louisiana and Texas, and similar formations in the Rockies and Appalachian Mountains.

Cohort utilizes the expertise of its parent company, J-W Operating Company, by contracting with it to drill and complete its wells. Cohort Energy operations include tight gas sand, coal bed methane, conventional gas plays and, most recently, its expansion into the Barnett Shale.`;
---

<BaseLayout title={title} description={description}>
	<PageShell breadcrumbs={getBreadcrumbs('/j-w-operating-co-cohort-energy')}>
		<ArticleContent>
			<CompanyPage
				companyName="J-W Operating Co. (Cohort Energy)"
				description={companyDescription}
				logoPath="/images/j-w-operating-co.png"
				contactPhone="(972) 233-8191"
				showProductionVerification={true}
				
			/>
		</ArticleContent>
	</PageShell>
</BaseLayout>
