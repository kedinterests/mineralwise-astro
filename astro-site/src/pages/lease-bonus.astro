---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Lease Bonus";
const description = "Usually the cash consideration that is paid by the lessee for the execution of an oil and gas lease by a landowner. It is usually based on a per acre payment.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Lease Bonus"
		definition="Usually the cash consideration that is paid by the lessee for the execution of an oil and gas lease by a landowner. It is usually based on a per acre payment."
		path="/lease-bonus"
		prevTerm={{ href: "/lease-automatic-custody-transfer-unit-lact-unit", label: "Lease Automatic Custody Transfer Unit Lact Unit" }}
		nextTerm={{ href: "/lessee", label: "Lessee" }}
	/>
</BaseLayout>
