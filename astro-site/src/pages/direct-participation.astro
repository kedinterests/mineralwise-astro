---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Direct Participation";
const description = "Financial participation in the direct costs of drilling a specific well or wells; as differentiated from owning an interest in an oil company stock, or partnership.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Direct Participation"
		definition="Financial participation in the direct costs of drilling a specific well or wells; as differentiated from owning an interest in an oil company stock, or partnership."
		path="/direct-participation"
		prevTerm={{ href: "/developmental-well", label: "Developmental Well" }}
		nextTerm={{ href: "/discovery-well", label: "Discovery Well" }}
	/>
</BaseLayout>
