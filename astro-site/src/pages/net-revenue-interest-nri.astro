---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPage from '../components/TermPage.astro';

const title = "Net Revenue Interest, NRI";
const description = "An owner’s interest in the revenues of a well.";
---

<BaseLayout title={title} description={description}>
	<TermPage
		term="Net Revenue Interest, NRI"
		definition="An owner’s interest in the revenues of a well."
		path="/net-revenue-interest-nri"
		prevTerm={{ href: "/natural-gas-liquids-ngl", label: "Natural Gas Liquids Ngl" }}
		nextTerm={{ href: "/non-participating-royalty-interest", label: "Non Participating Royalty Interest" }}
	/>
</BaseLayout>
